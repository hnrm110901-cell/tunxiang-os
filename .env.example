# TunxiangOS V3 环境变量模板
# 复制为 .env 并填入真实值

# ─── 数据库 ───
DATABASE_URL=postgresql+asyncpg://tunxiang:CHANGE_ME@localhost:5432/tunxiang_os
ALEMBIC_DATABASE_URL=postgresql://tunxiang:CHANGE_ME@localhost:5432/tunxiang_os
POSTGRES_USER=tunxiang
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=tunxiang_os

# 集团级跨品牌查询连接（必须使用 BYPASSRLS 权限角色）
# 该连接只授权访问 group_member_profiles 和 cross_brand_transactions 两张表
# 生产环境必须配置，禁止使用 dev 默认值
DATABASE_URL_GROUP=postgresql+asyncpg://group_service_role:CHANGE_ME@your-db-host/tunxiang_os

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=CHANGE_ME

# ─── AI ───
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ─── 收钱吧聚合支付(Shouqianba/Upay) ───
SHOUQIANBA_TERMINAL_SN=your_terminal_sn_here
SHOUQIANBA_TERMINAL_KEY=your_terminal_key_here
SHOUQIANBA_VENDOR_SN=your_vendor_sn_here
SHOUQIANBA_VENDOR_KEY=your_vendor_key_here

# ─── 域微服务端口 ───
TX_TRADE_URL=http://localhost:8001
TX_MENU_URL=http://localhost:8002
TX_MEMBER_URL=http://localhost:8003
TX_SUPPLY_URL=http://localhost:8004
TX_FINANCE_URL=http://localhost:8005
TX_ORG_URL=http://localhost:8006
TX_ANALYTICS_URL=http://localhost:8007
TX_AGENT_URL=http://localhost:8008
TX_OPS_URL=http://localhost:8009

# ─── 旧系统回退（M4后移除） ───
LEGACY_API_URL=

# ─── Mac mini 边缘 ───
COREML_BRIDGE_URL=http://localhost:8100
SYNC_INTERVAL_SECONDS=300
CLOUD_DATABASE_URL=postgresql+asyncpg://tunxiang:CHANGE_ME@cloud-host:5432/tunxiang_os
LOCAL_DATABASE_URL=postgresql+asyncpg://tunxiang:local@localhost:5432/tunxiang_local
# sync-engine 专用 DSN（psycopg 同步驱动，无 +asyncpg）
CLOUD_PG_DSN=postgresql://tunxiang:CHANGE_ME@cloud-host:5432/tunxiang_os
LOCAL_PG_DSN=postgresql://tunxiang:local@localhost:5432/tunxiang_local
# 门店标识（sync-engine 冲突解析 & 日志标记）
STORE_ID=store_001
TENANT_ID=00000000-0000-0000-0000-000000000001

# ─── Tailscale ───
TAILSCALE_AUTH_KEY=tskey-xxx

# ─── 阿里云短信服务 ───
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_SECRET=
ALIYUN_SMS_SIGN_NAME=屯象OS

# ─── 微信公众号（模板消息） ───
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ─── 企业微信 ───
WECHAT_CORP_ID=
WECHAT_AGENT_ID=
WECHAT_SECRET=

# ─── 企业微信群机器人（内部告警/审批通知） ───
WECOM_APPROVAL_WEBHOOK=
WECOM_ALERT_WEBHOOK=

# ─── 域名（V3架构） ───
HUB_DOMAIN=hub.tunxiangos.com
OS_DOMAIN=os.tunxiangos.com
POS_DOMAIN=pos.tunxiangos.com
KDS_DOMAIN=kds.tunxiangos.com
CONSUMER_DOMAIN=m.tunxiangos.com
FORGE_DOMAIN=forge.tunxiangos.com
API_DOMAIN=api.tunxiangos.com
WS_DOMAIN=ws.tunxiangos.com
DOCS_DOMAIN=docs.tunxiangos.com
WWW_DOMAIN=www.tunxiangos.com

# CORS 允许域名（逗号分隔，生产环境必须明确列出所有前端域名，禁止使用 *）
CORS_ALLOWED_ORIGINS=https://hub.tunxiang.com,https://os.tunxiang.com,https://pos.tunxiang.com

# ─── Hub IP白名单（逗号分隔） ───
HUB_ALLOWED_IPS=127.0.0.1,100.64.0.0/10

# ─── 前端构建URL ───
VITE_API_BASE_URL=https://api.tunxiangos.com
VITE_WS_BASE_URL=wss://ws.tunxiangos.com
VITE_TENANT_ID=
VITE_STORE_ID=

# ─── SSL ───
SSL_EMAIL=devops@tunxiang.tech
DNSPOD_API_ID=
DNSPOD_API_TOKEN=

# ─── 微信支付商户 ───
WECHAT_MCH_ID=
WECHAT_API_KEY=
# 微信小程序（顾客端）
WECHAT_MINIAPP_APP_ID=
WECHAT_MINIAPP_APP_SECRET=

# ─── 支付宝 ───
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ─── 美团外卖开放平台 ───
MEITUAN_APP_KEY=
MEITUAN_APP_SECRET=
MEITUAN_STORE_ID=

# ─── 微服务内部地址（用于 franchise_clone_service 等服务间调用）───
TX_MENU_BASE_URL=http://tx-menu:8002
TX_TRADE_BASE_URL=http://tx-trade:8001
TX_OPS_BASE_URL=http://tx-ops:8005
TX_SUPPLY_BASE_URL=http://tx-supply:8006
TX_FINANCE_BASE_URL=http://tx-finance:8007
TX_ANALYTICS_BASE_URL=http://tx-analytics:8009
TX_BRAIN_BASE_URL=http://tx-brain:8010
TX_INTEL_BASE_URL=http://tx-intel:8011
TX_ORG_BASE_URL=http://tx-org:8012

