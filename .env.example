# TunxiangOS V3.0 环境变量模板
# 复制为 .env 并填入真实值

# ─── 数据库 ───
DATABASE_URL=postgresql+asyncpg://tunxiang:CHANGE_ME@localhost:5432/tunxiang_os
ALEMBIC_DATABASE_URL=postgresql://tunxiang:CHANGE_ME@localhost:5432/tunxiang_os

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── AI ───
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ─── 域微服务端口 ───
TX_TRADE_URL=http://localhost:8001
TX_MENU_URL=http://localhost:8002
TX_MEMBER_URL=http://localhost:8003
TX_SUPPLY_URL=http://localhost:8004
TX_FINANCE_URL=http://localhost:8005
TX_ORG_URL=http://localhost:8006
TX_ANALYTICS_URL=http://localhost:8007
TX_AGENT_URL=http://localhost:8008

# ─── 旧系统回退（M4后移除） ───
LEGACY_API_URL=

# ─── Mac mini 边缘 ───
COREML_BRIDGE_URL=http://localhost:8100
SYNC_INTERVAL_SECONDS=300
CLOUD_DATABASE_URL=postgresql+asyncpg://tunxiang:CHANGE_ME@cloud-host:5432/tunxiang_os
LOCAL_DATABASE_URL=postgresql+asyncpg://tunxiang:local@localhost:5432/tunxiang_local

# ─── Tailscale ───
TAILSCALE_AUTH_KEY=tskey-xxx

# ─── 企业微信 ───
WECHAT_CORP_ID=
WECHAT_AGENT_ID=
WECHAT_SECRET=

# ─── 域名 ───
API_DOMAIN=api.zlsjos.cn
ADMIN_DOMAIN=admin.zlsjos.cn

# ─── 前端 ───
VITE_API_BASE_URL=https://api.zlsjos.cn
VITE_TENANT_ID=
VITE_STORE_ID=
