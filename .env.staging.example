# ─── Staging 环境变量 ───
# 复制为 .env.staging 后填入实际值
# 用法: cp .env.staging.example .env.staging
#        docker-compose -f docker-compose.staging.yml --env-file .env.staging up -d

# 主机（服务器IP或域名）
STG_HOST=REPLACE_ME_STG_HOST

# PostgreSQL（独立于生产库）
STG_POSTGRES_USER=tunxiang_stg
STG_POSTGRES_PASSWORD=CHANGE_ME_staging_password
STG_POSTGRES_DB=tunxiang_os_stg

# Redis
STG_REDIS_PASSWORD=CHANGE_ME_staging_redis

# AI（staging 可共用生产 key，但建议用低配额 key）
ANTHROPIC_API_KEY=
