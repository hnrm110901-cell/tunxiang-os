# ============================================================
# 屯象OS Docker 环境变量模板
# 复制为 .env 后填入真实值，禁止提交 .env 到 Git
# ============================================================

# ── 环境标识 ─────────────────────────────────────────────────
TX_ENV=dev
# dev | staging | prod

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=tunxiang
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=tunxiang_os
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# 生产环境读写分离（仅 prod 使用）
# DATABASE_READ_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres-replica:5432/${POSTGRES_DB}

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
# 生产环境 Sentinel（仅 prod 使用）
# REDIS_SENTINEL_HOSTS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# REDIS_SENTINEL_MASTER=txos-master

# ── JWT / 认证 ───────────────────────────────────────────────
TX_JWT_SECRET=CHANGE_ME_USE_32_CHAR_RANDOM_STRING
TX_JWT_ALGORITHM=HS256
TX_JWT_EXPIRE_MINUTES=1440
TX_AUTH_ENABLED=true
TX_RATE_LIMIT_ENABLED=true

# ── 腾讯云 ──────────────────────────────────────────────────
TENCENT_SECRET_ID=CHANGE_ME_TENCENT_SECRET_ID
TENCENT_SECRET_KEY=CHANGE_ME_TENCENT_SECRET_KEY
TENCENT_COS_BUCKET=CHANGE_ME_BUCKET_NAME
TENCENT_COS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=CHANGE_ME_SMS_APP_ID
TENCENT_SMS_SIGN_NAME=屯象科技

# ── Claude API（AI 决策中枢）──────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_KEY
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── 微信 ─────────────────────────────────────────────────────
WECHAT_APP_ID=CHANGE_ME_WECHAT_APP_ID
WECHAT_APP_SECRET=CHANGE_ME_WECHAT_APP_SECRET
WECHAT_MCH_ID=CHANGE_ME_WECHAT_MCH_ID
WECHAT_API_KEY=CHANGE_ME_WECHAT_API_KEY

# ── 抖音 ─────────────────────────────────────────────────────
DOUYIN_APP_ID=CHANGE_ME_DOUYIN_APP_ID
DOUYIN_APP_SECRET=CHANGE_ME_DOUYIN_APP_SECRET

# ── 域名 ─────────────────────────────────────────────────────
TX_DOMAIN=tunxiangos.com
TX_API_DOMAIN=api.tunxiangos.com

# ── SSL（生产环境）────────────────────────────────────────────
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem
CERTBOT_EMAIL=CHANGE_ME_ADMIN_EMAIL@example.com

# ── 日志 ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
# DEBUG | INFO | WARNING | ERROR

# ── Tailscale（门店 Mac mini 连接）────────────────────────────
TAILSCALE_AUTH_KEY=CHANGE_ME_TAILSCALE_AUTH_KEY
