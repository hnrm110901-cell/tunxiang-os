# ============================================================
# .env.czyz.dev.example — 同机联调端口偏移 (czyz, +0)
# ============================================================
# 用途：开发者本地 **同时拉起 czyz / zqx / sgc 三家** 联调时使用。
# 仅与 special/multi-host-dev.yml 配合，不要在生产部署中使用。
#
# 用法:
#   set -a && source infra/compose/special/.env.czyz.dev.example && set +a
#   docker compose \
#     -f infra/compose/base.yml \
#     -f infra/compose/envs/dev.yml \
#     -f infra/compose/tenants/czyz.yml \
#     -f infra/compose/special/multi-host-dev.yml up -d
#
# czyz 占用主机端口默认槽位（与单家部署默认值一致）。
# 如果三家全要并存，建议把 czyz 也错开（例如 +50），
# 但当前默认偏移 0，由用户根据机器情况自行选择是否覆盖。
# ============================================================

# ---- 本租户必填 ----
TUNXIANG_ENV=czyz-dev
TENANT_PORT_OFFSET=0

# ---- 数据库与缓存 ----
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# ---- 后端服务 ----
GATEWAY_HOST_PORT=8000
TX_TRADE_HOST_PORT=8001
TX_MENU_HOST_PORT=8002
TX_MEMBER_HOST_PORT=8003
TX_GROWTH_HOST_PORT=8004
TX_OPS_HOST_PORT=8005
TX_SUPPLY_HOST_PORT=8006
TX_FINANCE_HOST_PORT=8007
TX_AGENT_HOST_PORT=8008
TX_ANALYTICS_HOST_PORT=8009
TX_BRAIN_HOST_PORT=8010
TX_INTEL_HOST_PORT=8011
TX_ORG_HOST_PORT=8012
TUNXIANG_API_HOST_PORT=8013
TX_CIVIC_HOST_PORT=8014
TX_EXPENSE_HOST_PORT=8015
TX_PAY_HOST_PORT=8016
TX_DEVFORGE_HOST_PORT=8017
MCP_SERVER_HOST_PORT=8018
TX_PREDICT_HOST_PORT=8019

# ---- 前端 Vite Dev ----
WEB_ADMIN_HOST_PORT=5173
WEB_POS_HOST_PORT=5174
WEB_KDS_HOST_PORT=5175

# ---- base.yml 必填环境变量（占位，dev 用最小值即可）----
DATABASE_URL=postgresql+asyncpg://tunxiang:tunxiang_czyz_2024@postgres:5432/tunxiang_czyz
POSTGRES_USER=tunxiang
POSTGRES_PASSWORD=tunxiang_czyz_2024
POSTGRES_DB=tunxiang_czyz
TX_JWT_SECRET_KEY=dev_only_jwt_secret_change_in_prod
DEVFORGE_DATABASE_URL=postgresql://tunxiang:tunxiang_czyz_2024@postgres:5432/tunxiang_czyz
