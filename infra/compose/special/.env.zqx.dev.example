# ============================================================
# .env.zqx.dev.example — 同机联调端口偏移 (zqx, +100)
# ============================================================
# 用途：开发者本地 **同时拉起 czyz / zqx / sgc 三家** 联调时使用。
# 仅与 special/multi-host-dev.yml 配合，不要在生产部署中使用。
#
# 用法:
#   set -a && source infra/compose/special/.env.zqx.dev.example && set +a
#   docker compose \
#     -f infra/compose/base.yml \
#     -f infra/compose/envs/dev.yml \
#     -f infra/compose/tenants/zqx.yml \
#     -f infra/compose/special/multi-host-dev.yml up -d
#
# zqx 偏移 +100：postgres=5532, redis=6380, gateway=8100…
# ============================================================

# ---- 本租户必填 ----
TUNXIANG_ENV=zqx-dev
TENANT_PORT_OFFSET=100

# ---- 数据库与缓存 ----
POSTGRES_HOST_PORT=5532
REDIS_HOST_PORT=6380

# ---- 后端服务 ----
GATEWAY_HOST_PORT=8100
TX_TRADE_HOST_PORT=8101
TX_MENU_HOST_PORT=8102
TX_MEMBER_HOST_PORT=8103
TX_GROWTH_HOST_PORT=8104
TX_OPS_HOST_PORT=8105
TX_SUPPLY_HOST_PORT=8106
TX_FINANCE_HOST_PORT=8107
TX_AGENT_HOST_PORT=8108
TX_ANALYTICS_HOST_PORT=8109
TX_BRAIN_HOST_PORT=8110
TX_INTEL_HOST_PORT=8111
TX_ORG_HOST_PORT=8112
TUNXIANG_API_HOST_PORT=8113
TX_CIVIC_HOST_PORT=8114
TX_EXPENSE_HOST_PORT=8115
TX_PAY_HOST_PORT=8116
TX_DEVFORGE_HOST_PORT=8117
MCP_SERVER_HOST_PORT=8118
TX_PREDICT_HOST_PORT=8119

# ---- 前端 Vite Dev ----
WEB_ADMIN_HOST_PORT=5273
WEB_POS_HOST_PORT=5274
WEB_KDS_HOST_PORT=5275

# ---- base.yml 必填环境变量（占位，dev 用最小值即可）----
DATABASE_URL=postgresql+asyncpg://tunxiang:tunxiang_zqx_2024@postgres:5432/tunxiang_zqx
POSTGRES_USER=tunxiang
POSTGRES_PASSWORD=tunxiang_zqx_2024
POSTGRES_DB=tunxiang_zqx
TX_JWT_SECRET_KEY=dev_only_jwt_secret_change_in_prod
DEVFORGE_DATABASE_URL=postgresql://tunxiang:tunxiang_zqx_2024@postgres:5432/tunxiang_zqx
