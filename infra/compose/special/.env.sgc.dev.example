# ============================================================
# .env.sgc.dev.example — 同机联调端口偏移 (sgc, +200)
# ============================================================
# 用途：开发者本地 **同时拉起 czyz / zqx / sgc 三家** 联调时使用。
# 仅与 special/multi-host-dev.yml 配合，不要在生产部署中使用。
#
# 用法:
#   set -a && source infra/compose/special/.env.sgc.dev.example && set +a
#   docker compose \
#     -f infra/compose/base.yml \
#     -f infra/compose/envs/dev.yml \
#     -f infra/compose/tenants/sgc.yml \
#     -f infra/compose/special/multi-host-dev.yml up -d
#
# sgc 偏移 +200：postgres=5632, redis=6381, gateway=8200…
# ============================================================

# ---- 本租户必填 ----
TUNXIANG_ENV=sgc-dev
TENANT_PORT_OFFSET=200

# ---- 数据库与缓存 ----
POSTGRES_HOST_PORT=5632
REDIS_HOST_PORT=6381

# ---- 后端服务 ----
GATEWAY_HOST_PORT=8200
TX_TRADE_HOST_PORT=8201
TX_MENU_HOST_PORT=8202
TX_MEMBER_HOST_PORT=8203
TX_GROWTH_HOST_PORT=8204
TX_OPS_HOST_PORT=8205
TX_SUPPLY_HOST_PORT=8206
TX_FINANCE_HOST_PORT=8207
TX_AGENT_HOST_PORT=8208
TX_ANALYTICS_HOST_PORT=8209
TX_BRAIN_HOST_PORT=8210
TX_INTEL_HOST_PORT=8211
TX_ORG_HOST_PORT=8212
TUNXIANG_API_HOST_PORT=8213
TX_CIVIC_HOST_PORT=8214
TX_EXPENSE_HOST_PORT=8215
TX_PAY_HOST_PORT=8216
TX_DEVFORGE_HOST_PORT=8217
MCP_SERVER_HOST_PORT=8218
TX_PREDICT_HOST_PORT=8219

# ---- 前端 Vite Dev ----
WEB_ADMIN_HOST_PORT=5373
WEB_POS_HOST_PORT=5374
WEB_KDS_HOST_PORT=5375

# ---- base.yml 必填环境变量（占位，dev 用最小值即可）----
DATABASE_URL=postgresql+asyncpg://tunxiang:tunxiang_sgc_2024@postgres:5432/tunxiang_sgc
POSTGRES_USER=tunxiang
POSTGRES_PASSWORD=tunxiang_sgc_2024
POSTGRES_DB=tunxiang_sgc
TX_JWT_SECRET_KEY=dev_only_jwt_secret_change_in_prod
DEVFORGE_DATABASE_URL=postgresql://tunxiang:tunxiang_sgc_2024@postgres:5432/tunxiang_sgc
