# JumpServer 环境变量配置示例
# 复制为 .env 并填写实际值（.env 已加入 .gitignore，禁止提交）

# ── 必填：随机密钥 ──────────────────────────────────────────────────────────
# 生成命令：openssl rand -base64 42
# 警告：一旦写入数据库，此值永不可更改（否则所有加密数据丢失）
JMS_SECRET_KEY=请替换为42位随机字符串

# 组件认证Token
# 生成命令：openssl rand -base64 16
JMS_BOOTSTRAP_TOKEN=请替换为16位随机字符串

# ── 数据库配置 ──────────────────────────────────────────────────────────────
JMS_DB_USER=jumpserver
JMS_DB_PASSWORD=请替换为强密码

# ── Redis 配置 ──────────────────────────────────────────────────────────────
REDIS_PASSWORD=请替换为Redis密码（与主服务共享）

# ── 服务器标识 ──────────────────────────────────────────────────────────────
JMS_SERVER_NAME=jumpserver.txos.internal
