{
  "name": "web-kds",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:fast": "KDS_E2E_DURATION_MS=60000 playwright test",
    "e2e:nightly": "KDS_E2E_DURATION_MS=14400000 playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@tunxiang/design-system": "workspace:*",
    "@tx/tokens": "workspace:*",
    "@tx/touch": "workspace:*",
    "antd": "^5.12.0",
    "dayjs": "^1.11.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.14.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^10.2.1",
    "jsdom": "^25.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
