/* 宴席支付闭环页样式 */
/* 设计规范：主色 #FF6B35，按钮高度 88rpx，卡片圆角 24rpx，页面间距 32rpx */

/* ─── 页面根容器 ──────────────────────────────────────────────────── */

.page {
  min-height: 100vh;
  background: #F8F7F5;
  padding: 32rpx 32rpx 200rpx;
  box-sizing: border-box;
}

/* ─── 加载 / 错误状态 ─────────────────────────────────────────────── */

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #E8E6E1;
  border-top-color: #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #B4B2A9;
}

.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.error-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.error-msg {
  font-size: 28rpx;
  color: #5F5E5A;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 48rpx;
  font-size: 28rpx;
}

/* ─── 通用卡片 ────────────────────────────────────────────────────── */

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 24rpx;
  display: block;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

/* ─── 支付状态 Badge ──────────────────────────────────────────────── */

.status-badge {
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-unpaid {
  background: #F0EDE6;
  color: #5F5E5A;
}

.status-deposit_paid {
  background: #FFF3ED;
  color: #FF6B35;
}

.status-fully_paid {
  background: #E8F5F1;
  color: #0F6E56;
}

.status-refunded {
  background: #FEF2F2;
  color: #A32D2D;
}

/* ─── 订单信息行 ──────────────────────────────────────────────────── */

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 26rpx;
  color: #B4B2A9;
  width: 160rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #2C2C2A;
  flex: 1;
  line-height: 1.5;
}

.info-value.notes {
  color: #5F5E5A;
}

.divider {
  height: 1rpx;
  background: #E8E6E1;
  margin: 20rpx 0;
}

/* ─── 金额行 ──────────────────────────────────────────────────────── */

.amount-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.amount-label {
  font-size: 28rpx;
  color: #5F5E5A;
}

.amount-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2A;
}

.amount-value.accent {
  color: #FF6B35;
}

/* ─── 支付进度 ────────────────────────────────────────────────────── */

.progress-card .card-title {
  margin-bottom: 32rpx;
}

.progress-steps {
  display: flex;
  align-items: center;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 0 0 auto;
}

.step-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.dot-done {
  background: #0F6E56;
  color: #FFFFFF;
}

.dot-ready {
  background: #FFF3ED;
  border: 3rpx solid #FF6B35;
  color: #FF6B35;
}

.dot-pending {
  background: #FFF3ED;
  border: 3rpx solid #FF6B35;
  color: #FF6B35;
}

.dot-locked {
  background: #F0EDE6;
  color: #B4B2A9;
}

.step-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-name {
  font-size: 26rpx;
  color: #2C2C2A;
  font-weight: 500;
}

.step-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2C2A;
  margin-top: 4rpx;
}

.step-status {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.status-done { color: #0F6E56; }
.status-pending { color: #FF6B35; }
.status-locked { color: #B4B2A9; }

.step-line {
  flex: 1;
  height: 4rpx;
  background: #E8E6E1;
  margin: 0 16rpx;
  align-self: flex-start;
  margin-top: 30rpx;
  transition: background 0.3s;
}

.line-done {
  background: #0F6E56;
}

/* ─── 支付记录 ────────────────────────────────────────────────────── */

.pay-record {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E8E6E1;
}

.pay-record:last-child {
  border-bottom: none;
}

.pay-record-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pay-stage-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-deposit {
  background: #FFF3ED;
  color: #FF6B35;
}

.tag-balance {
  background: #E8F5F1;
  color: #0F6E56;
}

.tag-full {
  background: #EFF6FF;
  color: #185FA5;
}

.pay-record-info {
  display: flex;
  flex-direction: column;
}

.pay-method {
  font-size: 26rpx;
  color: #2C2C2A;
}

.pay-time {
  font-size: 22rpx;
  color: #B4B2A9;
  margin-top: 4rpx;
}

.pay-record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.pay-amount {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2A;
}

.pay-status-text {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.pay-paid { color: #0F6E56; }
.pay-refunded { color: #A32D2D; }
.pay-pending { color: #BA7517; }

/* ─── 支付方式选择 ─────────────────────────────────────────────────── */

.method-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.method-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border: 2rpx solid #E8E6E1;
  border-radius: 16rpx;
  background: #FFFFFF;
  position: relative;
  transition: border-color 0.2s, background 0.2s;
}

.method-selected {
  border-color: #FF6B35;
  background: #FFF9F6;
}

.method-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.method-icon {
  font-size: 40rpx;
}

.method-name {
  font-size: 28rpx;
  color: #2C2C2A;
  flex: 1;
}

.method-check {
  width: 40rpx;
  height: 40rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
}

/* ─── 底部操作按钮 ─────────────────────────────────────────────────── */

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: #FFFFFF;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.pay-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.pay-btn-inner {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.pay-btn-deposit {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8555 100%);
}

.pay-btn-balance {
  background: linear-gradient(135deg, #0F6E56 0%, #1A9070 100%);
}

.pay-btn-done {
  background: #E8F5F1;
}

.pay-btn-cancelled {
  background: #F0EDE6;
}

.pay-btn-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.pay-btn-done .pay-btn-label,
.pay-btn-cancelled .pay-btn-label {
  color: #5F5E5A;
}

.pay-btn-amount {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.btn-hover {
  opacity: 0.85;
  transform: scale(0.98);
}
