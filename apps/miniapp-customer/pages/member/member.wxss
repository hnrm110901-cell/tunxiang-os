.page-container { min-height: 100vh; background: #0B1A20; color: #fff; padding-bottom: 120rpx; }

/* ─── 未登录 ─── */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx 60rpx;
}

.login-avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #1a2a33;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  text-align: center;
  line-height: 160rpx;
  margin-bottom: 32rpx;
}

.login-hint { font-size: 28rpx; color: #999; margin-bottom: 48rpx; }

.login-btn {
  background: #FF6B2C !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  width: 100%;
}

/* ─── 会员卡 ─── */
.member-card {
  margin: 32rpx;
  background: linear-gradient(135deg, #1a3040, #112228);
  border-radius: 24rpx;
  padding: 36rpx;
  border: 1rpx solid #1a2a33;
}

.member-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 36rpx;
}

.member-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 107, 44, 0.3);
}

.member-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.member-name { font-size: 34rpx; font-weight: bold; color: #fff; }

/* 资产区 */
.assets-row {
  display: flex;
  align-items: center;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.asset-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.asset-value { font-size: 36rpx; font-weight: bold; color: #FF6B2C; }
.asset-label { font-size: 22rpx; color: #999; }

.asset-divider {
  width: 1rpx;
  height: 60rpx;
  background: #1a2a33;
}

/* ─── 功能菜单 ─── */
.menu-section {
  margin: 24rpx 32rpx;
  background: #112228;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #1a2a33;
}

.menu-item:last-child { border-bottom: none; }

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon { font-size: 36rpx; }
.menu-label { font-size: 30rpx; color: #fff; }
.menu-arrow { font-size: 28rpx; color: #666; }

/* ─── 消费统计 ─── */
.stats-card {
  margin: 24rpx 32rpx;
  background: #112228;
  border-radius: 20rpx;
  padding: 28rpx;
}

.stats-title { font-size: 28rpx; color: #999; margin-bottom: 20rpx; display: block; }

.stats-row { display: flex; }

.stats-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stats-value { font-size: 34rpx; font-weight: bold; color: #FF6B2C; }
.stats-label { font-size: 22rpx; color: #999; }

/* ─── 弹层 ─── */
.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 99;
}

.popup-sheet {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #112228;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 100;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 300ms ease-out;
}

.popup-sheet.show { transform: translateY(0); }

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #1a2a33;
}

.popup-title { font-size: 32rpx; font-weight: bold; color: #fff; }
.popup-close { font-size: 32rpx; color: #999; padding: 8rpx; }

.popup-list {
  max-height: 60vh;
  padding: 0 32rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #1a2a33;
}

.log-left { display: flex; flex-direction: column; gap: 8rpx; }
.log-desc { font-size: 28rpx; color: #fff; }
.log-time { font-size: 22rpx; color: #666; }

.log-amount { font-size: 30rpx; font-weight: bold; }
.log-amount.income { color: #0F6E56; }
.log-amount.expense { color: #FF6B2C; }

.empty-state { text-align: center; color: #666; font-size: 28rpx; padding: 80rpx 0; }
