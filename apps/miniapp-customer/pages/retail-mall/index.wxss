.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 40rpx; }

/* ─── Search bar ─── */
.search-bar {
  display: flex; align-items: center; padding: 24rpx 32rpx; gap: 20rpx;
  background: #112228;
}
.search-input-wrap {
  flex: 1; background: #1A3040; border-radius: 32rpx; padding: 16rpx 28rpx;
}
.search-input { font-size: 28rpx; color: #fff; }
.cart-btn { position: relative; padding: 8rpx; }
.cart-icon { font-size: 44rpx; color: #FF6B2C; }
.cart-badge {
  position: absolute; top: -8rpx; right: -8rpx;
  background: #FF3B30; color: #fff; font-size: 20rpx;
  min-width: 32rpx; height: 32rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  padding: 0 8rpx;
}

/* ─── Banner ─── */
.banner-swiper { height: 320rpx; margin: 0 32rpx 24rpx; border-radius: 16rpx; overflow: hidden; }
.banner-image { width: 100%; height: 100%; }

/* ─── Category tabs ─── */
.category-scroll { white-space: nowrap; padding: 0 32rpx 24rpx; }
.category-tab {
  display: inline-block; padding: 16rpx 32rpx; margin-right: 16rpx;
  background: #1A3040; border-radius: 32rpx;
  font-size: 26rpx; color: #999;
}
.category-tab.active { background: #FF6B2C; color: #fff; }

/* ─── Product grid ─── */
.product-grid {
  display: flex; flex-wrap: wrap; padding: 0 24rpx; gap: 16rpx;
}
.product-card {
  width: calc(50% - 8rpx); background: #112228; border-radius: 16rpx;
  overflow: hidden;
}
.product-image { width: 100%; height: 340rpx; }
.product-info { padding: 16rpx 20rpx 24rpx; }
.product-name {
  font-size: 28rpx; color: #fff; font-weight: 500;
  display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2;
  overflow: hidden; line-height: 1.4;
}
.product-tags { margin-top: 8rpx; display: flex; gap: 8rpx; flex-wrap: wrap; }
.product-tag {
  font-size: 20rpx; color: #FF6B2C; background: rgba(255,107,44,0.15);
  padding: 4rpx 12rpx; border-radius: 6rpx;
}
.product-price-row { margin-top: 12rpx; display: flex; align-items: baseline; gap: 8rpx; }
.product-price { font-size: 32rpx; color: #FF6B2C; font-weight: bold; }
.product-original { font-size: 22rpx; color: #666; text-decoration: line-through; }
.product-sales { font-size: 22rpx; color: #666; margin-top: 4rpx; display: block; }

/* ─── Loading ─── */
.loading-tip { text-align: center; padding: 32rpx; color: #666; font-size: 24rpx; }
.empty-tip { text-align: center; padding: 120rpx 0; color: #666; font-size: 28rpx; }
