.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 160rpx; }

/* ─── Address card ─── */
.address-card {
  display: flex; align-items: center; padding: 32rpx;
  background: #112228; margin-bottom: 24rpx;
}
.address-top { display: flex; gap: 16rpx; margin-bottom: 8rpx; }
.address-name { font-size: 30rpx; color: #fff; font-weight: 500; }
.address-phone { font-size: 26rpx; color: #999; }
.address-detail { font-size: 26rpx; color: #ccc; display: block; }
.address-empty { color: #666; font-size: 28rpx; }
.address-arrow { color: #666; font-size: 28rpx; margin-left: auto; }

/* ─── Cart list ─── */
.cart-list { padding: 0 32rpx; }
.cart-item {
  display: flex; align-items: center; gap: 20rpx;
  background: #112228; border-radius: 16rpx; padding: 24rpx;
  margin-bottom: 16rpx; position: relative;
}
.cart-checkbox {
  width: 40rpx; height: 40rpx; border-radius: 50%;
  border: 2rpx solid #666; flex-shrink: 0;
}
.cart-checkbox.checked { background: #FF6B2C; border-color: #FF6B2C; }
.cart-image { width: 160rpx; height: 160rpx; border-radius: 12rpx; flex-shrink: 0; }
.cart-info { flex: 1; min-width: 0; }
.cart-name { font-size: 28rpx; color: #fff; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cart-sku { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.cart-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx; }
.cart-price { font-size: 30rpx; color: #FF6B2C; font-weight: bold; }
.cart-qty { display: flex; align-items: center; gap: 12rpx; }
.qty-btn {
  width: 48rpx; height: 48rpx; background: #1A3040; border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 28rpx;
}
.qty-num { font-size: 26rpx; color: #fff; min-width: 40rpx; text-align: center; }
.cart-delete { position: absolute; top: 24rpx; right: 24rpx; color: #666; font-size: 24rpx; }

/* ─── Empty cart ─── */
.empty-cart { text-align: center; padding: 200rpx 0; }
.empty-text { color: #666; font-size: 28rpx; display: block; }
.empty-btn {
  display: inline-block; margin-top: 32rpx; padding: 20rpx 60rpx;
  background: #FF6B2C; color: #fff; border-radius: 40rpx; font-size: 28rpx;
}

/* ─── Checkout bar ─── */
.checkout-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; padding: 20rpx 32rpx;
  background: #112228; border-top: 1rpx solid #1A3040;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}
.checkout-select-all { display: flex; align-items: center; gap: 12rpx; color: #ccc; font-size: 26rpx; }
.checkout-total { flex: 1; text-align: right; margin-right: 24rpx; }
.total-label { font-size: 26rpx; color: #999; }
.total-price { font-size: 34rpx; color: #FF6B2C; font-weight: bold; }
.checkout-btn {
  padding: 20rpx 48rpx; background: #FF6B2C; color: #fff;
  border-radius: 40rpx; font-size: 28rpx;
}
.checkout-btn.disabled { opacity: 0.5; }

/* ─── Address popup ─── */
.address-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); z-index: 100;
}
.address-popup {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #112228; border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx; z-index: 101; max-height: 60vh; overflow-y: auto;
  transform: translateY(100%); transition: transform 0.3s;
}
.address-popup.show { transform: translateY(0); }
.popup-header { margin-bottom: 24rpx; }
.popup-title { font-size: 32rpx; color: #fff; font-weight: 500; }
.address-option {
  padding: 24rpx; background: #1A3040; border-radius: 12rpx; margin-bottom: 16rpx;
}
.addr-name { font-size: 28rpx; color: #fff; display: block; }
.addr-detail { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.address-option.add-new { text-align: center; color: #FF6B2C; font-size: 28rpx; }
