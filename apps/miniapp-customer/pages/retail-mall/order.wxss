.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 160rpx; }

.section { background: #112228; margin-bottom: 24rpx; padding: 32rpx; }
.section-title { font-size: 28rpx; color: #fff; font-weight: 500; display: block; margin-bottom: 20rpx; }

/* ─── Address ─── */
.address-section { border-bottom: 4rpx dashed #FF6B2C; }
.addr-top { display: flex; gap: 16rpx; margin-bottom: 8rpx; }
.addr-name { font-size: 30rpx; color: #fff; font-weight: 500; }
.addr-phone { font-size: 26rpx; color: #999; }
.addr-detail { font-size: 26rpx; color: #ccc; display: block; }

/* ─── Order items ─── */
.order-item { display: flex; gap: 20rpx; margin-bottom: 20rpx; }
.order-item:last-child { margin-bottom: 0; }
.item-image { width: 160rpx; height: 160rpx; border-radius: 12rpx; flex-shrink: 0; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; color: #fff; display: block; }
.item-sku { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.item-bottom { display: flex; justify-content: space-between; margin-top: 16rpx; }
.item-price { font-size: 28rpx; color: #FF6B2C; }
.item-qty { font-size: 26rpx; color: #999; }

/* ─── Discount ─── */
.discount-row { display: flex; justify-content: space-between; align-items: center; }
.discount-label { font-size: 28rpx; color: #fff; }
.discount-action { color: #FF6B2C; font-size: 26rpx; padding: 8rpx 24rpx; border: 1rpx solid #FF6B2C; border-radius: 24rpx; }
.discount-amount { font-size: 28rpx; color: #FF6B2C; }

/* ─── Remark ─── */
.remark-input {
  width: 100%; height: 140rpx; background: #1A3040; border-radius: 12rpx;
  padding: 20rpx; font-size: 26rpx; color: #fff; box-sizing: border-box;
}

/* ─── Price summary ─── */
.price-summary .price-row {
  display: flex; justify-content: space-between; padding: 12rpx 0;
  font-size: 26rpx; color: #999;
}
.price-row.total { padding-top: 20rpx; border-top: 1rpx solid #1A3040; }
.discount-text { color: #FF6B2C; }
.final-price { font-size: 36rpx; color: #FF6B2C; font-weight: bold; }

/* ─── Submit bar ─── */
.submit-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 32rpx; background: #112228; border-top: 1rpx solid #1A3040;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}
.submit-total { display: flex; align-items: baseline; }
.submit-label { font-size: 26rpx; color: #999; }
.submit-price { font-size: 40rpx; color: #FF6B2C; font-weight: bold; }
.submit-btn {
  padding: 24rpx 64rpx; background: #FF6B2C; color: #fff;
  border-radius: 44rpx; font-size: 30rpx; font-weight: 500;
}
.submit-btn.disabled { opacity: 0.5; }
