.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 160rpx; }

/* ─── Image swiper ─── */
.product-swiper { height: 750rpx; width: 100%; }
.product-big-image { width: 100%; height: 100%; }

/* ─── Header ─── */
.product-header { padding: 32rpx; background: #112228; }
.price-row { display: flex; align-items: baseline; gap: 8rpx; }
.price-symbol { font-size: 28rpx; color: #FF6B2C; font-weight: bold; }
.price-value { font-size: 52rpx; color: #FF6B2C; font-weight: bold; }
.price-original { font-size: 24rpx; color: #666; text-decoration: line-through; margin-left: 12rpx; }
.sales-badge { font-size: 22rpx; color: #999; margin-left: auto; }
.product-title { font-size: 32rpx; color: #fff; font-weight: 500; margin-top: 16rpx; display: block; line-height: 1.5; }
.product-desc { font-size: 26rpx; color: #999; margin-top: 8rpx; display: block; line-height: 1.6; }

/* ─── Info card ─── */
.info-card { margin: 24rpx 32rpx; background: #112228; border-radius: 16rpx; padding: 24rpx; }
.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #1A3040; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #999; }
.info-value { font-size: 26rpx; color: #fff; }

/* ─── SKU ─── */
.sku-section { margin: 24rpx 32rpx; background: #112228; border-radius: 16rpx; padding: 24rpx; }
.section-title { font-size: 28rpx; color: #fff; font-weight: 500; margin-bottom: 16rpx; display: block; }
.sku-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.sku-item {
  padding: 16rpx 32rpx; background: #1A3040; border-radius: 12rpx;
  font-size: 26rpx; color: #ccc; border: 2rpx solid transparent;
}
.sku-item.active { border-color: #FF6B2C; color: #FF6B2C; background: rgba(255,107,44,0.1); }

/* ─── Bottom bar ─── */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; padding: 20rpx 32rpx;
  background: #112228; border-top: 1rpx solid #1A3040;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  gap: 16rpx;
}
.qty-control { display: flex; align-items: center; gap: 16rpx; }
.qty-btn {
  width: 56rpx; height: 56rpx; background: #1A3040; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 32rpx;
}
.qty-value { font-size: 28rpx; color: #fff; min-width: 48rpx; text-align: center; }
.btn-add-cart {
  flex: 1; height: 80rpx; background: #1A3040; border-radius: 40rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #FF6B2C; border: 2rpx solid #FF6B2C;
}
.btn-buy-now {
  flex: 1; height: 80rpx; background: #FF6B2C; border-radius: 40rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #fff;
}

.loading-container { display: flex; justify-content: center; padding: 200rpx 0; }
.loading-text { color: #666; font-size: 28rpx; }
