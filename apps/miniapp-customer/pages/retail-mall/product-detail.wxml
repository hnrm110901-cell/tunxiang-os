<!-- Retail Mall: Product Detail -->
<view class="page-container" wx:if="{{!loading && product}}">
  <!-- Product image -->
  <view class="product-image-area">
    <image class="product-image" src="{{product.image_url || '/assets/placeholder-product.png'}}" mode="aspectFill" />
    <view class="discount-badge" wx:if="{{product.price_fen < product.original_price_fen}}">
      省¥{{(product.original_price_fen - product.price_fen) / 100}}
    </view>
  </view>

  <!-- Product info -->
  <view class="product-info">
    <view class="price-row">
      <text class="sale-price">¥{{product.price_fen / 100}}</text>
      <text class="original-price" wx:if="{{product.price_fen < product.original_price_fen}}">
        ¥{{product.original_price_fen / 100}}
      </text>
      <text class="sales-count">已售 {{product.sales || 0}}</text>
    </view>
    <text class="product-name">{{product.name}}</text>
    <text class="product-desc" wx:if="{{product.description}}">{{product.description}}</text>
  </view>

  <!-- SKU selector -->
  <view class="sku-section" wx:if="{{product.skus && product.skus.length > 1}}">
    <text class="section-label">规格</text>
    <view class="sku-list">
      <view class="sku-chip {{selectedSku && selectedSku.sku_id === item.sku_id ? 'selected' : ''}}"
            wx:for="{{product.skus}}" wx:key="sku_id"
            bindtap="onSelectSku" data-id="{{item.sku_id}}">
        <text>{{item.sku_name}}</text>
      </view>
    </view>
  </view>

  <!-- Quantity -->
  <view class="quantity-section">
    <text class="section-label">数量</text>
    <view class="quantity-control">
      <view class="qty-btn" bindtap="onChangeQuantity" data-delta="{{-1}}">
        <text>−</text>
      </view>
      <text class="qty-value">{{quantity}}</text>
      <view class="qty-btn" bindtap="onChangeQuantity" data-delta="{{1}}">
        <text>+</text>
      </view>
    </view>
  </view>

  <!-- Stock info -->
  <view class="stock-info">
    <text class="stock-text" wx:if="{{product.stock > 10}}">库存充足</text>
    <text class="stock-text low" wx:elif="{{product.stock > 0}}">仅剩 {{product.stock}} 件</text>
    <text class="stock-text out" wx:else>暂时缺货</text>
  </view>

  <!-- Bottom action bar -->
  <view class="action-bar">
    <view class="action-left">
      <navigator url="/pages/retail-mall/cart" class="action-icon">
        <text class="icon-text">🛒</text>
        <text class="icon-label">购物车</text>
      </navigator>
    </view>
    <view class="action-right">
      <button class="cart-btn" bindtap="onAddToCart" disabled="{{addingToCart || product.stock <= 0}}">
        加入购物车
      </button>
      <button class="buy-btn" bindtap="onBuyNow" disabled="{{product.stock <= 0}}">
        立即购买
      </button>
    </view>
  </view>
</view>

<view class="loading-state" wx:if="{{loading}}">
  <text>加载中...</text>
</view>
