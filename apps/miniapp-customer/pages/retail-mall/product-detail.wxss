.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 160rpx; }

.product-image-area { position: relative; width: 100%; height: 600rpx; }
.product-image { width: 100%; height: 100%; }
.discount-badge {
  position: absolute; top: 24rpx; left: 24rpx;
  background: #ff4d4f; color: #fff; padding: 6rpx 16rpx;
  border-radius: 16rpx; font-size: 24rpx; font-weight: 600;
}

.product-info { padding: 28rpx 32rpx; }
.price-row { display: flex; align-items: baseline; gap: 16rpx; margin-bottom: 16rpx; }
.sale-price { font-size: 48rpx; font-weight: 700; color: #ff4d4f; }
.original-price { font-size: 26rpx; color: #666; text-decoration: line-through; }
.sales-count { font-size: 24rpx; color: #999; margin-left: auto; }

.product-name { font-size: 34rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 12rpx; line-height: 1.4; }
.product-desc { font-size: 26rpx; color: #999; display: block; line-height: 1.6; }

.sku-section, .quantity-section {
  padding: 24rpx 32rpx; margin: 0 32rpx 16rpx;
  background: #112228; border-radius: 16rpx;
}
.section-label { font-size: 26rpx; color: #999; display: block; margin-bottom: 16rpx; }

.sku-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.sku-chip {
  padding: 12rpx 28rpx; border-radius: 24rpx; font-size: 26rpx;
  background: rgba(255,255,255,0.06); color: #ccc; border: 1rpx solid transparent;
}
.sku-chip.selected {
  background: rgba(255,107,44,0.12); color: #FF6B2C;
  border-color: #FF6B2C;
}

.quantity-control { display: flex; align-items: center; gap: 24rpx; }
.qty-btn {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: rgba(255,255,255,0.08); display: flex;
  align-items: center; justify-content: center;
  font-size: 32rpx; color: #ccc;
}
.qty-value { font-size: 32rpx; font-weight: 600; color: #fff; min-width: 48rpx; text-align: center; }

.stock-info { padding: 0 32rpx; margin-bottom: 16rpx; }
.stock-text { font-size: 24rpx; color: #52c41a; }
.stock-text.low { color: #faad14; }
.stock-text.out { color: #ff4d4f; }

.action-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; padding: 20rpx 32rpx;
  background: #112228; border-top: 1rpx solid rgba(255,255,255,0.06);
  padding-bottom: env(safe-area-inset-bottom);
}
.action-left { display: flex; gap: 32rpx; margin-right: 24rpx; }
.action-icon { display: flex; flex-direction: column; align-items: center; gap: 2rpx; }
.icon-text { font-size: 36rpx; }
.icon-label { font-size: 20rpx; color: #999; }

.action-right { display: flex; flex: 1; gap: 16rpx; }
.cart-btn, .buy-btn {
  flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 40rpx;
  font-size: 28rpx; font-weight: 600;
}
.cart-btn { background: rgba(255,107,44,0.15) !important; color: #FF6B2C !important; }
.buy-btn { background: #FF6B2C !important; color: #fff !important; }

.loading-state { display: flex; justify-content: center; padding: 200rpx 0; color: #999; font-size: 28rpx; }
