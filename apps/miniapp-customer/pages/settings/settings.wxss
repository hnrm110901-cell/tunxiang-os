/* 设置页样式 */
.settings-page {
  min-height: 100vh;
  background: #0B1A20;
  padding: 24rpx 32rpx;
}

.section {
  background: #112228;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 24rpx;
}

/* 语言大按钮 */
.lang-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.lang-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #1A2F38;
  border: 2rpx solid #2A3F48;
  border-radius: 12rpx;
  padding: 32rpx;
  transition: all 0.2s;
}

.lang-btn.active {
  border-color: #FF6B35;
  background: rgba(255, 107, 53, 0.1);
}

.lang-label {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.lang-btn.active .lang-label {
  color: #FF6B35;
}

.lang-check {
  font-size: 32rpx;
  color: #FF6B35;
  font-weight: 700;
}

/* 列表项 */
.cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.cell:last-child {
  border-bottom: none;
}

.cell-label {
  font-size: 28rpx;
  color: #FFFFFF;
}

.cell-arrow {
  font-size: 26rpx;
  color: #666;
}

.cell-value {
  font-size: 26rpx;
  color: #999;
}
