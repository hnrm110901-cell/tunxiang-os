<!-- 我的邀请记录页 -->
<view class="page">

  <!-- 顶部统计栏 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-value">{{summary.invited_count}}</text>
      <text class="stat-label">已邀请</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value orange">{{summary.earned_points}}</text>
      <text class="stat-label">已获积分</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value gray">{{summary.pending_points}}</text>
      <text class="stat-label">待到账积分</text>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="list-wrap" wx:if="{{records.length > 0}}">
    <view
      class="record-item"
      wx:for="{{records}}"
      wx:key="id"
    >
      <!-- 头像占位 -->
      <view class="avatar-wrap">
        <view class="avatar-placeholder">
          <text class="avatar-initial">{{item.nickname ? item.nickname.slice(0, 1) : '友'}}</text>
        </view>
      </view>

      <!-- 信息区 -->
      <view class="record-info">
        <text class="record-nickname">{{item.nickname || '好友'}}</text>
        <text class="record-time">注册于 {{item.register_time}}</text>
      </view>

      <!-- 积分状态 -->
      <view class="points-status">
        <text class="points-value">+{{item.reward_points}} 积分</text>
        <view
          class="status-badge"
          wx:if="{{item.status === 'credited'}}"
        >
          <text class="status-text credited">已到账</text>
        </view>
        <view
          class="status-badge"
          wx:elif="{{item.status === 'pending'}}"
        >
          <text class="status-text pending">处理中</text>
        </view>
        <view
          class="status-badge"
          wx:else
        >
          <text class="status-text expired">已失效</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
      <text class="load-more-text" wx:if="{{!loadingMore}}">上拉加载更多</text>
      <text class="load-more-text" wx:else>加载中...</text>
    </view>
    <view class="no-more" wx:else>
      <text class="no-more-text">已显示全部记录</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-wrap" wx:if="{{!loading && records.length === 0}}">
    <view class="empty-illustration">
      <text class="empty-icon">👥</text>
    </view>
    <text class="empty-title">暂无邀请记录</text>
    <text class="empty-desc">去邀请好友，一起赚积分吧！</text>
    <button class="btn-go-invite" bindtap="goToInvite">去邀请好友</button>
  </view>

  <!-- 初始加载 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

</view>
