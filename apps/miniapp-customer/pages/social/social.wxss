.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 60rpx; }

/* Tabs */
.social-tabs {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 20rpx;
}

.social-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #999;
  background: #112228;
  border-radius: 16rpx;
}

.social-tab.active {
  background: #FF6B2C;
  color: #fff;
  font-weight: 600;
}

/* Tab content */
.tab-content {
  padding: 0 32rpx;
}

/* Feature card */
.feature-card {
  background: linear-gradient(135deg, #112228, #1a2a33);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 28rpx;
  text-align: center;
}

.feature-hero { margin-bottom: 24rpx; }
.feature-title { font-size: 36rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 12rpx; }
.feature-desc { font-size: 26rpx; color: #999; display: block; }

/* CTA button */
.cta-btn {
  background: #FF6B2C !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  width: 100%;
  margin-top: 24rpx;
}

/* Group order */
.group-active {
  background: #112228;
  border-radius: 24rpx;
  padding: 28rpx;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.group-title { font-size: 32rpx; font-weight: bold; color: #fff; }
.group-code { font-size: 24rpx; color: #FF6B2C; }

.group-members { margin-bottom: 24rpx; }
.members-title { font-size: 26rpx; color: #999; display: block; margin-bottom: 16rpx; }

.member-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #1a2a33;
  gap: 16rpx;
}

.member-name { font-size: 28rpx; color: #fff; flex: 1; }
.member-role { font-size: 22rpx; color: #FF6B2C; }
.member-items { font-size: 24rpx; color: #999; }

.group-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  background: #1a2a33 !important;
  color: #ccc !important;
  border-radius: 44rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.action-btn.share {
  border: 2rpx solid #FF6B2C !important;
  color: #FF6B2C !important;
  background: transparent !important;
}

.action-btn.primary {
  background: #FF6B2C !important;
  color: #fff !important;
}

/* Gift types */
.gift-types {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.gift-type-card {
  flex: 1;
  background: #112228;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.gift-type-card.selected {
  border-color: #FF6B2C;
  background: rgba(255, 107, 44, 0.08);
}

.gift-type-label { font-size: 28rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 8rpx; }
.gift-type-desc { font-size: 22rpx; color: #999; display: block; }

/* Amount */
.amount-section { margin-bottom: 28rpx; }
.section-label { font-size: 28rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 16rpx; }

.amount-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.amount-chip {
  padding: 16rpx 40rpx;
  border-radius: 16rpx;
  background: #112228;
  color: #ccc;
  font-size: 30rpx;
  font-weight: 600;
}

.amount-chip.selected {
  background: rgba(255, 107, 44, 0.15);
  color: #FF6B2C;
  border: 2rpx solid #FF6B2C;
}

/* Message */
.message-section { margin-bottom: 28rpx; }

.gift-message-input {
  width: 100%;
  background: #112228;
  border-radius: 16rpx;
  padding: 20rpx;
  color: #fff;
  font-size: 28rpx;
  min-height: 120rpx;
}

/* Share rewards */
.share-card {
  background: linear-gradient(135deg, #FF6B2C, #FF9F5C) !important;
}

.referral-section {
  background: #112228;
  border-radius: 24rpx;
  padding: 32rpx;
}

.referral-code-box {
  text-align: center;
  margin-bottom: 24rpx;
}

.referral-label { font-size: 26rpx; color: #999; display: block; margin-bottom: 12rpx; }
.referral-code {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF6B2C;
  letter-spacing: 8rpx;
}

.referral-actions {
  display: flex;
  gap: 20rpx;
}

/* Misc */
.loading-tip { text-align: center; padding: 60rpx 0; color: #999; font-size: 28rpx; }
.empty-state { text-align: center; color: #999; font-size: 26rpx; padding: 40rpx 0; }
