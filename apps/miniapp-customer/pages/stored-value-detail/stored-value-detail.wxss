.page-container {
  min-height: 100vh;
  background: #0B1A20;
  color: #fff;
  padding-bottom: env(safe-area-inset-bottom);
}

/* --- 余额小卡 --- */
.balance-card-mini {
  margin: 32rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  border-radius: 24rpx;
  padding: 32rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 32rpx rgba(255,107,53,0.3);
}

.mini-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  display: block;
  margin-bottom: 8rpx;
}

.mini-amount {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: -1rpx;
}

/* --- Tab 栏 --- */
.tab-bar {
  display: flex;
  margin: 0 32rpx 8rpx;
  background: #112228;
  border-radius: 16rpx;
  padding: 6rpx;
  gap: 4rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  padding: 16rpx 0;
  border-radius: 12rpx;
  position: relative;
  transition: all 200ms;
}

.tab-active {
  color: #FF6B35;
  font-weight: 600;
  background: rgba(255,107,53,0.12);
}

/* --- 列表 --- */
.list-wrap {
  padding: 0 24rpx;
  margin-top: 8rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #112228;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  gap: 20rpx;
}

/* 图标圆形背景，按类型区分颜色 */
.record-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  text-align: center;
  line-height: 72rpx;
}
.record-icon-recharge { background: rgba(15,110,86,0.18); }
.record-icon-consume  { background: rgba(163,45,45,0.18); }
.record-icon-refund   { background: rgba(24,95,165,0.18); }
.record-icon-bonus    { background: rgba(255,107,53,0.15); }

.record-info {
  flex: 1;
  min-width: 0;
}

.record-desc {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time {
  font-size: 22rpx;
  color: rgba(255,255,255,0.35);
}

.record-amount {
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.amount-positive { color: #0F6E56; }
.amount-negative { color: #A32D2D; }

/* --- 空状态 --- */
.list-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: rgba(255,255,255,0.35); }

/* --- 加载 / 结尾 --- */
.list-loading, .list-end {
  text-align: center;
  padding: 40rpx 0;
  font-size: 24rpx;
  color: rgba(255,255,255,0.25);
}
