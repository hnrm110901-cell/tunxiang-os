/* 企业订餐历史样式 */

.page-container {
  min-height: 100vh;
  background: #0B1A20;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ─── 月份切换器 ─── */
.month-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 24rpx;
}

.month-arrow {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #112228;
  border-radius: 32rpx;
}

.month-arrow.disabled {
  opacity: 0.3;
}

.arrow-text {
  font-size: 40rpx;
  color: #FF6B2C;
  line-height: 1;
}

.month-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.month-label {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.month-icon {
  font-size: 20rpx;
  color: #666;
}

/* ─── 月度汇总卡 ─── */
.summary-card {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #1A3040, #112228);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
}

.summary-row {
  display: flex;
  align-items: center;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.s-value {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.s-value.count {
  color: #FF6B2C;
}

.s-value.spent {
  color: #FF6B2C;
}

.s-value.remain {
  color: #0F6E56;
}

.s-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 6rpx;
}

.summary-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* ─── 加载骨架 ─── */
.loading-wrap {
  padding: 0 24rpx;
}

.skeleton-item {
  height: 120rpx;
  background: #112228;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  animation: skeleton-pulse 1.4s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0% { opacity: 0.5; }
  50% { opacity: 0.9; }
  100% { opacity: 0.5; }
}

/* ─── 订单列表 ─── */
.orders-wrap {
  padding: 0 24rpx;
}

/* 空状态 */
.empty-wrap {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #555;
}

/* 日期分组 */
.date-group {
  margin-bottom: 24rpx;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 12rpx;
}

.date-label {
  font-size: 26rpx;
  color: #ccc;
  font-weight: 500;
}

.date-count {
  font-size: 22rpx;
  color: #666;
}

/* 订单卡片 */
.order-card {
  background: #112228;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}

.order-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.order-meal-badge {
  font-size: 20rpx;
  color: #fff;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.order-meal-badge.lunch {
  background: #D4840A;
}

.order-meal-badge.dinner {
  background: #6B3FA0;
}

.order-dishes {
  flex: 1;
  font-size: 26rpx;
  color: #fff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-amount {
  font-size: 28rpx;
  color: #FF6B2C;
  font-weight: bold;
  flex-shrink: 0;
}

.order-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.order-time {
  font-size: 22rpx;
  color: #666;
}

.delivery-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.delivery-badge.done {
  color: #0F6E56;
  background: rgba(15, 110, 86, 0.15);
}

.delivery-badge.pending {
  color: #D4840A;
  background: rgba(212, 132, 10, 0.15);
}

.delivery-badge text {
  font-size: 20rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: #666;
}

.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.no-more-text {
  font-size: 22rpx;
  color: #444;
}
