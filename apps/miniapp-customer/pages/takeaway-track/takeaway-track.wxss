.track-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0B1A20;
  color: #fff;
}

.loading-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.track-scroll {
  flex: 1;
  padding: 20rpx 24rpx;
}

/* ─── 状态大卡片 ─── */
.status-card {
  background: linear-gradient(135deg, #1a3540, #112228);
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.status-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,107,44,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.status-icon {
  font-size: 60rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
}

.countdown-row {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 12rpx;
}

.countdown-label {
  font-size: 26rpx;
  color: #999;
}

.countdown-value {
  font-size: 34rpx;
  color: #FF6B2C;
  font-weight: 700;
}

/* ─── 骑手信息 ─── */
.rider-card {
  background: #112228;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rider-info {
  display: flex;
  align-items: center;
}

.rider-avatar-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,107,44,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.rider-avatar-text {
  font-size: 40rpx;
}

.rider-detail {
  display: flex;
  flex-direction: column;
}

.rider-name {
  font-size: 28rpx;
  font-weight: 600;
}

.rider-distance {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.rider-call {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background: rgba(255,107,44,0.12);
  border-radius: 12rpx;
}

.call-icon {
  font-size: 36rpx;
}

.call-text {
  font-size: 20rpx;
  color: #FF6B2C;
  margin-top: 4rpx;
}

/* ─── 时间线 ─── */
.timeline-card {
  background: #112228;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.timeline-item {
  position: relative;
  padding-left: 40rpx;
  padding-bottom: 28rpx;
  min-height: 60rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 6rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #333;
  border: 3rpx solid #444;
}

.timeline-item.done .timeline-dot {
  background: #4CAF50;
  border-color: #4CAF50;
}

.timeline-item.active .timeline-dot {
  background: #FF6B2C;
  border-color: #FF6B2C;
  box-shadow: 0 0 12rpx rgba(255,107,44,0.5);
}

.timeline-line {
  position: absolute;
  left: 8rpx;
  top: 30rpx;
  bottom: 0;
  width: 4rpx;
  background: #333;
}

.timeline-item.done .timeline-line {
  background: #4CAF50;
}

.timeline-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.timeline-step {
  font-size: 26rpx;
  color: #999;
}

.timeline-item.done .timeline-step,
.timeline-item.active .timeline-step {
  color: #fff;
}

.timeline-time {
  font-size: 22rpx;
  color: #666;
}

/* ─── 订单详情折叠 ─── */
.detail-card {
  background: #112228;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 600;
}

.detail-toggle {
  font-size: 24rpx;
  color: #FF6B2C;
}

.detail-body {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 10rpx 0;
}

.detail-label {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.detail-value {
  font-size: 24rpx;
  color: #ccc;
  text-align: right;
}

.addr-val {
  max-width: 400rpx;
}

.detail-divider {
  height: 1rpx;
  background: rgba(255,255,255,0.04);
  margin: 12rpx 0;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}

.detail-item-name {
  font-size: 24rpx;
  color: #ccc;
}

.detail-item-price {
  font-size: 24rpx;
  color: #ccc;
}

.detail-row.total .detail-label {
  color: #fff;
  font-weight: 600;
}

.total-val {
  color: #FF6B2C;
  font-weight: 700;
  font-size: 28rpx;
}
