/* 门店评价列表页 */
.page { background: #f8f8f8; min-height: 100vh; }

/* ── 顶部评分概览 ── */
.score-header {
  background: #fff;
  padding: 40rpx 32rpx 32rpx;
  margin-bottom: 16rpx;
}
.store-title {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 24rpx;
}
.score-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.score-big {
  font-size: 72rpx;
  font-weight: bold;
  color: #FF6B35;
  line-height: 1;
}
.score-stars {
  display: flex;
  gap: 4rpx;
  flex-direction: column;
}
.score-star {
  font-size: 28rpx;
  color: #ddd;
}
.score-star.filled { color: #FF6B35; }
.score-star.half { color: #ffc49a; }
.score-count {
  font-size: 24rpx;
  color: #999;
  margin-left: auto;
}

/* 评分分布条 */
.dist-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}
.dist-label {
  font-size: 22rpx;
  color: #999;
  width: 48rpx;
}
.dist-bar-bg {
  flex: 1;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}
.dist-bar-fill {
  height: 100%;
  background: #FF6B35;
  border-radius: 6rpx;
  transition: width 0.3s;
}
.dist-pct {
  font-size: 22rpx;
  color: #999;
  width: 60rpx;
  text-align: right;
}

/* 分项评分 */
.sub-scores {
  display: flex;
  justify-content: space-around;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}
.sub-score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.sub-score-label {
  font-size: 22rpx;
  color: #999;
}
.sub-score-val {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B35;
}

/* ── 筛选 Tab ── */
.filter-tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
  overflow-x: auto;
}
.filter-tab {
  flex-shrink: 0;
  padding: 24rpx 32rpx;
  font-size: 26rpx;
  color: #666;
  position: relative;
}
.filter-tab.active {
  color: #FF6B35;
  font-weight: bold;
}
.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #FF6B35;
  border-radius: 2rpx;
}

/* ── 评价列表 ── */
.review-list { padding: 0 0 40rpx; }

.review-item {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

/* 用户行 */
.user-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.nickname {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}
.review-date {
  font-size: 22rpx;
  color: #ccc;
}
.item-stars { display: flex; gap: 4rpx; }
.item-star { font-size: 24rpx; color: #ddd; }
.item-star.filled { color: #FF6B35; }

/* 标签 Chips */
.tag-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.tag-chip {
  padding: 6rpx 18rpx;
  background: #fff3ef;
  color: #FF6B35;
  border-radius: 24rpx;
  font-size: 22rpx;
  border: 1rpx solid #ffd0bc;
}

/* 评价文字 */
.review-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  display: block;
  margin-bottom: 16rpx;
}

/* 评价图片 */
.review-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.review-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}

/* 商家回复 */
.merchant-reply {
  background: #f8f8f8;
  border-left: 4rpx solid #FF6B35;
  padding: 16rpx 20rpx;
  border-radius: 0 8rpx 8rpx 0;
  margin-top: 8rpx;
}
.reply-label {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: bold;
}
.reply-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: block;
  margin-top: 6rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #ccc; }

/* 加载更多 / 已全部加载 */
.load-more, .no-more {
  text-align: center;
  padding: 32rpx;
}
.load-more-text { font-size: 26rpx; color: #FF6B35; }
.no-more-text { font-size: 24rpx; color: #ccc; }
