/* 菜品详情页 — 深色主题，与 menu/cart 风格统一 */
/* 品牌色: #FF6B2C  背景: #0B1A20  次级背景: #112228  边线: #1a2a33 */

.detail-page {
  min-height: 100vh;
  background: #0B1A20;
  color: #fff;
  padding-bottom: 180rpx;
}

/* ─── 顶部大图 ─── */
.hero-wrap {
  position: relative;
  width: 750rpx;
  height: 480rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.hero-img {
  width: 750rpx;
  height: 480rpx;
  display: block;
}

.hero-placeholder {
  width: 750rpx;
  height: 480rpx;
  background: #112228;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-placeholder-text {
  font-size: 120rpx;
  color: rgba(255, 107, 44, 0.3);
  font-weight: bold;
}

/* 标签浮层 */
.hero-tags {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  font-weight: bold;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.tag-recommend {
  background: #FF6B2C;
  color: #fff;
}

.tag-new {
  background: #0F6E56;
  color: #fff;
}

.tag-spicy {
  background: #A32D2D;
  color: #fff;
}

/* 沽清遮罩 */
.soldout-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.soldout-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 4rpx;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  top: calc(24rpx + env(safe-area-inset-top));
  left: 24rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 52rpx;
  color: #fff;
  line-height: 1;
  margin-left: -4rpx;
  margin-top: -4rpx;
}

/* ─── 基础信息 ─── */
.info-section {
  padding: 32rpx 32rpx 24rpx;
  background: #112228;
}

.info-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.dish-name {
  flex: 1;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.3;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-shrink: 0;
}

.dish-price {
  font-size: 44rpx;
  color: #FF6B2C;
  font-weight: bold;
}

.original-price {
  font-size: 26rpx;
  color: #666;
  text-decoration: line-through;
}

.sales-hint {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  display: block;
}

.recommend-reason {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(24, 95, 165, 0.15);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin-top: 8rpx;
}

.recommend-icon {
  font-size: 20rpx;
  font-weight: bold;
  color: #fff;
  background: #185FA5;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.recommend-text {
  font-size: 24rpx;
  color: #7eb8f5;
  line-height: 1.4;
}

/* ─── 分割线 ─── */
.divider {
  height: 16rpx;
  background: #0B1A20;
}

/* ─── 菜品描述 ─── */
.desc-section {
  padding: 28rpx 32rpx;
  background: #112228;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ccc;
  margin-bottom: 16rpx;
  display: block;
}

.desc-text {
  font-size: 28rpx;
  color: #bbb;
  line-height: 1.7;
}

/* ─── 过敏原 ─── */
.allergen-section {
  padding: 0 32rpx;
  background: #112228;
}

.allergen-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-top: 1rpx solid #1a2a33;
}

.toggle-icon {
  font-size: 28rpx;
  color: #666;
}

.allergen-body {
  padding-bottom: 24rpx;
}

.allergen-text {
  font-size: 26rpx;
  color: #bbb;
  line-height: 1.6;
  display: block;
  margin-bottom: 8rpx;
}

/* ─── 规格选择 ─── */
.spec-section {
  padding: 28rpx 32rpx;
  background: #112228;
}

.spec-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.spec-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  border-radius: 12rpx;
  border: 2rpx solid #1a2a33;
  background: #0B1A20;
  min-width: 120rpx;
}

.spec-item.active {
  border-color: #FF6B2C;
  background: rgba(255, 107, 44, 0.08);
}

.spec-name {
  font-size: 28rpx;
  color: #ccc;
}

.spec-item.active .spec-name {
  color: #FF6B2C;
  font-weight: 600;
}

.spec-price {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.spec-item.active .spec-price {
  color: #FF6B2C;
}

/* ─── 数量选择 ─── */
.qty-section {
  padding: 24rpx 32rpx;
  background: #112228;
}

.qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.qty-label {
  font-size: 28rpx;
  color: #ccc;
}

.qty-ctrl {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.qty-btn.minus {
  background: #1a2a33;
  color: #ccc;
}

.qty-btn.minus.disabled {
  opacity: 0.35;
}

.qty-btn.plus {
  background: #FF6B2C;
  color: #fff;
}

.qty-num {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  min-width: 48rpx;
  text-align: center;
}

/* ─── 相关推荐 ─── */
.related-section {
  padding: 28rpx 0 28rpx 32rpx;
  background: #112228;
}

.related-section .section-title {
  padding-right: 32rpx;
}

.related-scroll {
  display: flex;
  white-space: nowrap;
  padding-bottom: 8rpx;
  margin-top: 8rpx;
}

.related-card {
  display: inline-flex;
  flex-direction: column;
  width: 200rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  vertical-align: top;
}

.related-img {
  width: 200rpx;
  height: 160rpx;
  border-radius: 16rpx;
  display: block;
}

.related-name {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200rpx;
}

.related-price {
  font-size: 26rpx;
  color: #FF6B2C;
  font-weight: bold;
  margin-top: 6rpx;
}

/* ─── 底部占位 ─── */
.bottom-placeholder {
  height: 180rpx;
}

/* ─── 加入购物车固定底栏 ─── */
.add-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #112228;
  border-top: 1rpx solid #1a2a33;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 32rpx;
  padding-right: 32rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.add-price {
  display: flex;
  flex-direction: column;
}

.add-price-label {
  font-size: 22rpx;
  color: #999;
}

.add-price-value {
  font-size: 40rpx;
  color: #FF6B2C;
  font-weight: bold;
  line-height: 1.2;
}

.add-btn {
  height: 88rpx;
  min-width: 280rpx;
  background: #FF6B2C;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 200ms ease;
}

.add-btn.adding {
  background: #0F6E56;
}

.add-btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* ─── 沽清底栏 ─── */
.soldout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #1a2a33;
  display: flex;
  align-items: center;
  justify-content: center;
}

.soldout-bar-text {
  font-size: 26rpx;
  color: #A32D2D;
}
