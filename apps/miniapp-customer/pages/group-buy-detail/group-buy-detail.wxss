.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 0;
}

/* 顶部轮播 */
.hero-swiper {
  width: 750rpx;
  height: 480rpx;
}
.hero-img {
  width: 100%;
  height: 480rpx;
  background: #e0e0e0;
}

/* 价格区 */
.price-card {
  background: #fff;
  padding: 32rpx;
  margin-bottom: 2rpx;
}
.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.group-price {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF3B30;
}
.original-price {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
}
.save-tag {
  font-size: 22rpx;
  color: #FF6B35;
  background: rgba(255,107,53,0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.campaign-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

/* 倒计时 */
.countdown-bar {
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}
.countdown-label {
  font-size: 26rpx;
  color: #666;
}
.countdown-nums {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.countdown-block {
  display: inline-block;
  width: 52rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: #FF3B30;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  border-radius: 8rpx;
  font-family: monospace;
}
.countdown-sep {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF3B30;
  margin: 0 2rpx;
}

/* 参团成员 */
.members-card {
  background: #fff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}
.members-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.members-hint {
  font-size: 24rpx;
  color: #FF6B35;
}
.members-hint.success {
  color: #52c41a;
}
.avatar-row {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}
.avatar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar-img {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #eee;
}
.avatar-placeholder {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #FF6B35;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}
.avatar-placeholder.empty {
  background: #e0e0e0;
  color: #999;
  border: 2rpx dashed #ccc;
}
.avatar-placeholder.more {
  background: #f0f0f0;
  color: #666;
  font-size: 20rpx;
}

/* 活动规则 */
.rules-card {
  background: #fff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}
.rules-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.rules-arrow {
  font-size: 24rpx;
  color: #999;
}
.rules-body {
  margin-top: 20rpx;
}
.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.rule-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FF6B35;
  margin-top: 14rpx;
  flex-shrink: 0;
}
.rule-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 菜品介绍 */
.dish-intro-card {
  background: #fff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}
.dish-desc {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}
.dish-detail-img {
  width: 100%;
  margin-top: 20rpx;
  border-radius: 12rpx;
}

/* 底部占位 */
.bottom-spacer {
  height: 140rpx;
}

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.btn-share {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #666 !important;
  background: #f0f0f0 !important;
  border-radius: 44rpx;
  border: none;
}
.btn-join {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff !important;
  background: #FF6B35 !important;
  border-radius: 44rpx;
  border: none;
}
.btn-join[disabled] {
  opacity: 0.6;
}

/* 成功弹层 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-content {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}
.modal-icon {
  width: 100rpx;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50%;
  background: #52c41a;
  color: #fff;
  font-size: 48rpx;
  margin: 0 auto 24rpx;
}
.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
.modal-desc {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 32rpx;
}
.modal-share-btn {
  width: 100% !important;
  height: 80rpx;
  line-height: 80rpx;
  background: #FF6B35 !important;
  color: #fff !important;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 20rpx;
}
.modal-close {
  font-size: 26rpx;
  color: #999;
  display: block;
}
