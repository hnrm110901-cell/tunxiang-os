.container { padding: 0; background: #0B1A20; min-height: 100vh; color: #fff; }
.page-title { font-size: 36rpx; font-weight: bold; padding: 30rpx 30rpx 0; }

/* 筛选栏 */
.filter-bar { display: flex; padding: 24rpx 30rpx; gap: 20rpx; }
.filter-item { padding: 14rpx 32rpx; background: #1a2a33; border-radius: 30rpx; font-size: 26rpx; color: #999; }
.filter-item.active { background: #FF6B2C; color: #fff; }

/* 优惠券列表 */
.coupon-list { padding: 0 30rpx 30rpx; }
.empty-tip { text-align: center; color: #666; font-size: 28rpx; padding: 120rpx 0; }

/* 单张优惠券卡片 */
.coupon-card { display: flex; align-items: center; background: #112228; border-radius: 16rpx; margin-bottom: 24rpx; overflow: hidden; }
.coupon-card.disabled { opacity: 0.5; }

/* 左侧金额区域 */
.coupon-left { width: 200rpx; min-height: 180rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20rpx 0; position: relative; }
.coupon-left::after { content: ''; position: absolute; right: 0; top: 20rpx; bottom: 20rpx; width: 1rpx; border-right: 2rpx dashed #1a2a33; }
.coupon-type-reduction { background: rgba(255, 107, 44, 0.1); }
.coupon-type-discount { background: rgba(255, 107, 44, 0.1); }
.coupon-type-gift { background: rgba(76, 175, 80, 0.1); }

.coupon-amount { display: flex; align-items: baseline; }
.amount-symbol { font-size: 28rpx; color: #FF6B2C; }
.amount-symbol.small { font-size: 24rpx; }
.amount-value { font-size: 56rpx; font-weight: bold; color: #FF6B2C; }
.coupon-threshold { font-size: 22rpx; color: #999; margin-top: 8rpx; }

/* 右侧信息 */
.coupon-right { flex: 1; padding: 24rpx; display: flex; flex-direction: column; gap: 8rpx; }
.coupon-name { font-size: 28rpx; font-weight: bold; color: #fff; }
.coupon-condition { font-size: 22rpx; color: #FF6B2C; }
.coupon-expire { font-size: 22rpx; color: #666; }

/* 操作区 */
.coupon-action { padding: 0 24rpx; display: flex; align-items: center; }
.use-btn { font-size: 24rpx; background: #FF6B2C !important; color: #fff !important; border-radius: 30rpx; padding: 0 24rpx; height: 56rpx; line-height: 56rpx; min-width: 0; }
.status-label { font-size: 24rpx; color: #666; white-space: nowrap; }
