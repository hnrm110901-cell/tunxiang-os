.page { background: #f8f8f8; padding-bottom: 120rpx; }
.order-header { background: #FF6B35; padding: 40rpx 32rpx 32rpx; color: #fff; }
.header-title { font-size: 36rpx; font-weight: bold; display: block; }
.order-no { font-size: 24rpx; opacity: 0.85; display: block; margin-top: 8rpx; }
.store-name { font-size: 22rpx; opacity: 0.75; display: block; margin-top: 4rpx; }

.section { background: #fff; margin-top: 16rpx; padding: 32rpx; }
.section-title { font-size: 30rpx; color: #333; font-weight: bold; display: block; margin-bottom: 24rpx; }

/* 星星评分 */
.star-row { display: flex; gap: 16rpx; margin-bottom: 12rpx; }
.star { font-size: 64rpx; color: #ddd; }
.star.filled { color: #FF6B35; }
.rating-label { font-size: 26rpx; color: #FF6B35; }

/* 分项评分 */
.sub-rating { display: flex; align-items: center; margin-bottom: 20rpx; }
.sub-label { width: 160rpx; font-size: 26rpx; color: #666; }
.sub-stars { display: flex; gap: 8rpx; }
.sub-star { font-size: 40rpx; color: #ddd; }
.sub-star.filled { color: #FF6B35; }

/* 文字评价 */
.review-text { width: 100%; min-height: 160rpx; font-size: 28rpx; color: #333; }
.word-count { text-align: right; font-size: 22rpx; color: #ccc; display: block; }

/* 图片区 */
.image-area { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.img-item { position: relative; width: 160rpx; height: 160rpx; }
.preview { width: 160rpx; height: 160rpx; border-radius: 8rpx; background: #eee; }
.del-img { position: absolute; top: -10rpx; right: -10rpx; width: 36rpx; height: 36rpx; background: rgba(0,0,0,0.5); color: #fff; border-radius: 50%; font-size: 24rpx; text-align: center; line-height: 36rpx; }
.add-img { width: 160rpx; height: 160rpx; border: 2rpx dashed #ddd; border-radius: 8rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.add-icon { font-size: 48rpx; }
.add-text { font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* 快速标签 */
.tags-area { display: flex; flex-wrap: wrap; gap: 12rpx; }
.quick-tag { padding: 10rpx 24rpx; background: #f5f5f5; border-radius: 32rpx; font-size: 26rpx; color: #666; border: 2rpx solid transparent; }
.quick-tag.selected { background: #fff3ef; color: #FF6B35; border-color: #FF6B35; }

/* 匿名 */
.anon-section { display: flex; justify-content: space-between; align-items: center; }

/* 提交 */
.submit-area { position: fixed; bottom: 0; left: 0; right: 0; padding: 16rpx 32rpx 40rpx; background: #fff; }
.submit-btn { background: #FF6B35; color: #fff; font-size: 32rpx; border-radius: 48rpx; }
.submit-btn.disabled { background: #ffd0bc; }
