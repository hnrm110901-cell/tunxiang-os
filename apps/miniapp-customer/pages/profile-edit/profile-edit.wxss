.page-container {
  min-height: 100vh;
  background: #0B1A20;
  color: #fff;
  padding-bottom: 120rpx;
}

/* --- 头像区 --- */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #1a2a33;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-overlay-text {
  font-size: 22rpx;
  color: #fff;
}

.avatar-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* --- 表单区 --- */
.form-section {
  margin: 0 32rpx;
  background: #112228;
  border-radius: 20rpx;
  overflow: hidden;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #1a2a33;
}

.form-row:last-child { border-bottom: none; }

.form-label {
  font-size: 30rpx;
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #fff;
  text-align: right;
}

.form-placeholder { color: #555; }

.form-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.form-picker-text {
  font-size: 30rpx;
  color: #fff;
}

.form-arrow {
  font-size: 28rpx;
  color: #666;
}

.form-phone-row {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
}

.form-phone-text {
  font-size: 30rpx;
  color: #fff;
}

.form-phone-btn {
  background: rgba(255, 107, 53, 0.15);
  border: 1rpx solid rgba(255, 107, 53, 0.4);
  border-radius: 24rpx;
  padding: 6rpx 24rpx;
}

.form-phone-btn-text {
  font-size: 24rpx;
  color: #FF6B35;
}

/* --- 标签区（口味/过敏原） --- */
.tags-section {
  margin: 24rpx 32rpx 0;
  background: #112228;
  border-radius: 20rpx;
  padding: 28rpx;
}

.tags-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.tags-hint {
  font-size: 22rpx;
  color: #666;
  display: block;
  margin-bottom: 24rpx;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  border: 1rpx solid #1a2a33;
  background: rgba(255, 255, 255, 0.05);
}

.tag-text {
  font-size: 28rpx;
  color: #ccc;
}

.tag-selected {
  background: rgba(255, 107, 53, 0.15);
  border-color: #FF6B35;
}

.tag-selected .tag-text {
  color: #FF6B35;
}

.tag-selected-warn {
  background: rgba(255, 59, 48, 0.15);
  border-color: #FF3B30;
}

.tag-selected-warn .tag-text {
  color: #FF3B30;
}

/* --- 保存按钮 --- */
.save-section {
  padding: 48rpx 32rpx 32rpx;
}

.save-btn {
  background: #FF6B2C !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  width: 100%;
}

.save-btn-disabled {
  opacity: 0.6;
}
