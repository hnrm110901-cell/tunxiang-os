.page { background: #f8f8f8; min-height: 100vh; padding-bottom: 120rpx; }

.image-section { background: #fff; padding: 24rpx; margin-bottom: 16rpx; }
.image-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.image-item { position: relative; width: 200rpx; height: 200rpx; }
.preview-img { width: 200rpx; height: 200rpx; border-radius: 8rpx; background: #eee; }
.del-btn {
  position: absolute; top: -12rpx; right: -12rpx;
  width: 40rpx; height: 40rpx; border-radius: 50%;
  background: rgba(0,0,0,0.5); color: #fff;
  font-size: 28rpx; text-align: center; line-height: 40rpx;
}
.add-image {
  width: 200rpx; height: 200rpx; border-radius: 8rpx;
  border: 2rpx dashed #ddd; display: flex;
  flex-direction: column; align-items: center; justify-content: center;
  background: #fafafa;
}
.add-icon { font-size: 56rpx; color: #999; line-height: 1; }
.add-text { font-size: 22rpx; color: #999; margin-top: 4rpx; }

.section { background: #fff; padding: 24rpx; margin-bottom: 16rpx; }
.content-section { position: relative; }
.section-label { font-size: 26rpx; color: #333; font-weight: bold; display: block; margin-bottom: 16rpx; }

.title-input { font-size: 30rpx; color: #333; width: 100%; }
.content-input { font-size: 28rpx; color: #333; width: 100%; min-height: 200rpx; }
.word-count { position: absolute; right: 24rpx; bottom: 24rpx; font-size: 22rpx; color: #ccc; }

.tags-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag-chip {
  padding: 10rpx 24rpx; border-radius: 32rpx;
  font-size: 26rpx; background: #f5f5f5; color: #666;
  border: 2rpx solid transparent;
}
.tag-chip.selected { background: #fff3ef; color: #FF6B35; border-color: #FF6B35; }

.link-store { display: flex; align-items: center; }
.store-name { flex: 1; font-size: 26rpx; color: #999; }
.arrow { font-size: 32rpx; color: #ccc; }

.submit-area { position: fixed; bottom: 0; left: 0; right: 0; padding: 16rpx 32rpx 40rpx; background: #fff; }
.submit-btn { background: #FF6B35; color: #fff; font-size: 32rpx; border-radius: 48rpx; }
.submit-btn.disabled { background: #ffd0bc; }
