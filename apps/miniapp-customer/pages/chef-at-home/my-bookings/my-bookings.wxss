.container {
  padding: 0;
  background: #0B1A20;
  min-height: 100vh;
  color: #fff;
}

/* ─── Tab栏 ─── */
.tab-bar {
  display: flex;
  background: #112228;
  border-bottom: 1rpx solid #1a2a33;
  position: sticky;
  top: 0;
  z-index: 50;
}
.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx 0;
  font-size: 26rpx;
  color: #999;
  position: relative;
}
.tab-item.active {
  color: #FF6B35;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #FF6B35;
  border-radius: 2rpx;
}
.tab-badge {
  background: #FF6B35;
  border-radius: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}
.tab-badge-text { font-size: 20rpx; color: #fff; font-weight: bold; }

/* ─── 列表区域 ─── */
.list-wrap { padding: 24rpx 32rpx; }

/* ─── 加载态 ─── */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 24rpx;
}
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid #1a2a33;
  border-top-color: #FF6B35;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #999; }

/* ─── 空状态 ─── */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 16rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-title { font-size: 32rpx; color: #fff; font-weight: 500; }
.empty-sub { font-size: 26rpx; color: #999; }
.go-book-btn {
  margin-top: 16rpx;
  padding: 20rpx 56rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* ─── 待确认提示条 ─── */
.pending-notice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(186,117,23,0.12);
  border: 1rpx solid rgba(186,117,23,0.3);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}
.notice-icon { font-size: 32rpx; }
.notice-text { font-size: 26rpx; color: #BA7517; line-height: 1.5; flex: 1; }

/* ─── 预约卡片 ─── */
.booking-card {
  background: #112228;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.status-tag.status-pending {
  color: #BA7517;
  background: rgba(186,117,23,0.15);
}
.status-tag.status-confirmed {
  color: #0F6E56;
  background: rgba(15,110,86,0.15);
}
.status-tag.status-in_service {
  color: #FF6B35;
  background: rgba(255,107,53,0.15);
}
.status-tag.status-completed {
  color: #999;
  background: rgba(153,153,153,0.1);
}
.status-tag.status-cancelled {
  color: #666;
  background: rgba(102,102,102,0.1);
}
.booking-id { font-size: 22rpx; color: #555; }

/* 大厨信息行 */
.chef-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #1a2a33;
}
.chef-avatar-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #1a2a33;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.chef-avatar-emoji { font-size: 44rpx; }
.chef-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.chef-name { font-size: 30rpx; font-weight: bold; color: #fff; }
.chef-title { font-size: 22rpx; color: #999; }

.contact-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 16rpx;
  background: rgba(255,107,53,0.1);
  border-radius: 16rpx;
  flex-shrink: 0;
}
.contact-btn-icon { font-size: 28rpx; }
.contact-btn-text { font-size: 20rpx; color: #FF6B35; }

/* 详情行 */
.booking-detail { display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 20rpx; }
.detail-row { display: flex; align-items: flex-start; gap: 12rpx; }
.detail-icon { font-size: 26rpx; flex-shrink: 0; width: 36rpx; }
.detail-text { font-size: 28rpx; color: #ccc; flex: 1; }
.address-text { word-break: break-all; line-height: 1.5; }

/* 金额行 */
.amount-row {
  display: flex;
  gap: 32rpx;
  padding: 16rpx 0 0;
  border-top: 1rpx solid #1a2a33;
}
.amount-info, .deposit-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.amount-label, .deposit-label { font-size: 22rpx; color: #999; }
.amount-total { font-size: 30rpx; color: #fff; font-weight: 600; }
.deposit-paid { font-size: 28rpx; color: #FF6B35; font-weight: 600; }

/* 操作按钮 */
.card-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
}
.cancel-btn {
  padding: 16rpx 32rpx;
  border: 1rpx solid #555;
  border-radius: 44rpx;
  font-size: 26rpx;
  color: #999;
}
.track-btn {
  padding: 16rpx 32rpx;
  background: #FF6B35;
  border-radius: 44rpx;
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

/* ─── 取消确认弹层（卡片内） ─── */
.cancel-confirm-layer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(11,26,32,0.92);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}
.cancel-confirm-box {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}
.cancel-confirm-title { font-size: 32rpx; font-weight: bold; color: #fff; }
.cancel-confirm-sub { font-size: 24rpx; color: #999; text-align: center; }
.cancel-confirm-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 16rpx;
  width: 100%;
}
.cancel-confirm-no {
  flex: 1;
  height: 88rpx;
  border: 1rpx solid #555;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999;
}
.cancel-confirm-yes {
  flex: 1;
  height: 88rpx;
  background: #A32D2D;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}
.cancel-confirm-yes.loading { opacity: 0.7; }

.bottom-spacer { height: 80rpx; }
