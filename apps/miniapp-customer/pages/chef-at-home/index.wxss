.container { padding: 0; background: #0B1A20; min-height: 100vh; color: #fff; padding-bottom: 60rpx; }

/* 顶部横幅 */
.hero-banner {
  background: linear-gradient(135deg, #FF6B35, #FF8C5A);
  padding: 48rpx 32rpx 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.hero-text { display: flex; flex-direction: column; gap: 10rpx; }
.hero-title { font-size: 44rpx; font-weight: bold; color: #fff; display: block; }
.hero-subtitle { font-size: 26rpx; color: rgba(255,255,255,0.9); display: block; }
.hero-deco { font-size: 80rpx; }

/* 地址/搜索栏 */
.search-bar { padding: 20rpx 32rpx; background: #112228; }
.location-row {
  display: flex;
  align-items: center;
  background: #1a2a33;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  gap: 12rpx;
}
.location-icon { font-size: 28rpx; }
.location-text { flex: 1; font-size: 28rpx; color: #ccc; }
.location-arrow { font-size: 32rpx; color: #FF6B35; font-weight: bold; }

/* 日期筛选 */
.date-filter-wrap { padding: 20rpx 0 0; background: #112228; border-bottom: 1rpx solid #1a2a33; }
.date-scroll { width: 100%; }
.date-list { display: flex; padding: 0 24rpx 20rpx; white-space: nowrap; }
.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  margin-right: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #1a2a33;
  gap: 6rpx;
}
.date-item.active { background: #FF6B35; }
.date-weekday { font-size: 22rpx; color: #999; }
.date-item.active .date-weekday { color: rgba(255,255,255,0.8); }
.date-day { font-size: 32rpx; font-weight: bold; color: #fff; }
.date-month { font-size: 20rpx; color: #666; }
.date-item.active .date-month { color: rgba(255,255,255,0.7); }

/* 菜系筛选 */
.cuisine-filter-wrap { padding: 20rpx 0; background: #0B1A20; }
.cuisine-filter { white-space: nowrap; padding: 0 24rpx; }
.cuisine-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  background: #1a2a33;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #999;
  margin-right: 16rpx;
}
.cuisine-item.active { background: #FF6B35; color: #fff; }

/* 厨师列表 */
.chef-list-wrap { padding: 0 32rpx; }

.loading-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
  gap: 20rpx;
}
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 4rpx solid #1a2a33;
  border-top-color: #FF6B35;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.error-tip { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 24rpx; }
.error-text { font-size: 28rpx; color: #999; }
.retry-btn { padding: 16rpx 48rpx; background: #FF6B35; color: #fff; border-radius: 44rpx; font-size: 28rpx; }

.empty-tip { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; gap: 16rpx; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 30rpx; color: #fff; font-weight: 500; }
.empty-sub { font-size: 26rpx; color: #666; }

/* 厨师卡片 */
.chef-card {
  display: flex;
  align-items: flex-start;
  background: #112228;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  margin-top: 20rpx;
  gap: 20rpx;
}

.chef-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #1a2a33;
}

.chef-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 10rpx; }

.chef-name-row { display: flex; align-items: center; gap: 12rpx; }
.chef-name { font-size: 30rpx; font-weight: bold; color: #fff; }
.chef-title-badge {
  font-size: 20rpx;
  color: #FF6B35;
  background: rgba(255,107,53,0.15);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.chef-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.chef-tag {
  font-size: 22rpx;
  color: #999;
  background: #1a2a33;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.chef-stats-row { display: flex; align-items: center; gap: 8rpx; font-size: 24rpx; color: #999; }
.chef-rating { color: #FFC832; }
.chef-dot { color: #333; }

.chef-specialties { font-size: 24rpx; color: #666; }

.chef-price-row { display: flex; align-items: center; gap: 12rpx; }
.chef-fee-label { font-size: 22rpx; color: #999; }
.chef-fee { font-size: 26rpx; color: #FF6B35; font-weight: bold; }
.chef-distance { font-size: 22rpx; color: #666; margin-left: auto; }

/* 预约按钮（右侧竖向） */
.chef-book-btn {
  flex-shrink: 0;
  background: #FF6B35;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  text-align: center;
  align-self: center;
  writing-mode: vertical-rl;
  letter-spacing: 4rpx;
}

.bottom-spacer { height: 60rpx; }
