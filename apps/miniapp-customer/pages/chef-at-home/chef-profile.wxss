.container { padding: 0; background: #0B1A20; min-height: 100vh; color: #fff; }
.loading-tip { display: flex; flex-direction: column; align-items: center; color: #666; font-size: 28rpx; padding: 120rpx 0; gap: 20rpx; }
.loading-spinner { width: 60rpx; height: 60rpx; border-radius: 50%; border: 4rpx solid #1a2a33; border-top-color: #FF6B35; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty-tip { text-align: center; color: #666; font-size: 28rpx; padding: 80rpx 0; }
.load-error { text-align: center; padding: 120rpx 32rpx; }
.error-text { font-size: 28rpx; color: #999; }

/* 厨师头部 */
.profile-header { display: flex; padding: 40rpx 32rpx; background: #112228; gap: 24rpx; }
.profile-avatar { width: 160rpx; height: 160rpx; border-radius: 24rpx; flex-shrink: 0; background: #1a2a33; }
.profile-info { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 16rpx; }
.profile-name-row { display: flex; align-items: center; gap: 12rpx; }
.profile-name { font-size: 36rpx; font-weight: bold; }
.profile-title { font-size: 22rpx; color: #FF6B35; background: rgba(255,107,53,0.15); padding: 6rpx 14rpx; border-radius: 8rpx; }
.profile-stats { display: flex; align-items: center; gap: 0; }
.stat-item { display: flex; flex-direction: column; align-items: center; flex: 1; }
.stat-divider { width: 1rpx; height: 40rpx; background: #1a2a33; }
.stat-value { font-size: 30rpx; font-weight: bold; color: #FF6B35; }
.stat-label { font-size: 20rpx; color: #999; margin-top: 4rpx; }
.cuisine-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.cuisine-tag { font-size: 22rpx; color: #999; background: #1a2a33; padding: 4rpx 12rpx; border-radius: 8rpx; }

/* Tab */
.tab-bar { display: flex; border-bottom: 1rpx solid #1a2a33; background: #0B1A20; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 26rpx; color: #999; position: relative; }
.tab-item.active { color: #FF6B35; font-weight: 600; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 25%; right: 25%; height: 4rpx; background: #FF6B35; border-radius: 2rpx; }

/* Tab 内容 */
.tab-content { padding: 32rpx; padding-bottom: 160rpx; }
.booking-tab { padding-bottom: 200rpx; }

/* 简介 */
.info-block { margin-bottom: 36rpx; }
.info-title { font-size: 28rpx; color: #999; display: block; margin-bottom: 16rpx; }
.tag-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag { font-size: 26rpx; color: #999; background: #1a2a33; padding: 10rpx 20rpx; border-radius: 12rpx; }
.tag.highlight { color: #FF6B35; background: rgba(255,107,53,0.1); }
.status-badge { font-size: 26rpx; padding: 8rpx 20rpx; border-radius: 12rpx; display: inline-block; }
.status-available { color: #4CAF50; background: rgba(76,175,80,0.15); }
.status-booked { color: #FFC832; background: rgba(255,200,50,0.15); }
.status-on_service { color: #FF6B35; background: rgba(255,107,53,0.15); }
.status-off_duty { color: #999; background: rgba(153,153,153,0.15); }

/* 作品集 */
.portfolio-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.portfolio-item { width: calc(50% - 8rpx); }
.portfolio-image { width: 100%; height: 240rpx; border-radius: 16rpx; background: #1a2a33; }
.portfolio-caption { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }

/* 评价 */
.rating-card { background: #112228; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.rating-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.rating-stars { color: #FFC832; font-size: 28rpx; }
.rating-date { color: #666; font-size: 22rpx; }
.rating-comment { font-size: 28rpx; color: #ccc; line-height: 1.6; }

/* ─── 预约表单 ─── */
.form-block { margin-bottom: 40rpx; }
.form-block-title { font-size: 30rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 4rpx; }
.form-block-hint { font-size: 22rpx; color: #999; display: block; margin-bottom: 20rpx; }

.loading-inline { font-size: 26rpx; color: #999; padding: 24rpx 0; }

/* 日历 */
.calendar-month-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.month-nav-btn { width: 56rpx; height: 56rpx; background: #1a2a33; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; color: #FF6B35; text-align: center; line-height: 56rpx; }
.month-label { font-size: 30rpx; font-weight: bold; }

.calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 10rpx; }
.calendar-weekday { text-align: center; font-size: 22rpx; color: #999; padding: 8rpx 0; }
.calendar-cell { text-align: center; font-size: 28rpx; padding: 16rpx 0; border-radius: 12rpx; }
.calendar-cell.empty { background: transparent; }
.calendar-cell.available { color: #fff; background: rgba(255,107,53,0.15); cursor: pointer; }
.calendar-cell.available.selected { background: #FF6B35; color: #fff; font-weight: bold; }
.calendar-cell.unavailable { color: #444; background: #111; }

.calendar-legend { display: flex; gap: 32rpx; margin-top: 20rpx; }
.legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; color: #999; }
.legend-dot { width: 20rpx; height: 20rpx; border-radius: 6rpx; }
.legend-dot.available { background: rgba(255,107,53,0.15); border: 1rpx solid #FF6B35; }
.legend-dot.unavailable { background: #111; }
.legend-dot.selected { background: #FF6B35; }

/* 时间段 */
.slot-list { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; }
.slot-item { padding: 16rpx 28rpx; background: #1a2a33; border-radius: 12rpx; font-size: 26rpx; color: #999; }
.slot-item.active { background: #FF6B35; color: #fff; }

/* 人数步进器 */
.guest-stepper { display: flex; align-items: center; gap: 24rpx; margin-top: 16rpx; }
.stepper-btn { width: 72rpx; height: 72rpx; background: #1a2a33; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 40rpx; color: #FF6B35; text-align: center; line-height: 72rpx; }
.stepper-btn.disabled { opacity: 0.4; }
.stepper-value { font-size: 36rpx; font-weight: bold; min-width: 80rpx; text-align: center; }

/* 地址输入 */
.address-row { display: flex; gap: 16rpx; align-items: center; margin-top: 16rpx; }
.form-input { background: #1a2a33; padding: 20rpx 24rpx; border-radius: 12rpx; font-size: 28rpx; color: #fff; flex: 1; }
.address-input { flex: 1; }
.location-pick-btn { background: #FF6B35; color: #fff; padding: 20rpx 20rpx; border-radius: 12rpx; font-size: 24rpx; flex-shrink: 0; }

/* 备注 */
.form-textarea { background: #1a2a33; padding: 20rpx 24rpx; border-radius: 12rpx; font-size: 28rpx; color: #fff; width: 100%; height: 160rpx; box-sizing: border-box; margin-top: 16rpx; }
.placeholder { color: #555; }
.char-count { font-size: 22rpx; color: #555; display: block; text-align: right; margin-top: 8rpx; }

.bottom-spacer { height: 200rpx; }

/* ─── 底部操作栏 ─── */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #112228;
  border-top: 1rpx solid #1a2a33;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 100;
}

.bottom-fee-info { display: flex; flex-direction: column; gap: 4rpx; flex: 1; }
.bottom-fee-label { font-size: 22rpx; color: #999; }
.bottom-fee-price { font-size: 32rpx; color: #FF6B35; font-weight: bold; }

.switch-booking-btn {
  background: #FF6B35;
  color: #fff;
  padding: 22rpx 56rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  flex-shrink: 0;
}
.switch-booking-btn.disabled { background: #555; }

.booking-summary { display: flex; flex-direction: column; gap: 4rpx; flex: 1; }
.booking-date-label { font-size: 24rpx; color: #fff; }
.booking-guests-label { font-size: 22rpx; color: #999; }

.confirm-booking-btn {
  background: #FF6B35;
  color: #fff;
  padding: 22rpx 48rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  flex-shrink: 0;
}
.confirm-booking-btn.loading { opacity: 0.7; }
