.container {
  padding: 0;
  background: #0B1A20;
  min-height: 100vh;
  color: #fff;
  padding-bottom: 160rpx;
}

/* ─── 加载/错误态 ─── */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 24rpx;
}
.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 4rpx solid #1a2a33;
  border-top-color: #FF6B35;
  animation: spin 0.8s linear infinite;
}
.loading-spinner-sm {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #1a2a33;
  border-top-color: #FF6B35;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 28rpx; color: #999; }
.error-wrap { display: flex; flex-direction: column; align-items: center; padding: 120rpx 32rpx; gap: 24rpx; }
.error-icon { font-size: 64rpx; }
.error-text { font-size: 28rpx; color: #999; }
.retry-btn { padding: 20rpx 56rpx; background: #FF6B35; color: #fff; border-radius: 44rpx; font-size: 28rpx; }

/* ─── 大厨头部横幅 ─── */
.chef-hero {
  position: relative;
  height: 360rpx;
  overflow: hidden;
}
.chef-hero-bg {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}
.chef-hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(11,26,32,0.3) 0%, rgba(11,26,32,0.85) 100%);
}
.chef-hero-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: flex-end;
  gap: 24rpx;
}
.chef-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4rpx solid #FF6B35;
  flex-shrink: 0;
  background: #1a2a33;
}
.chef-hero-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding-bottom: 8rpx;
}
.chef-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.chef-name { font-size: 40rpx; font-weight: bold; color: #fff; }
.chef-title-badge {
  font-size: 22rpx;
  color: #FF6B35;
  background: rgba(255,107,53,0.2);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(255,107,53,0.4);
}
.chef-slogan { font-size: 24rpx; color: rgba(255,255,255,0.75); line-height: 1.5; }
.chef-meta-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}
.chef-meta-item { font-size: 24rpx; color: rgba(255,255,255,0.8); }
.chef-meta-dot { font-size: 20rpx; color: #555; }

/* ─── 荣誉证书 ─── */
.honors-wrap { padding: 20rpx 0; border-bottom: 1rpx solid #1a2a33; }
.honors-scroll { width: 100%; }
.honors-list { display: flex; padding: 0 32rpx; white-space: nowrap; gap: 16rpx; }
.honor-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,200,50,0.1);
  border: 1rpx solid rgba(255,200,50,0.3);
  border-radius: 24rpx;
  padding: 10rpx 20rpx;
  flex-shrink: 0;
}
.honor-icon { font-size: 28rpx; }
.honor-text { font-size: 24rpx; color: #FFC832; }

/* ─── 服务信息卡片 ─── */
.info-card {
  background: #112228;
  margin: 20rpx 32rpx;
  border-radius: 24rpx;
  padding: 28rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
  color: #fff;
}
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 24rpx;
}
.info-cell { display: flex; flex-direction: column; gap: 8rpx; }
.info-label { font-size: 24rpx; color: #999; }
.info-value { font-size: 28rpx; color: #fff; font-weight: 500; }
.info-value.primary { color: #FF6B35; }
.time-slots-row { display: flex; flex-direction: column; gap: 12rpx; }
.slot-tags { display: flex; flex-wrap: wrap; gap: 10rpx; }
.slot-tag {
  font-size: 24rpx;
  color: #ccc;
  background: #1a2a33;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* ─── 个人简介 ─── */
.bio-card {
  background: #112228;
  margin: 20rpx 32rpx;
  border-radius: 24rpx;
  padding: 28rpx;
}
.bio-content { margin-top: 16rpx; }
.bio-text {
  font-size: 28rpx;
  color: #ccc;
  line-height: 1.7;
  display: block;
}
.bio-collapsed {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}
.bio-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0 0;
}
.bio-toggle-text { font-size: 24rpx; color: #FF6B35; }
.bio-toggle-arrow { font-size: 24rpx; color: #FF6B35; }

/* ─── 擅长菜系标签 ─── */
.cuisine-tags-card {
  background: #112228;
  margin: 20rpx 32rpx;
  border-radius: 24rpx;
  padding: 28rpx;
}
.cuisine-tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}
.cuisine-tag-item {
  font-size: 26rpx;
  color: #FF6B35;
  background: rgba(255,107,53,0.12);
  border: 1rpx solid rgba(255,107,53,0.3);
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
}

/* ─── 代表作品横向滚动 ─── */
.signature-section {
  padding: 0 0 8rpx;
}
.signature-title {
  padding: 24rpx 32rpx 16rpx;
}
.signature-scroll { width: 100%; }
.signature-list {
  display: flex;
  padding: 0 32rpx;
  white-space: nowrap;
  gap: 16rpx;
}
.signature-card {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  flex-shrink: 0;
  background: #112228;
  border-radius: 16rpx;
  overflow: hidden;
}
.signature-image {
  width: 240rpx;
  height: 180rpx;
  background: #1a2a33;
}
.signature-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  padding: 12rpx 16rpx 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.signature-price {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: bold;
  padding: 0 16rpx 12rpx;
}

/* ─── 用户评价 ─── */
.reviews-section {
  padding: 0 32rpx 24rpx;
}
.reviews-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 24rpx 0 16rpx;
}
.reviews-count { font-size: 24rpx; color: #999; }
.reviews-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #999;
}
.reviews-empty { text-align: center; padding: 40rpx 0; }
.reviews-empty-text { font-size: 28rpx; color: #666; }
.reviews-list { display: flex; flex-direction: column; gap: 16rpx; }
.review-item {
  background: #112228;
  border-radius: 20rpx;
  padding: 24rpx;
}
.review-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.review-user {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.review-avatar-placeholder {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #1a2a33;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}
.review-name { font-size: 26rpx; color: #ccc; }
.review-date { font-size: 22rpx; color: #666; }
.review-stars { display: flex; gap: 4rpx; margin-bottom: 10rpx; }
.review-star { font-size: 28rpx; color: #333; }
.review-star.active { color: #FFC832; }
.review-content {
  font-size: 28rpx;
  color: #ddd;
  line-height: 1.6;
  display: block;
}
.review-images {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}
.review-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #1a2a33;
}

/* ─── 菜单区域 ─── */
.menu-section { padding: 0 0 32rpx; }
.menu-section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}
.section-title { font-size: 32rpx; font-weight: bold; }
.section-hint { font-size: 24rpx; color: #999; }

.loading-menu {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 60rpx 0;
  font-size: 26rpx;
  color: #999;
}

/* 分类Tab */
.category-tabs { width: 100%; }
.category-tab-list { display: flex; padding: 0 32rpx 16rpx; white-space: nowrap; border-bottom: 1rpx solid #1a2a33; }
.category-tab {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 24rpx;
  font-size: 26rpx;
  color: #999;
  border-radius: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.category-tab.active {
  color: #FF6B35;
  background: rgba(255,107,53,0.12);
  font-weight: 600;
}
.category-count {
  font-size: 22rpx;
  color: #666;
  background: #1a2a33;
  padding: 2rpx 8rpx;
  border-radius: 12rpx;
  min-width: 28rpx;
  text-align: center;
}
.category-tab.active .category-count {
  color: #FF6B35;
  background: rgba(255,107,53,0.2);
}

/* 菜品列表 */
.dish-list { padding: 16rpx 32rpx; display: flex; flex-direction: column; gap: 16rpx; }
.dish-card {
  display: flex;
  gap: 20rpx;
  background: #112228;
  border-radius: 20rpx;
  padding: 20rpx;
  align-items: flex-start;
}
.dish-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #1a2a33;
}
.dish-info { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.dish-name { font-size: 30rpx; font-weight: 600; color: #fff; }
.dish-desc { font-size: 24rpx; color: #999; line-height: 1.5; }
.dish-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.dish-tag {
  font-size: 22rpx;
  color: #FF6B35;
  background: rgba(255,107,53,0.1);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}
.dish-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}
.dish-price { font-size: 30rpx; color: #FF6B35; font-weight: bold; }

/* 步进器 */
.dish-stepper { display: flex; align-items: center; gap: 12rpx; }
.stepper-minus,
.stepper-plus {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  flex-shrink: 0;
}
.stepper-minus {
  border: 2rpx solid #FF6B35;
  color: #FF6B35;
}
.stepper-minus.hidden { opacity: 0; pointer-events: none; }
.stepper-plus { background: #FF6B35; color: #fff; }
.stepper-num { font-size: 30rpx; font-weight: bold; min-width: 36rpx; text-align: center; }

.empty-menu { text-align: center; padding: 60rpx 0; font-size: 28rpx; color: #666; }
.empty-menu-text { color: #666; }

.bottom-spacer { height: 200rpx; }

/* ─── 浮动底部栏 ─── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #112228;
  border-top: 1rpx solid #1a2a33;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  gap: 20rpx;
  z-index: 200;
}
.cart-summary {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.cart-badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FF6B35;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cart-count { font-size: 28rpx; font-weight: bold; color: #fff; }
.cart-info { display: flex; flex-direction: column; gap: 4rpx; }
.cart-total { font-size: 32rpx; color: #FF6B35; font-weight: bold; }
.cart-hint { font-size: 22rpx; color: #999; }

.bottom-fee-info { display: flex; flex-direction: column; gap: 4rpx; flex: 1; }
.bottom-fee-label { font-size: 22rpx; color: #999; }
.bottom-fee-price { font-size: 30rpx; color: #FF6B35; font-weight: bold; }

.book-btn {
  background: #FF6B35;
  color: #fff;
  padding: 0 48rpx;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ─── 购物车展开面板 ─── */
.cart-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 120rpx;
  background: rgba(0,0,0,0.5);
  z-index: 190;
}
.cart-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 120rpx;
  background: #112228;
  border-top: 1rpx solid #1a2a33;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 195;
  max-height: 60vh;
  display: flex;
  flex-direction: column;
}
.cart-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #1a2a33;
}
.cart-panel-title { font-size: 30rpx; font-weight: bold; }
.cart-clear-btn { font-size: 26rpx; color: #999; padding: 8rpx 16rpx; }
.cart-panel-list { flex: 1; overflow: hidden; padding: 0 32rpx; }
.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #1a2a33;
  gap: 16rpx;
}
.cart-item:last-child { border-bottom: none; }
.cart-item-name { flex: 1; font-size: 28rpx; color: #fff; }
.cart-item-stepper { display: flex; align-items: center; gap: 12rpx; }
.cart-item-price { font-size: 28rpx; color: #FF6B35; font-weight: bold; width: 120rpx; text-align: right; }
.cart-panel-total {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  border-top: 1rpx solid #1a2a33;
}
.cart-panel-total-label { font-size: 26rpx; color: #999; }
.cart-panel-total-price { font-size: 34rpx; color: #FF6B35; font-weight: bold; }
