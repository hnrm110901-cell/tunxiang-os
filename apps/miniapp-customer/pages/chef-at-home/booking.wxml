<!-- 大厨到家预约确认 + 支付 + 成功页 -->
<view class="container">

  <!-- ─── 支付成功页 ─── -->
  <view class="success-page" wx:if="{{paySuccess}}">
    <view class="success-icon-wrap">
      <text class="success-icon">✓</text>
    </view>
    <text class="success-title">预约成功！</text>
    <text class="success-subtitle">大厨将按时上门，请保持电话畅通</text>

    <view class="success-card">
      <view class="success-row">
        <text class="success-label">订单编号</text>
        <text class="success-value">{{bookingId}}</text>
      </view>
      <view class="success-row">
        <text class="success-label">厨师</text>
        <text class="success-value">{{chefName}} {{chefTitle}}</text>
      </view>
      <view class="success-row">
        <text class="success-label">上门时间</text>
        <text class="success-value">{{serviceDateDisplay}}</text>
      </view>
      <view class="success-row">
        <text class="success-label">上门地址</text>
        <text class="success-value address-val">{{address}}</text>
      </view>
      <view class="success-row">
        <text class="success-label">用餐人数</text>
        <text class="success-value">{{guestCount}}人</text>
      </view>
    </view>

    <view class="success-actions">
      <view class="success-btn outline" bindtap="callChef">
        <text>📞 联系大厨</text>
      </view>
      <view class="success-btn primary" bindtap="goToTracking">
        <text>查看订单进度</text>
      </view>
    </view>
  </view>

  <!-- ─── 预约确认 + 支付主界面 ─── -->
  <block wx:else>

    <!-- 厨师信息 -->
    <view class="chef-summary">
      <view class="chef-summary-left">
        <text class="chef-label">已选大厨</text>
        <view class="chef-row">
          <text class="chef-name">{{chefName}}</text>
          <text class="chef-title">{{chefTitle}}</text>
        </view>
      </view>
      <text class="chef-avatar-placeholder">👨‍🍳</text>
    </view>

    <!-- 订单摘要 -->
    <view class="summary-card">
      <text class="card-title">预约摘要</text>

      <view class="summary-row">
        <text class="summary-label">服务时间</text>
        <text class="summary-value">{{serviceDateDisplay}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">上门地址</text>
        <text class="summary-value address-val">{{address}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">用餐人数</text>
        <text class="summary-value">{{guestCount}}人</text>
      </view>
      <view class="summary-row" wx:if="{{remark}}">
        <text class="summary-label">备注</text>
        <text class="summary-value">{{remark}}</text>
      </view>
    </view>

    <!-- 已选菜品 -->
    <view class="summary-card" wx:if="{{dishes && dishes.length > 0}}">
      <text class="card-title">已选菜品</text>
      <view class="dish-row" wx:for="{{dishes}}" wx:key="dish_id">
        <text class="dish-name">{{item.name}}</text>
        <text class="dish-qty">x{{item.quantity}}</text>
        <text class="dish-price">¥{{item.price_fen * item.quantity / 100}}</text>
      </view>
    </view>

    <!-- 联系人信息 -->
    <view class="summary-card">
      <text class="card-title">联系信息</text>
      <view class="form-item">
        <text class="form-label">联系人</text>
        <input class="form-input" value="{{contactName}}" bindinput="onContactNameInput"
               placeholder="请填写联系人姓名" placeholder-class="placeholder" />
      </view>
      <view class="form-item">
        <text class="form-label">联系电话</text>
        <input class="form-input" type="number" value="{{contactPhone}}" bindinput="onContactPhoneInput"
               placeholder="请填写联系电话" placeholder-class="placeholder" />
      </view>
    </view>

    <!-- 价格明细 -->
    <view class="price-card">
      <text class="card-title">费用明细</text>
      <view class="price-loading" wx:if="{{loadingPrice}}">
        <text>计算中...</text>
      </view>
      <block wx:elif="{{priceDetail}}">
        <view class="price-row">
          <text class="price-label">菜品费</text>
          <text class="price-value">¥{{priceDetail.dish_total_fen / 100}}</text>
        </view>
        <view class="price-row">
          <text class="price-label">厨师服务费（{{guestCount}}人）</text>
          <text class="price-value">¥{{priceDetail.service_fee_fen / 100}}</text>
        </view>
        <view class="price-row" wx:if="{{priceDetail.ingredient_fee_fen > 0}}">
          <text class="price-label">食材费</text>
          <text class="price-value">¥{{priceDetail.ingredient_fee_fen / 100}}</text>
        </view>
        <view class="price-row" wx:if="{{priceDetail.transport_fee_fen > 0}}">
          <text class="price-label">交通费</text>
          <text class="price-value">¥{{priceDetail.transport_fee_fen / 100}}</text>
        </view>
        <view class="price-divider"></view>
        <view class="price-total-row">
          <text class="price-total-label">合计</text>
          <text class="price-total-value">¥{{priceDetail.total_fen / 100}}</text>
        </view>
      </block>
      <block wx:else>
        <view class="price-row">
          <text class="price-label">厨师服务费</text>
          <text class="price-value">¥{{baseFeeYuan}}</text>
        </view>
        <view class="price-total-row">
          <text class="price-total-label">合计（预估）</text>
          <text class="price-total-value">¥{{baseFeeYuan}}</text>
        </view>
      </block>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>

    <!-- 底部支付栏 -->
    <view class="bottom-pay-bar">
      <view class="pay-total-info">
        <text class="pay-label">应付</text>
        <text class="pay-amount">¥{{priceDetail ? priceDetail.total_fen / 100 : baseFeeYuan}}</text>
      </view>
      <view class="pay-btn {{submitting ? 'loading' : ''}}" bindtap="submitAndPay">
        <text>{{submitting ? '处理中...' : '微信支付'}}</text>
      </view>
    </view>
  </block>
</view>
