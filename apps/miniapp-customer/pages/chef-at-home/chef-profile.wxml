<!-- 厨师详情 -->
<view class="container">
  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:elif="{{chef}}">
    <!-- 厨师头像+基本信息 -->
    <view class="profile-header">
      <image class="profile-avatar" src="{{chef.avatar}}" mode="aspectFill" lazy-load />
      <view class="profile-info">
        <view class="profile-name-row">
          <text class="profile-name">{{chef.name}}</text>
          <text class="profile-title">{{chef.title}}</text>
        </view>
        <view class="profile-stats">
          <view class="stat-item">
            <text class="stat-value">{{chef.rating}}</text>
            <text class="stat-label">评分</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{chef.total_services}}</text>
            <text class="stat-label">服务次数</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{chef.years_experience}}年</text>
            <text class="stat-label">从业经验</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Tab 切换 -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'intro' ? 'active' : ''}}" bindtap="switchTab" data-tab="intro">简介</view>
      <view class="tab-item {{activeTab === 'portfolio' ? 'active' : ''}}" bindtap="switchTab" data-tab="portfolio">作品集</view>
      <view class="tab-item {{activeTab === 'ratings' ? 'active' : ''}}" bindtap="switchTab" data-tab="ratings">评价</view>
    </view>

    <!-- 简介 -->
    <view class="tab-content" wx:if="{{activeTab === 'intro'}}">
      <view class="info-block">
        <text class="info-title">擅长菜系</text>
        <view class="tag-list">
          <text class="tag" wx:for="{{chef.cuisine_types}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
      <view class="info-block">
        <text class="info-title">招牌菜品</text>
        <view class="tag-list">
          <text class="tag highlight" wx:for="{{chef.specialties}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
      <view class="info-block">
        <text class="info-title">厨师状态</text>
        <text class="status-badge status-{{chef.status}}">
          {{chef.status === 'available' ? '可预约' : chef.status === 'booked' ? '已预约' : chef.status === 'on_service' ? '服务中' : '休息中'}}
        </text>
      </view>
    </view>

    <!-- 作品集 -->
    <view class="tab-content" wx:if="{{activeTab === 'portfolio'}}">
      <view class="portfolio-grid" wx:if="{{chef.portfolio && chef.portfolio.length > 0}}">
        <view class="portfolio-item" wx:for="{{chef.portfolio}}" wx:key="image"
              bindtap="previewImage" data-url="{{item.image}}">
          <image class="portfolio-image" src="{{item.image}}" mode="aspectFill" lazy-load />
          <text class="portfolio-caption" wx:if="{{item.caption}}">{{item.caption}}</text>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <text>暂无作品</text>
      </view>
    </view>

    <!-- 评价 -->
    <view class="tab-content" wx:if="{{activeTab === 'ratings'}}">
      <view wx:if="{{chef.recent_ratings && chef.recent_ratings.length > 0}}">
        <view class="rating-card" wx:for="{{chef.recent_ratings}}" wx:key="created_at">
          <view class="rating-header">
            <text class="rating-stars">{{item.rating >= 1 ? '★' : '☆'}}{{item.rating >= 2 ? '★' : '☆'}}{{item.rating >= 3 ? '★' : '☆'}}{{item.rating >= 4 ? '★' : '☆'}}{{item.rating >= 5 ? '★' : '☆'}}</text>
            <text class="rating-date">{{item.created_at}}</text>
          </view>
          <text class="rating-comment" wx:if="{{item.comment}}">{{item.comment}}</text>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <text>暂无评价</text>
      </view>
    </view>

    <!-- 底部选择按钮 -->
    <view class="bottom-spacer"></view>
    <view class="bottom-action">
      <button class="select-btn" bindtap="selectThisChef" wx:if="{{chef.status === 'available'}}">
        选择该厨师
      </button>
      <button class="select-btn disabled" disabled wx:else>
        暂不可预约
      </button>
    </view>
  </block>
</view>
