<!-- 外卖结算页 -->
<view class="checkout-page">
  <scroll-view scroll-y class="checkout-scroll">
    <!-- 配送地址 -->
    <view class="section addr-section" bindtap="changeAddress">
      <view class="addr-row">
        <text class="addr-icon">&#128205;</text>
        <view class="addr-info" wx:if="{{address}}">
          <view class="addr-name-row">
            <text class="addr-name">{{address.name}}</text>
            <text class="addr-phone">{{address.phone}}</text>
          </view>
          <text class="addr-detail">{{address.region}} {{address.detail}}</text>
        </view>
        <view class="addr-info" wx:else>
          <text class="addr-placeholder">请选择配送地址</text>
        </view>
        <text class="arrow">&#9654;</text>
      </view>
    </view>

    <!-- 配送时间 -->
    <view class="section time-section">
      <view class="section-row" bindtap="showTimePicker">
        <text class="section-label">配送时间</text>
        <view class="section-value-row">
          <text class="section-value">{{deliveryTimeText}}</text>
          <text class="arrow">&#9654;</text>
        </view>
      </view>
    </view>

    <!-- 菜品列表 -->
    <view class="section items-section">
      <view class="section-title">已选菜品</view>
      <view class="checkout-item" wx:for="{{items}}" wx:key="id">
        <text class="item-name">{{item.name}}</text>
        <view class="item-right">
          <view class="item-counter">
            <view class="counter-btn minus" catchtap="minusItem" data-idx="{{index}}">-</view>
            <text class="counter-num">x{{item.quantity}}</text>
            <view class="counter-btn plus" catchtap="plusItem" data-idx="{{index}}">+</view>
          </view>
          <text class="item-subtotal">¥{{item.subtotalYuan}}</text>
        </view>
      </view>
    </view>

    <!-- 餐具份数 -->
    <view class="section">
      <view class="section-row">
        <text class="section-label">餐具份数</text>
        <view class="item-counter">
          <view class="counter-btn minus" catchtap="minusUten">-</view>
          <text class="counter-num">{{utensilCount}}</text>
          <view class="counter-btn plus" catchtap="plusUten">+</view>
        </view>
      </view>
    </view>

    <!-- 优惠券 -->
    <view class="section" bindtap="chooseCoupon">
      <view class="section-row">
        <text class="section-label">优惠券</text>
        <view class="section-value-row">
          <text class="section-value {{coupon ? 'coupon-active' : ''}}">
            {{coupon ? '-¥' + couponYuan : (couponCount > 0 ? couponCount + '张可用' : '暂无可用')}}
          </text>
          <text class="arrow">&#9654;</text>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="section remark-section">
      <view class="section-row">
        <text class="section-label">订单备注</text>
      </view>
      <input class="remark-input" placeholder="如：少放辣、不要葱等"
             placeholderClass="remark-placeholder"
             value="{{remark}}" bindinput="onRemarkInput" maxlength="100" />
    </view>

    <!-- 费用明细 -->
    <view class="section fee-section">
      <view class="fee-row">
        <text class="fee-label">菜品合计</text>
        <text class="fee-value">¥{{dishTotalYuan}}</text>
      </view>
      <view class="fee-row">
        <text class="fee-label">配送费</text>
        <text class="fee-value">¥{{deliveryFeeYuan}}</text>
      </view>
      <view class="fee-row">
        <text class="fee-label">包装费</text>
        <text class="fee-value">¥{{packFeeYuan}}</text>
      </view>
      <view class="fee-row" wx:if="{{coupon}}">
        <text class="fee-label">优惠券抵扣</text>
        <text class="fee-value coupon-discount">-¥{{couponYuan}}</text>
      </view>
      <view class="fee-divider"></view>
      <view class="fee-row total-row">
        <text class="fee-label">实付金额</text>
        <text class="fee-value total-value">¥{{payTotalYuan}}</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view style="height: 140rpx;"></view>
  </scroll-view>

  <!-- 底部提交栏 -->
  <view class="submit-bar">
    <view class="submit-left">
      <text class="submit-total-label">合计</text>
      <text class="submit-total-price">¥{{payTotalYuan}}</text>
    </view>
    <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="submitOrder">
      <text>{{submitting ? '提交中...' : '提交订单'}}</text>
    </view>
  </view>

  <!-- 配送时间选择弹层 -->
  <view class="time-picker-mask" wx:if="{{showTimeSelect}}" bindtap="hideTimePicker"></view>
  <view class="time-picker-popup" wx:if="{{showTimeSelect}}">
    <view class="time-picker-title">选择配送时间</view>
    <view class="time-option {{deliveryType === 'now' ? 'active' : ''}}"
          bindtap="selectDeliveryType" data-type="now">
      <text>立即配送</text>
      <text class="time-option-desc">预计{{estimatedTime}}送达</text>
    </view>
    <view class="time-option {{deliveryType === 'schedule' ? 'active' : ''}}"
          bindtap="selectDeliveryType" data-type="schedule">
      <text>预约配送</text>
    </view>
    <picker wx:if="{{deliveryType === 'schedule'}}" mode="time" value="{{scheduleTime}}"
            start="{{scheduleStart}}" end="22:00" bindchange="onScheduleTimeChange">
      <view class="schedule-pick-row">
        <text>选择时间: {{scheduleTime || '请选择'}}</text>
      </view>
    </picker>
    <view class="time-picker-confirm" bindtap="confirmTimePicker">确定</view>
  </view>
</view>
