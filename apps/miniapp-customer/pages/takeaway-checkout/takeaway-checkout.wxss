.checkout-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0B1A20;
  color: #fff;
}

.checkout-scroll {
  flex: 1;
  padding: 20rpx 24rpx;
}

/* ─── 通用区块 ─── */
.section {
  background: #112228;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-label {
  font-size: 28rpx;
  color: #ccc;
}

.section-value-row {
  display: flex;
  align-items: center;
}

.section-value {
  font-size: 28rpx;
  color: #999;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.arrow {
  font-size: 18rpx;
  color: #666;
  margin-left: 8rpx;
}

/* ─── 地址 ─── */
.addr-section {
  padding: 28rpx 24rpx;
}

.addr-row {
  display: flex;
  align-items: center;
}

.addr-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.addr-info {
  flex: 1;
  overflow: hidden;
}

.addr-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.addr-name {
  font-size: 30rpx;
  font-weight: 600;
}

.addr-phone {
  font-size: 26rpx;
  color: #999;
}

.addr-detail {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.addr-placeholder {
  font-size: 28rpx;
  color: #666;
}

/* ─── 菜品列表 ─── */
.checkout-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}

.checkout-item:last-child {
  border-bottom: none;
}

.item-name {
  font-size: 26rpx;
  flex: 1;
  margin-right: 16rpx;
}

.item-right {
  display: flex;
  align-items: center;
}

.item-counter {
  display: flex;
  align-items: center;
}

.counter-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.counter-btn.plus {
  background: #FF6B2C;
  color: #fff;
}

.counter-btn.minus {
  background: rgba(255,107,44,0.15);
  color: #FF6B2C;
}

.counter-num {
  font-size: 24rpx;
  min-width: 40rpx;
  text-align: center;
}

.item-subtotal {
  font-size: 26rpx;
  color: #FF6B2C;
  min-width: 100rpx;
  text-align: right;
}

/* ─── 备注 ─── */
.remark-input {
  margin-top: 16rpx;
  background: #1a2a33;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #fff;
}

.remark-placeholder {
  color: #666;
}

/* ─── 费用明细 ─── */
.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.fee-label {
  font-size: 26rpx;
  color: #999;
}

.fee-value {
  font-size: 26rpx;
  color: #ccc;
}

.fee-divider {
  height: 1rpx;
  background: rgba(255,255,255,0.06);
  margin: 12rpx 0;
}

.total-row .fee-label {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.total-value {
  font-size: 34rpx;
  color: #FF6B2C;
  font-weight: 700;
}

.coupon-discount {
  color: #4CAF50;
}

.coupon-active {
  color: #FF6B2C;
}

/* ─── 底部提交栏 ─── */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 112rpx;
  background: #1a2a33;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.3);
  z-index: 100;
}

.submit-left {
  display: flex;
  align-items: baseline;
}

.submit-total-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 8rpx;
}

.submit-total-price {
  font-size: 36rpx;
  color: #FF6B2C;
  font-weight: 700;
}

.submit-btn {
  background: #FF6B2C;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 18rpx 48rpx;
  border-radius: 44rpx;
}

.submit-btn.disabled {
  background: #555;
  color: #999;
}

/* ─── 时间选择弹层 ─── */
.time-picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
}

.time-picker-popup {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #112228;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  z-index: 201;
}

.time-picker-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  text-align: center;
}

.time-option {
  padding: 24rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  background: #1a2a33;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
}

.time-option.active {
  border: 2rpx solid #FF6B2C;
  color: #FF6B2C;
}

.time-option-desc {
  font-size: 24rpx;
  color: #999;
}

.schedule-pick-row {
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #FF6B2C;
}

.time-picker-confirm {
  background: #FF6B2C;
  color: #fff;
  text-align: center;
  padding: 20rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 20rpx;
}
