.page-container { min-height: 100vh; background: #0B1A20; color: #fff; padding-bottom: 140rpx; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 200rpx 0 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: #999; margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: #666; }

/* 加载 */
.loading-tip { text-align: center; color: #999; font-size: 28rpx; padding: 60rpx 0; }

/* 地址列表 */
.address-list { padding: 24rpx; }

.address-card {
  background: #112228;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  border-left: 6rpx solid transparent;
}

.address-card.is-default {
  border-left-color: #FF6B35;
}

.address-main { padding: 28rpx; }

.address-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.address-name { font-size: 30rpx; color: #fff; font-weight: bold; }
.address-phone { font-size: 26rpx; color: #999; }

.address-tag {
  background: #1a2a33;
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
}
.tag-text { font-size: 22rpx; color: #FF6B2C; }

.default-badge {
  background: rgba(255, 107, 53, 0.15);
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
}
.default-text { font-size: 22rpx; color: #FF6B35; }

.address-detail {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
  display: block;
}

/* 操作按钮 */
.address-actions {
  display: flex;
  border-top: 1rpx solid #1a2a33;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
}

.action-btn + .action-btn {
  border-left: 1rpx solid #1a2a33;
}

.action-text { font-size: 24rpx; color: #999; }
.action-edit .action-text { color: #FF6B2C; }
.action-delete .action-text { color: #e53e3e; }
.action-default .action-text { color: #48bb78; }

/* 底部新增按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #0B1A20;
}

.add-btn {
  background: #FF6B2C !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
}
