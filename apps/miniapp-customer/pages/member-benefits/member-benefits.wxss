.page { background: #f8f8f8; min-height: 100vh; padding-bottom: 60rpx; }

/* ===== 会员卡 ===== */
.member-card {
  padding: 40rpx 32rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.tier-normal { background: linear-gradient(135deg, #8C8C8C, #BFBFBF); }
.tier-silver { background: linear-gradient(135deg, #8C8C8C, #C0C0C0, #A8A8A8); }
.tier-gold   { background: linear-gradient(135deg, #C5973A, #D4A853, #B8860B); }
.tier-black  { background: linear-gradient(135deg, #1A1A1A, #333, #111); }

.card-bg-decoration {
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.card-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background: #eee;
  flex-shrink: 0;
}

.member-info { flex: 1; }

.member-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.tier-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tier-icon { font-size: 28rpx; }
.tier-name { font-size: 24rpx; color: rgba(255, 255, 255, 0.85); }

.points-box { text-align: right; }

.points-num {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  line-height: 1.1;
}

.points-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 升级进度 */
.upgrade-progress { margin-top: 24rpx; }

.progress-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 8rpx;
}

.progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 4rpx;
  transition: width 600ms ease;
}

.top-tier-badge {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
}

/* ===== 通用区块 ===== */
.section {
  background: #fff;
  margin-top: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
}

/* ===== 本月权益网格 ===== */
.benefits-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.benefit-item {
  width: calc(50% - 8rpx);
  background: #fafafa;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  box-sizing: border-box;
}

.benefit-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 8rpx;
}

.benefit-name {
  font-size: 24rpx;
  color: #333;
  display: block;
}

.benefit-value {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: bold;
  display: block;
  margin: 4rpx 0;
}

.benefit-status {
  font-size: 20rpx;
  color: #67c23a;
}

.benefit-status.used {
  color: #bbb;
  text-decoration: line-through;
}

/* ===== 等级对比表 ===== */
.tier-compare-scroll {
  white-space: nowrap;
  width: 100%;
}

.tier-compare-table {
  display: flex;
  min-width: max-content;
}

.compare-col {
  display: flex;
  flex-direction: column;
  width: 160rpx;
  flex-shrink: 0;
}

.compare-col.header {
  width: 140rpx;
  flex-shrink: 0;
}

.compare-col.current {
  background: #fff3ef;
  border-radius: 8rpx;
}

.col-header {
  padding: 16rpx 8rpx;
  font-size: 24rpx;
  color: #999;
  font-weight: bold;
  display: block;
}

.col-header-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  min-height: 80rpx;
  justify-content: center;
}

.col-icon { font-size: 32rpx; }
.col-name { font-size: 22rpx; color: #333; margin-top: 4rpx; }

.compare-row-label {
  padding: 16rpx 8rpx;
  font-size: 24rpx;
  color: #666;
  border-top: 1rpx solid #f0f0f0;
  display: block;
}

.compare-cell {
  padding: 16rpx 8rpx;
  font-size: 24rpx;
  color: #333;
  text-align: center;
  border-top: 1rpx solid #f0f0f0;
  display: block;
}

.compare-cell.highlight {
  color: #FF6B35;
  font-weight: bold;
}

/* ===== 获取积分列表 ===== */
.earn-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.earn-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.earn-icon { font-size: 40rpx; flex-shrink: 0; }

.earn-info { flex: 1; }

.earn-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  display: block;
}

.earn-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.earn-points {
  color: #FF6B35;
  font-size: 26rpx;
  font-weight: bold;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.earn-arrow {
  font-size: 32rpx;
  color: #ccc;
  flex-shrink: 0;
}
