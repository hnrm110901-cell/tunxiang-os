<!-- 新增/编辑收货地址 -->
<view class="page-container">
  <view class="form-wrap">

    <!-- 姓名 -->
    <view class="form-section">
      <text class="form-label">收货人</text>
      <input class="form-input" placeholder="请输入收货人姓名"
             value="{{name}}" bindinput="onNameInput" maxlength="20" />
    </view>

    <!-- 手机号 -->
    <view class="form-section">
      <text class="form-label">手机号</text>
      <input class="form-input" placeholder="请输入手机号" type="number"
             value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>

    <!-- 地区选择 -->
    <view class="form-section">
      <text class="form-label">所在地区</text>
      <picker mode="region" bindchange="onRegionChange" value="{{regionArr}}">
        <view class="form-input form-picker">
          <text class="{{region ? '' : 'placeholder-text'}}">{{region || '请选择省/市/区'}}</text>
          <text class="picker-arrow">></text>
        </view>
      </picker>
    </view>

    <!-- 详细地址 -->
    <view class="form-section">
      <text class="form-label">详细地址</text>
      <textarea class="form-textarea" placeholder="楼栋号/门牌号等详细信息"
                value="{{detail}}" bindinput="onDetailInput" maxlength="200" />
    </view>

    <!-- 地图选点（可选） -->
    <view class="map-section" bindtap="chooseLocation">
      <text class="map-icon">📍</text>
      <text class="map-text">{{location ? '已选择位置' : '地图选点（可选）'}}</text>
      <text class="map-arrow">></text>
    </view>

    <!-- 标签选择 -->
    <view class="form-section">
      <text class="form-label">地址标签</text>
      <view class="tag-list">
        <view class="tag-item {{tag === t ? 'active' : ''}}"
              wx:for="{{tagOptions}}" wx:for-item="t" wx:key="*this"
              bindtap="selectTag" data-tag="{{t}}">
          <text class="tag-item-text">{{t}}</text>
        </view>
      </view>
    </view>

    <!-- 设为默认 -->
    <view class="default-section" bindtap="toggleDefault">
      <text class="default-label">设为默认地址</text>
      <view class="default-switch {{isDefault ? 'on' : ''}}">
        <view class="switch-dot"></view>
      </view>
    </view>

  </view>

  <!-- 保存按钮 -->
  <view class="bottom-bar">
    <button class="save-btn" bindtap="saveAddress" disabled="{{saving}}">
      {{saving ? '保存中...' : '保存地址'}}
    </button>
  </view>
</view>
