.page-container {
  min-height: 100vh; background: #0B1A20;
  padding: 32rpx;
}

/* ─── 奖品信息卡 ─── */
.exchange-body {
  display: flex; flex-direction: column; align-items: center;
}
.prize-info-card {
  width: 100%;
  background: linear-gradient(135deg, #112228 0%, #1a2e38 100%);
  border-radius: 28rpx; padding: 48rpx 32rpx;
  display: flex; flex-direction: column; align-items: center;
  border: 1rpx solid rgba(255,255,255,0.06);
  margin-bottom: 48rpx;
}
.prize-icon-large {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: rgba(255,107,53,0.1);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx;
}
.prize-emoji { font-size: 72rpx; }

.prize-name-lg {
  display: block; font-size: 36rpx; font-weight: 800; color: #fff;
  margin-bottom: 12rpx; text-align: center;
}
.prize-desc-lg {
  display: block; font-size: 26rpx; color: #999; text-align: center;
  margin-bottom: 32rpx; line-height: 1.5;
}

.prize-cost {
  display: flex; align-items: baseline; gap: 8rpx;
  margin-bottom: 12rpx;
}
.cost-label { font-size: 26rpx; color: #999; }
.cost-num { font-size: 48rpx; font-weight: 900; color: #FF6B35; }
.cost-unit { font-size: 26rpx; color: #999; }

.prize-current { margin-top: 8rpx; }
.prize-current text { font-size: 24rpx; color: #666; }
.current-num { color: #FF6B35; font-weight: 700; }

/* ─── 操作区 ─── */
.action-area {
  width: 100%; display: flex; flex-direction: column; align-items: center;
  gap: 20rpx;
}
.exchange-main-btn {
  width: 100%; height: 96rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF9A5C 100%);
  border-radius: 48rpx; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255,107,53,0.3);
}
.exchange-main-btn text {
  color: #fff; font-size: 32rpx; font-weight: 700;
}
.cancel-link { padding: 16rpx 32rpx; }
.cancel-link text { font-size: 26rpx; color: #666; }

/* ─── 兑换成功 ─── */
.success-body {
  display: flex; flex-direction: column; align-items: center;
  padding-top: 60rpx;
}
.success-icon-wrap { margin-bottom: 24rpx; }
.success-circle {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(82,196,26,0.3);
}
.success-check { font-size: 56rpx; color: #fff; font-weight: 900; }

.success-title {
  display: block; font-size: 36rpx; font-weight: 800; color: #52c41a;
  margin-bottom: 8rpx;
}
.success-prize {
  display: block; font-size: 28rpx; color: #ccc; margin-bottom: 40rpx;
}

/* ─── 核销码 ─── */
.code-card {
  width: 100%;
  background: #112228; border-radius: 24rpx; padding: 40rpx 32rpx;
  display: flex; flex-direction: column; align-items: center;
  border: 1rpx solid rgba(255,255,255,0.06);
  margin-bottom: 32rpx;
}
.code-label {
  font-size: 24rpx; color: #999; margin-bottom: 16rpx;
}
.code-value {
  font-size: 56rpx; font-weight: 900; color: #FF6B35;
  letter-spacing: 8rpx; margin-bottom: 12rpx;
}
.code-expire {
  margin-bottom: 24rpx;
}
.code-expire text { font-size: 22rpx; color: #666; }
.copy-btn {
  background: rgba(255,107,53,0.1); border: 1rpx solid rgba(255,107,53,0.3);
  border-radius: 32rpx; padding: 14rpx 48rpx;
}
.copy-btn text { font-size: 26rpx; color: #FF6B35; font-weight: 600; }

/* ─── 使用说明 ─── */
.instructions {
  width: 100%;
  background: #112228; border-radius: 20rpx; padding: 28rpx;
  border: 1rpx solid rgba(255,255,255,0.04);
  margin-bottom: 40rpx;
}
.inst-title {
  display: block; font-size: 26rpx; font-weight: 600; color: #ccc;
  margin-bottom: 16rpx;
}
.inst-item {
  display: flex; gap: 8rpx; padding: 6rpx 0;
}
.inst-dot { color: #666; font-size: 24rpx; }
.inst-text { font-size: 24rpx; color: #888; line-height: 1.5; }

.back-btn {
  padding: 20rpx 64rpx; background: rgba(255,255,255,0.06);
  border-radius: 40rpx;
}
.back-btn text { font-size: 28rpx; color: #ccc; }

/* ─── 确认弹窗 ─── */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; pointer-events: none;
  transition: opacity 0.25s;
  z-index: 999;
}
.modal-mask.show {
  opacity: 1; pointer-events: auto;
}
.modal-content {
  width: 580rpx; background: #1a2e38; border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx;
  display: flex; flex-direction: column; align-items: center;
}
.modal-title {
  font-size: 34rpx; font-weight: 700; color: #fff; margin-bottom: 16rpx;
}
.modal-desc {
  font-size: 28rpx; color: #FF6B35; font-weight: 600; margin-bottom: 8rpx;
}
.modal-sub {
  font-size: 24rpx; color: #999; margin-bottom: 36rpx;
}
.modal-actions {
  display: flex; width: 100%; gap: 20rpx;
}
.modal-cancel {
  flex: 1; height: 80rpx; display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.06); border-radius: 40rpx;
}
.modal-cancel text { font-size: 28rpx; color: #999; }
.modal-confirm {
  flex: 1; height: 80rpx; display: flex; align-items: center; justify-content: center;
  background: #FF6B35; border-radius: 40rpx;
}
.modal-confirm text { font-size: 28rpx; color: #fff; font-weight: 600; }
.modal-confirm.disabled {
  opacity: 0.5;
}
