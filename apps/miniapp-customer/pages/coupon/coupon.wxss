/* 优惠券中心样式 */

.page-container {
  min-height: 100vh;
  background: #0B1A20;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ──── Tab切换 ──── */
.tab-bar {
  display: flex;
  padding: 24rpx 32rpx 16rpx;
  gap: 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #777;
  position: relative;
}

.tab-item.active {
  color: #FF6B35;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 25%;
  right: 25%;
  height: 4rpx;
  background: #FF6B35;
  border-radius: 2rpx;
}

/* ──── 通用优惠券卡片 ──── */
.coupon-list {
  padding: 24rpx 32rpx;
}

.coupon-card {
  display: flex;
  align-items: stretch;
  background: #112228;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  min-height: 160rpx;
}

.coupon-card.disabled {
  opacity: 0.5;
}

/* 左侧背景色 */
.coupon-left, .claimable-left {
  width: 200rpx;
  min-height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 12rpx;
  flex-shrink: 0;
  position: relative;
}

.coupon-bg-orange { background: rgba(255, 107, 53, 0.18); }
.coupon-bg-green  { background: rgba(15, 110, 86, 0.22); }
.coupon-bg-blue   { background: rgba(27, 109, 171, 0.22); }
.coupon-bg-gray   { background: rgba(100, 100, 100, 0.1); }

/* 金额展示 */
.coupon-amount {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.amount-sym {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 600;
}

.amount-sym.small {
  font-size: 22rpx;
}

.amount-sym.gift {
  font-size: 40rpx;
  color: #0F6E56;
}

.coupon-bg-green .amount-sym,
.coupon-bg-green .amount-val {
  color: #0F6E56;
}

.coupon-bg-blue .amount-sym,
.coupon-bg-blue .amount-val {
  color: #1B6DAB;
}

.coupon-bg-gray .amount-sym,
.coupon-bg-gray .amount-val {
  color: #999;
}

.amount-val {
  font-size: 56rpx;
  font-weight: bold;
  color: #FF6B35;
}

.coupon-threshold {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: center;
}

/* 即将过期徽章 */
.expire-soon-badge {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  background: #A32D2D;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

/* 虚线分隔 */
.coupon-divider {
  width: 1rpx;
  background: repeating-linear-gradient(
    to bottom,
    transparent 0,
    transparent 8rpx,
    rgba(255,255,255,0.12) 8rpx,
    rgba(255,255,255,0.12) 16rpx
  );
  flex-shrink: 0;
}

/* 右侧信息 */
.coupon-right {
  flex: 1;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  overflow: hidden;
}

.coupon-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-condition {
  font-size: 24rpx;
  color: #FF6B35;
  display: block;
}

.coupon-expire {
  font-size: 22rpx;
  color: #666;
  display: block;
}

.coupon-expire.red {
  color: #A32D2D;
}

/* 操作区 */
.coupon-action {
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.use-btn {
  font-size: 24rpx !important;
  background: #FF6B35 !important;
  color: #fff !important;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  min-width: 0;
  white-space: nowrap;
}

.status-label {
  font-size: 24rpx;
  color: #555;
  white-space: nowrap;
}

/* ──── 可领取列表 ──── */
.claimable-list {
  padding: 24rpx 32rpx;
}

.claimable-card {
  display: flex;
  align-items: stretch;
  background: #112228;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  min-height: 160rpx;
}

.claimable-right {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  gap: 16rpx;
}

.claimable-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.claimable-condition {
  font-size: 24rpx;
  color: #777;
  display: block;
}

.claimable-valid {
  font-size: 22rpx;
  color: #555;
  display: block;
}

.claim-btn {
  font-size: 24rpx !important;
  background: #FF6B35 !important;
  color: #fff !important;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  min-width: 0;
  white-space: nowrap;
  flex-shrink: 0;
}

.claim-btn.claimed {
  background: #1a2a33 !important;
  color: #555 !important;
}

/* ──── 通用状态 ──── */
.loading-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #666;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

.safe-bottom {
  height: 40rpx;
}
