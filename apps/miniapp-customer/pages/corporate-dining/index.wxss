.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 40rpx; }

/* ─── Enterprise header ─── */
.enterprise-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 32rpx; background: linear-gradient(135deg, #1A3040, #112228);
}
.enterprise-selector { display: flex; align-items: center; gap: 12rpx; }
.enterprise-name { font-size: 36rpx; color: #fff; font-weight: bold; }
.switch-icon { font-size: 20rpx; color: #FF6B2C; }
.enterprise-role {
  font-size: 22rpx; color: #FF6B2C; background: rgba(255,107,44,0.15);
  padding: 6rpx 16rpx; border-radius: 16rpx;
}

/* ─── No enterprise ─── */
.no-enterprise { text-align: center; padding: 120rpx 60rpx; }
.no-enterprise-text { font-size: 32rpx; color: #fff; display: block; margin-bottom: 16rpx; }
.no-enterprise-tip { font-size: 26rpx; color: #666; display: block; }

/* ─── Account card ─── */
.account-card {
  margin: 24rpx 32rpx; background: linear-gradient(135deg, #FF6B2C, #FF8F5E);
  border-radius: 24rpx; padding: 32rpx;
}
.account-title { font-size: 26rpx; color: rgba(255,255,255,0.8); margin-bottom: 24rpx; }
.account-grid { display: flex; justify-content: space-around; }
.account-item { text-align: center; }
.account-value { font-size: 40rpx; color: #fff; font-weight: bold; display: block; }
.account-label { font-size: 22rpx; color: rgba(255,255,255,0.7); display: block; margin-top: 4rpx; }
.account-cycle { margin-top: 24rpx; padding-top: 20rpx; border-top: 1rpx solid rgba(255,255,255,0.2); }
.cycle-label { font-size: 24rpx; color: rgba(255,255,255,0.8); }

/* ─── Quick grid ─── */
.quick-grid {
  display: flex; flex-wrap: wrap; padding: 0 24rpx; margin: 24rpx 0; gap: 16rpx;
}
.quick-item {
  width: calc(50% - 8rpx); background: #112228; border-radius: 16rpx;
  padding: 32rpx 24rpx; display: flex; flex-direction: column; align-items: center;
}
.quick-icon { width: 72rpx; height: 72rpx; margin-bottom: 12rpx; }
.quick-label { font-size: 28rpx; color: #fff; font-weight: 500; }
.quick-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* ─── Section ─── */
.section { padding: 32rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; color: #fff; font-weight: 500; display: block; margin-bottom: 20rpx; }
.section-more { font-size: 24rpx; color: #FF6B2C; }

/* ─── Package list ─── */
.package-card {
  display: flex; gap: 20rpx; background: #112228; border-radius: 16rpx;
  padding: 24rpx; margin-bottom: 16rpx;
}
.package-image { width: 180rpx; height: 140rpx; border-radius: 12rpx; flex-shrink: 0; }
.package-info { flex: 1; }
.package-name { font-size: 28rpx; color: #fff; font-weight: 500; display: block; }
.package-desc { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.package-bottom { display: flex; justify-content: space-between; margin-top: 16rpx; }
.package-price { font-size: 28rpx; color: #FF6B2C; font-weight: bold; }
.package-person { font-size: 22rpx; color: #999; }

/* ─── Recent orders ─── */
.recent-order { background: #112228; border-radius: 12rpx; padding: 24rpx; margin-bottom: 12rpx; }
.order-top { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.order-no { font-size: 26rpx; color: #fff; }
.order-status { font-size: 24rpx; color: #FF6B2C; }
.order-detail { font-size: 24rpx; color: #999; display: block; }
.order-bottom { display: flex; justify-content: space-between; margin-top: 12rpx; }
.order-amount { font-size: 28rpx; color: #fff; font-weight: 500; }
.order-time { font-size: 22rpx; color: #666; }

.empty-tip { text-align: center; padding: 60rpx 0; color: #666; font-size: 26rpx; }

/* ─── Enterprise switcher ─── */
.switcher-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); z-index: 100;
}
.switcher-popup {
  position: fixed; bottom: 0; left: 0; right: 0; background: #112228;
  border-radius: 24rpx 24rpx 0 0; padding: 32rpx; z-index: 101;
  transform: translateY(100%); transition: transform 0.3s;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
.switcher-popup.show { transform: translateY(0); }
.popup-title { font-size: 32rpx; color: #fff; font-weight: 500; margin-bottom: 24rpx; display: block; }
.switcher-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx; background: #1A3040; border-radius: 12rpx; margin-bottom: 12rpx;
}
.switcher-item.active { border: 2rpx solid #FF6B2C; }
.switcher-name { font-size: 28rpx; color: #fff; }
.switcher-role { font-size: 22rpx; color: #999; }
