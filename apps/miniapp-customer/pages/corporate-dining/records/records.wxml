<!-- 企业挂账记录页 -->
<view class="page-container">

  <!-- 月份切换器 -->
  <view class="month-bar">
    <view class="month-arrow" bindtap="prevMonth">
      <text class="arrow-text">&#8249;</text>
    </view>
    <picker mode="date" fields="month" value="{{currentMonth}}" bindchange="onMonthChange">
      <view class="month-picker">
        <text class="month-label">{{currentMonthDisplay}}</text>
        <text class="month-icon">&#x25BC;</text>
      </view>
    </picker>
    <view class="month-arrow {{isCurrentMonth ? 'disabled' : ''}}" bindtap="nextMonth">
      <text class="arrow-text">&#8250;</text>
    </view>
  </view>

  <!-- 月度汇总卡片 -->
  <view class="summary-card">
    <view class="summary-row">
      <view class="summary-item">
        <text class="s-value total">¥{{summary.totalYuan}}</text>
        <text class="s-label">月度总计</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="s-value settled">¥{{summary.settledYuan}}</text>
        <text class="s-label">已结算</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="s-value pending">¥{{summary.pendingYuan}}</text>
        <text class="s-label">待结算</text>
      </view>
    </view>
    <view class="summary-count">
      <text class="s-count-text">共 {{summary.count}} 笔，{{summary.settledCount}} 笔已结算</text>
    </view>
  </view>

  <!-- 导出按钮 -->
  <view class="export-row">
    <view class="export-btn" bindtap="exportRecords">
      <text class="export-icon">📋</text>
      <text class="export-text">导出本月账单</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="skeleton-item" wx:for="{{[1,2,3,4,5]}}" wx:key="*this"></view>
  </view>

  <!-- 记录列表 -->
  <view class="records-list" wx:if="{{!loading}}">

    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{records.length === 0}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">{{currentMonthDisplay}} 暂无挂账记录</text>
    </view>

    <!-- 记录卡片 -->
    <view class="record-card" wx:for="{{records}}" wx:key="id">
      <view class="record-top">
        <view class="record-title-wrap">
          <text class="record-title">{{item.summary || '企业用餐'}}</text>
          <view class="status-badge {{item.status === 'settled' ? 'settled' : 'pending'}}">
            <text class="status-text">{{item.status === 'settled' ? '已结算' : '待结算'}}</text>
          </view>
        </view>
        <text class="record-amount">¥{{item.amountYuan}}</text>
      </view>

      <!-- 菜品明细（折叠展示前3条） -->
      <view class="dish-detail" wx:if="{{item.items && item.items.length > 0}}">
        <text class="dish-item-text" wx:for="{{item.items}}" wx:for-item="dish" wx:key="dish_id" wx:if="{{index < 3}}">
          {{dish.dish_name}} ×{{dish.qty}}{{index < (item.items.length > 3 ? 2 : item.items.length - 1) ? '、' : ''}}
        </text>
        <text class="dish-more" wx:if="{{item.items.length > 3}}">等{{item.items.length}}项</text>
      </view>

      <view class="record-bottom">
        <text class="record-date">{{item.dateDisplay}}</text>
        <text class="record-no">单号 {{item.order_no || '-'}}</text>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
      <text class="load-more-text">加载更多</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && records.length > 0}}">
      <text class="no-more-text">— 已显示全部记录 —</text>
    </view>

  </view>

</view>
