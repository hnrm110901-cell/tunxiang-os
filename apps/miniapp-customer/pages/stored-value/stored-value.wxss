.page-container { min-height: 100vh; background: #0B1A20; color: #fff; padding-bottom: 160rpx; }

/* --- 余额卡片 --- */
.balance-card {
  margin: 32rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8C42);
  border-radius: 24rpx;
  padding: 40rpx 36rpx 32rpx;
  position: relative;
}

.balance-card-inner { }

.balance-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 12rpx;
}

.balance-amount {
  font-size: 60rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.balance-level {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  display: inline-block;
  background: rgba(255,255,255,0.2);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.balance-detail-link {
  position: absolute;
  right: 36rpx;
  top: 40rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.arrow-right {
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* --- 充值面额 --- */
.section {
  margin: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 24rpx;
}

.plan-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.plan-item {
  width: calc(33.33% - 14rpx);
  background: #112A33;
  border: 2rpx solid #1a3a45;
  border-radius: 16rpx;
  padding: 28rpx 12rpx;
  text-align: center;
  box-sizing: border-box;
}

.plan-active {
  border-color: #FF6B35;
  background: rgba(255, 107, 53, 0.1);
}

.plan-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.plan-bonus {
  font-size: 22rpx;
  color: #FF6B35;
}

.plan-bonus-none {
  color: #999;
}

/* --- 自定义金额 --- */
.custom-input-wrap {
  margin: 0 32rpx 32rpx;
}

.custom-input-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.custom-input {
  background: #112A33;
  border: 2rpx solid #1a3a45;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #fff;
  font-size: 32rpx;
}

/* --- 充值说明 --- */
.rules-section {
  margin-top: 16rpx;
}

.rules-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rules-arrow {
  font-size: 28rpx;
  color: #666;
  transition: transform 0.2s;
  display: inline-block;
}

.rules-arrow-open {
  transform: rotate(90deg);
}

.rules-body {
  margin-top: 20rpx;
}

.rule-item {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}

/* --- 底部 --- */
.bottom-placeholder { height: 160rpx; }

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #0B1A20;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #1a2a33;
}

.recharge-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #FF6B35 !important;
  color: #fff !important;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  text-align: center;
  border: none;
}

.recharge-btn[disabled] {
  background: #4a4a4a !important;
  color: #999 !important;
}
