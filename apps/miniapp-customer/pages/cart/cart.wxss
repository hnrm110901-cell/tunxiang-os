/* 购物车结算页 */
.cart-page {
  min-height: 100vh;
  background: #0B1A20;
  color: #fff;
}

/* ─── 顶部标题 ─── */
.cart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: #112228;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  min-width: 120rpx;
}

.back-icon {
  font-size: 48rpx;
  color: #FF6B35;
  line-height: 1;
  margin-top: -4rpx;
}

.back-text {
  font-size: 28rpx;
  color: #FF6B35;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.header-placeholder {
  min-width: 120rpx;
}

/* ─── 凑单提示 ─── */
.addon-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(255, 107, 53, 0.1);
  border-bottom: 1rpx solid rgba(255, 107, 53, 0.2);
}

.addon-text { font-size: 26rpx; color: #FF6B35; }
.addon-action { font-size: 26rpx; color: #FF6B35; font-weight: 600; }

/* ─── 空状态 ─── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; margin-bottom: 32rpx; }

.empty-btn {
  padding: 20rpx 64rpx;
  background: #FF6B35;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* ─── 购物车列表 ─── */
.cart-list {
  flex: 1;
  padding: 0 32rpx;
}

.cart-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

/* 主行：图片 + 信息 + 数量 */
.item-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.item-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.item-spec {
  font-size: 24rpx;
  color: #999;
}

.item-price {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 600;
}

/* 数量增减 */
.item-qty-ctrl {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn.minus {
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.2);
}

.qty-btn.plus {
  background: #FF6B35;
}

.qty-btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

.qty-num {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
  min-width: 36rpx;
  text-align: center;
}

/* 单品备注行 */
.item-remark-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 12rpx;
}

.remark-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.item-remark-input {
  flex: 1;
  font-size: 26rpx;
  color: #ccc;
  height: 36rpx;
  line-height: 36rpx;
}

.remark-placeholder {
  color: rgba(255,255,255,0.3);
  font-size: 26rpx;
}

/* ─── AA分摊 ─── */
.aa-section {
  margin: 20rpx 32rpx;
  padding: 24rpx;
  background: #112228;
  border-radius: 20rpx;
}

.aa-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.aa-title { font-size: 28rpx; color: #fff; font-weight: 600; }
.aa-toggle { font-size: 24rpx; color: #FF6B35; }

.aa-body {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.08);
}

.aa-party {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.aa-label { font-size: 28rpx; color: #ccc; }

.aa-qty-ctrl {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.aa-result { font-size: 32rpx; color: #FF6B35; font-weight: bold; }

/* ─── 优惠券 ─── */
.coupon-section {
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
  display: block;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.coupon-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #112228;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.coupon-item.selected {
  border-color: #FF6B35;
  background: rgba(255, 107, 53, 0.08);
}

.coupon-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.coupon-name { font-size: 28rpx; color: #fff; }
.coupon-cond { font-size: 22rpx; color: #999; }
.coupon-value { font-size: 30rpx; color: #FF6B35; font-weight: bold; flex-shrink: 0; }

.coupon-check {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
  flex-shrink: 0;
}

.coupon-clear {
  text-align: right;
  padding: 12rpx 0;
}

.coupon-clear-text { font-size: 24rpx; color: #999; }

/* ─── 整单备注 ─── */
.notes-section {
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}

.notes-input {
  background: #112228;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #fff;
  width: 100%;
  box-sizing: border-box;
}

.notes-placeholder { color: rgba(255,255,255,0.3); }

/* 底部占位 */
.bottom-placeholder { height: 200rpx; }

/* ─── 吸底结算栏 ─── */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #1E2A3A;
  border-top: 1rpx solid rgba(255,255,255,0.08);
  box-shadow: 0 -4px 16px rgba(0,0,0,0.3);
}

.checkout-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.checkout-count {
  font-size: 24rpx;
  color: #999;
}

.checkout-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.checkout-label { font-size: 24rpx; color: #ccc; }

.checkout-total {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6B35;
}

.checkout-discount {
  font-size: 22rpx;
  color: #0F6E56;
}

.checkout-btn {
  background: #FF6B35;
  border-radius: 44rpx;
  padding: 0 48rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkout-btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* ─── 结算弹层遮罩 ─── */
.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 99;
}

/* ─── 结算底部弹层 ─── */
.checkout-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #1E2A3A;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 32rpx;
  z-index: 100;
  transform: translateY(100%);
  transition: transform 300ms ease-out;
}

.checkout-sheet.visible {
  transform: translateY(0);
}

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}

.sheet-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  padding: 24rpx 0 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

/* 订单小计 */
.sheet-summary {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.summary-label {
  font-size: 28rpx;
  color: #ccc;
}

.summary-value {
  font-size: 28rpx;
  color: #fff;
}

.summary-value.discount {
  color: #0F6E56;
}

.summary-divider {
  height: 1rpx;
  background: rgba(255,255,255,0.08);
  margin: 12rpx 0;
}

.total-row {
  margin-top: 4rpx;
}

.total-label {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.total-value {
  font-size: 36rpx;
  color: #FF6B35;
  font-weight: bold;
}

/* 弹层区块 */
.sheet-section {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.sheet-section-title {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.sheet-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sheet-row-label { font-size: 28rpx; color: #ccc; }
.sheet-row-value { font-size: 28rpx; color: #fff; }
.sheet-row-value.balance { color: #0F6E56; font-weight: 600; }

/* 支付选项 */
.payment-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.payment-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.payment-option.selected {
  border-color: #FF6B35;
  background: rgba(255, 107, 53, 0.08);
}

.payment-icon { font-size: 36rpx; }

.payment-name {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.payment-balance {
  font-size: 24rpx;
  color: #0F6E56;
}

.payment-check {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
}

/* 确认下单按钮 */
.sheet-confirm-btn {
  margin: 28rpx 0 0;
  background: #FF6B35;
  border-radius: 44rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sheet-confirm-btn.disabled {
  background: rgba(255,107,53,0.4);
}

.sheet-confirm-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* 安全区底部 */
.sheet-safe-area {
  height: env(safe-area-inset-bottom);
  min-height: 32rpx;
}
