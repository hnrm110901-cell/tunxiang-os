<!-- 购物车结算页 — 菜品清单 + 单品备注 + 优惠 + 结算弹层 -->
<view class="cart-page">

  <!-- 顶部标题 -->
  <view class="cart-header">
    <view class="back-btn" bindtap="goBackToMenu">
      <text class="back-icon">‹</text>
      <text class="back-text">继续点菜</text>
    </view>
    <text class="header-title">已选菜品 ({{items.length}})</text>
    <view class="header-placeholder"></view>
  </view>

  <!-- 凑单提示 -->
  <view class="addon-tip" wx:if="{{addonTip}}" bindtap="goBackToMenu">
    <text class="addon-text">{{addonTip}}</text>
    <text class="addon-action">去凑单 ›</text>
  </view>

  <!-- 菜品列表 -->
  <scroll-view class="cart-list" scroll-y enhanced show-scrollbar="{{false}}">

    <view class="empty-state" wx:if="{{items.length === 0}}">
      <text class="empty-icon">🛒</text>
      <text class="empty-text">购物车空空如也</text>
      <view class="empty-btn" bindtap="goBackToMenu">去点菜</view>
    </view>

    <view class="cart-item" wx:for="{{items}}" wx:key="dishId">
      <!-- 菜品信息行 -->
      <view class="item-main">
        <image class="item-img" src="{{item.imageUrl || '/assets/dish-placeholder.png'}}" mode="aspectFill" lazy-load />
        <view class="item-info">
          <text class="item-name">{{item.dishName}}</text>
          <text class="item-spec" wx:if="{{item.spec}}">{{item.spec}}</text>
          <text class="item-price">¥{{(item.unitPriceFen / 100).toFixed(2)}}</text>
        </view>
        <view class="item-qty-ctrl">
          <view class="qty-btn minus" bindtap="changeQty" data-index="{{index}}" data-delta="-1">
            <text class="qty-btn-text">－</text>
          </view>
          <text class="qty-num">{{item.quantity}}</text>
          <view class="qty-btn plus" bindtap="changeQty" data-index="{{index}}" data-delta="1">
            <text class="qty-btn-text">＋</text>
          </view>
        </view>
      </view>
      <!-- 单品备注 -->
      <view class="item-remark-row">
        <text class="remark-icon">📝</text>
        <input
          class="item-remark-input"
          placeholder="备注（如：少辣、不要香菜）"
          placeholderClass="remark-placeholder"
          value="{{item.notes}}"
          bindinput="onItemRemarkInput"
          data-index="{{index}}"
          maxlength="50"
        />
      </view>
    </view>

  </scroll-view>

  <!-- AA分摊 -->
  <view class="aa-section" wx:if="{{items.length > 0}}" bindtap="toggleAASplit">
    <view class="aa-header">
      <text class="aa-title">👥 AA分摊</text>
      <text class="aa-toggle">{{showAASplit ? '收起 ∧' : '展开 ∨'}}</text>
    </view>
    <view class="aa-body" wx:if="{{showAASplit}}" catchtap="">
      <view class="aa-party">
        <text class="aa-label">共</text>
        <view class="aa-qty-ctrl">
          <view class="qty-btn minus" catchtap="changePartySize" data-delta="-1">
            <text class="qty-btn-text">－</text>
          </view>
          <text class="qty-num">{{partySize}}</text>
          <view class="qty-btn plus" catchtap="changePartySize" data-delta="1">
            <text class="qty-btn-text">＋</text>
          </view>
        </view>
        <text class="aa-label">人用餐</text>
      </view>
      <text class="aa-result">每人约 ¥{{(perPersonFen / 100).toFixed(2)}}</text>
    </view>
  </view>

  <!-- 可用优惠 -->
  <view class="coupon-section" wx:if="{{availableCoupons.length > 0}}">
    <text class="section-title">可用优惠</text>
    <view class="coupon-list">
      <view
        class="coupon-item {{selectedCoupon && selectedCoupon.id === item.id ? 'selected' : ''}}"
        wx:for="{{availableCoupons}}"
        wx:for-item="item"
        wx:key="id"
        bindtap="selectCoupon"
        data-index="{{index}}"
      >
        <view class="coupon-info">
          <text class="coupon-name">{{item.name || item.title}}</text>
          <text class="coupon-cond" wx:if="{{item.min_amount_fen}}">满¥{{(item.min_amount_fen/100).toFixed(0)}}可用</text>
        </view>
        <text class="coupon-value">-¥{{((item.discount_fen || item.amount_fen || 0) / 100).toFixed(0)}}</text>
        <view class="coupon-check" wx:if="{{selectedCoupon && selectedCoupon.id === item.id}}">✓</view>
      </view>
    </view>
    <view class="coupon-clear" wx:if="{{selectedCoupon}}" bindtap="clearCoupon">
      <text class="coupon-clear-text">不使用优惠券</text>
    </view>
  </view>

  <!-- 整单备注 -->
  <view class="notes-section" wx:if="{{items.length > 0}}">
    <text class="section-title">整单备注</text>
    <input
      class="notes-input"
      placeholder="如：过敏花生、帮忙预备生日蛋糕"
      placeholderClass="notes-placeholder"
      bindinput="onNotesInput"
      value="{{orderNotes}}"
      maxlength="100"
    />
  </view>

  <!-- 底部占位，防被吸底区遮挡 -->
  <view class="bottom-placeholder"></view>
</view>

<!-- 底部吸底结算栏 -->
<view class="checkout-bar" wx:if="{{items.length > 0}}">
  <view class="checkout-info">
    <view class="checkout-count-row">
      <text class="checkout-count">共{{totalCount}}件</text>
    </view>
    <view class="checkout-price-row">
      <text class="checkout-label">合计</text>
      <text class="checkout-total">¥{{(finalTotalFen / 100).toFixed(2)}}</text>
    </view>
    <text class="checkout-discount" wx:if="{{discountFen > 0}}">已优惠 ¥{{(discountFen / 100).toFixed(2)}}</text>
  </view>
  <view class="checkout-btn" bindtap="openCheckoutSheet">
    <text class="checkout-btn-text">去结算</text>
  </view>
</view>

<!-- 结算弹层遮罩 -->
<view class="sheet-mask" wx:if="{{showCheckoutSheet}}" bindtap="closeCheckoutSheet"></view>

<!-- 结算底部弹层 -->
<view class="checkout-sheet {{showCheckoutSheet ? 'visible' : ''}}">
  <view class="sheet-handle"></view>
  <text class="sheet-title">确认结算</text>

  <!-- 订单小计 -->
  <view class="sheet-summary">
    <view class="summary-row">
      <text class="summary-label">菜品小计</text>
      <text class="summary-value">¥{{(totalFen / 100).toFixed(2)}}</text>
    </view>
    <view class="summary-row" wx:if="{{discountFen > 0}}">
      <text class="summary-label">优惠减免</text>
      <text class="summary-value discount">-¥{{(discountFen / 100).toFixed(2)}}</text>
    </view>
    <view class="summary-divider"></view>
    <view class="summary-row total-row">
      <text class="summary-label total-label">实付金额</text>
      <text class="summary-value total-value">¥{{(finalTotalFen / 100).toFixed(2)}}</text>
    </view>
  </view>

  <!-- 储值卡余额 -->
  <view class="sheet-section" wx:if="{{storedValueBalance > 0}}">
    <view class="sheet-row">
      <text class="sheet-row-label">储值卡余额</text>
      <text class="sheet-row-value balance">¥{{(storedValueBalance / 100).toFixed(2)}}</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="sheet-section">
    <text class="sheet-section-title">支付方式</text>
    <view class="payment-options">
      <view
        class="payment-option {{paymentMethod === 'wechat' ? 'selected' : ''}}"
        bindtap="selectPayment"
        data-method="wechat"
      >
        <text class="payment-icon">💚</text>
        <text class="payment-name">微信支付</text>
        <view class="payment-check" wx:if="{{paymentMethod === 'wechat'}}">✓</view>
      </view>
      <view
        class="payment-option {{paymentMethod === 'stored_value' ? 'selected' : ''}}"
        wx:if="{{storedValueBalance >= finalTotalFen}}"
        bindtap="selectPayment"
        data-method="stored_value"
      >
        <text class="payment-icon">💳</text>
        <text class="payment-name">储值卡</text>
        <text class="payment-balance">余额¥{{(storedValueBalance / 100).toFixed(2)}}</text>
        <view class="payment-check" wx:if="{{paymentMethod === 'stored_value'}}">✓</view>
      </view>
      <view
        class="payment-option {{paymentMethod === 'enterprise' ? 'selected' : ''}}"
        wx:if="{{hasEnterpriseAccount}}"
        bindtap="selectPayment"
        data-method="enterprise"
      >
        <text class="payment-icon">🏢</text>
        <text class="payment-name">企业挂账</text>
        <view class="payment-check" wx:if="{{paymentMethod === 'enterprise'}}">✓</view>
      </view>
    </view>
  </view>

  <!-- 确认下单按钮 -->
  <view class="sheet-confirm-btn {{submitting ? 'disabled' : ''}}" bindtap="submitOrder">
    <text class="sheet-confirm-text">{{submitting ? '下单中...' : '确认下单 ¥' + (finalTotalFen / 100).toFixed(2)}}</text>
  </view>

  <!-- 安全区底部占位 -->
  <view class="sheet-safe-area"></view>
</view>
