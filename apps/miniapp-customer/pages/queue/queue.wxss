.container { padding: 0; background: #0B1A20; min-height: 100vh; color: #fff; }

.take-number-section { padding: 40rpx 30rpx; }
.section-title { font-size: 36rpx; font-weight: bold; margin-bottom: 40rpx; }

.form-item { margin-bottom: 40rpx; }
.form-label { font-size: 28rpx; color: #999; margin-bottom: 20rpx; display: block; }

/* 人数选项 */
.guest-options { display: flex; flex-wrap: wrap; gap: 20rpx; }
.guest-item { flex: 1; min-width: 40%; text-align: center; padding: 24rpx 0; background: #1a2a33; border-radius: 12rpx; font-size: 28rpx; color: #999; }
.guest-item.active { background: #FF6B2C; color: #fff; }

/* 排队概况 */
.queue-overview { background: #112228; border-radius: 16rpx; padding: 28rpx; margin-bottom: 40rpx; }
.overview-title { font-size: 28rpx; color: #999; margin-bottom: 20rpx; }
.overview-row { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #1a2a33; }
.overview-row:last-child { border-bottom: none; }
.overview-type { font-size: 28rpx; color: #ccc; flex: 1; }
.overview-count { font-size: 28rpx; color: #FF6B2C; flex: 1; text-align: center; }
.overview-time { font-size: 28rpx; color: #999; flex: 1; text-align: right; }

.submit-btn { margin-top: 20rpx; background: #FF6B2C !important; color: #fff !important; border-radius: 44rpx; font-size: 32rpx; height: 88rpx; line-height: 88rpx; }
.submit-btn[disabled] { opacity: 0.6; }

/* 已取号 — 票据卡片 */
.ticket-section { padding: 40rpx 30rpx; }
.ticket-card { background: linear-gradient(135deg, #FF6B2C, #FF8F5E); border-radius: 20rpx; padding: 48rpx 30rpx; text-align: center; margin-bottom: 40rpx; }
.ticket-type { font-size: 28rpx; color: rgba(255,255,255,0.8); margin-bottom: 12rpx; }
.ticket-number { font-size: 80rpx; font-weight: bold; color: #fff; }
.ticket-hint { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-top: 12rpx; }

/* 等位进度 */
.progress-section { background: #112228; border-radius: 16rpx; padding: 28rpx; margin-bottom: 32rpx; }
.progress-item { display: flex; justify-content: space-between; padding: 18rpx 0; border-bottom: 1rpx solid #1a2a33; }
.progress-item:last-child { border-bottom: none; }
.progress-label { font-size: 28rpx; color: #999; }
.progress-value { font-size: 28rpx; color: #ccc; }
.progress-value.highlight { color: #FF6B2C; font-weight: bold; }

/* 提示 */
.tip-box { background: rgba(255, 107, 44, 0.1); border-radius: 12rpx; padding: 20rpx 24rpx; margin-bottom: 40rpx; }
.tip-text { font-size: 24rpx; color: #FF6B2C; }

.cancel-btn { background: #1a2a33 !important; color: #999 !important; border-radius: 44rpx; font-size: 30rpx; height: 80rpx; line-height: 80rpx; }
