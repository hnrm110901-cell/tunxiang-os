.container { padding: 0; background: #0B1A20; min-height: 100vh; color: #fff; }
.page-title { font-size: 36rpx; font-weight: bold; padding: 30rpx 30rpx 0; }

/* Tab 切换 */
.tab-bar { display: flex; border-bottom: 1rpx solid #1a2a33; margin-top: 20rpx; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #999; position: relative; }
.tab-item.active { color: #FF6B2C; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 25%; right: 25%; height: 4rpx; background: #FF6B2C; border-radius: 2rpx; }

/* 账户总览 */
.overview-section { padding: 30rpx; }
.balance-card { background: linear-gradient(135deg, #FF6B2C, #FF8F5E); border-radius: 20rpx; padding: 48rpx 36rpx; margin-bottom: 30rpx; }
.balance-label { font-size: 26rpx; color: rgba(255,255,255,0.8); }
.balance-amount { margin: 16rpx 0 12rpx; }
.balance-symbol { font-size: 36rpx; color: #fff; margin-right: 4rpx; }
.balance-value { font-size: 72rpx; font-weight: bold; color: #fff; }
.balance-company { font-size: 24rpx; color: rgba(255,255,255,0.7); }

.stats-row { display: flex; background: #112228; border-radius: 16rpx; padding: 28rpx 0; margin-bottom: 30rpx; }
.stat-item { flex: 1; text-align: center; }
.stat-value { font-size: 36rpx; font-weight: bold; color: #FF6B2C; display: block; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }

.quota-section { background: #112228; border-radius: 16rpx; padding: 28rpx; }
.quota-row { display: flex; justify-content: space-between; padding: 14rpx 0; }
.quota-row:first-child { border-bottom: 1rpx solid #1a2a33; }
.quota-label { font-size: 28rpx; color: #999; }
.quota-value { font-size: 28rpx; color: #fff; }

/* 消费记录 */
.records-section { padding: 30rpx; }
.empty-tip { text-align: center; color: #666; font-size: 28rpx; padding: 120rpx 0; }

.record-card { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #1a2a33; }
.record-left { display: flex; flex-direction: column; gap: 8rpx; }
.record-title { font-size: 28rpx; color: #fff; }
.record-time { font-size: 22rpx; color: #666; }
.record-right { text-align: right; }
.record-amount { font-size: 30rpx; font-weight: bold; display: block; }
.record-amount.expense { color: #FF6B2C; }
.record-amount.income { color: #4CAF50; }
.record-headcount { font-size: 22rpx; color: #999; }

.load-more { text-align: center; padding: 30rpx; color: #FF6B2C; font-size: 26rpx; }

/* 预订团餐 */
.booking-section { padding: 30rpx; }
.form-item { margin-bottom: 36rpx; }
.form-label { font-size: 28rpx; color: #999; margin-bottom: 16rpx; display: block; }
.picker-value { background: #1a2a33; padding: 20rpx 24rpx; border-radius: 12rpx; font-size: 28rpx; color: #fff; }
.form-input { background: #1a2a33; padding: 20rpx 24rpx; border-radius: 12rpx; font-size: 28rpx; color: #fff; }
.form-textarea { background: #1a2a33; padding: 20rpx 24rpx; border-radius: 12rpx; font-size: 28rpx; color: #fff; width: 100%; height: 160rpx; box-sizing: border-box; }
.placeholder { color: #666; }

.meal-type-list { display: flex; gap: 20rpx; }
.meal-type-item { flex: 1; text-align: center; padding: 20rpx 0; background: #1a2a33; border-radius: 12rpx; font-size: 28rpx; color: #999; }
.meal-type-item.active { background: #FF6B2C; color: #fff; }

.budget-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.budget-item { padding: 16rpx 32rpx; background: #1a2a33; border-radius: 12rpx; font-size: 26rpx; color: #999; }
.budget-item.active { background: #FF6B2C; color: #fff; }

.submit-btn { margin-top: 48rpx; background: #FF6B2C !important; color: #fff !important; border-radius: 44rpx; font-size: 32rpx; height: 88rpx; line-height: 88rpx; }
.submit-btn[disabled] { opacity: 0.6; }
