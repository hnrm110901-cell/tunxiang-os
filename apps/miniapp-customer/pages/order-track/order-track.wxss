.page-container {
  min-height: 100vh;
  background: #0B1A20;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* Header */
.track-header {
  padding: 32rpx;
  background: linear-gradient(180deg, #112228, #0B1A20);
}

.track-header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.track-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.track-order-no {
  font-size: 24rpx;
  color: #999;
}

.track-store {
  font-size: 26rpx;
  color: #ccc;
}

/* Rush cooldown */
.rush-cooldown {
  text-align: center;
  padding: 16rpx 0;
}

.cooldown-text {
  font-size: 24rpx;
  color: #999;
}

/* Items */
.items-section {
  margin: 0 32rpx;
  background: #112228;
  border-radius: 24rpx;
  padding: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 20rpx;
  display: block;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #1a2a33;
  gap: 16rpx;
}

.order-item:last-child {
  border-bottom: none;
}

.item-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.item-name {
  font-size: 28rpx;
  color: #fff;
}

.item-qty {
  font-size: 24rpx;
  color: #999;
}

.item-price {
  font-size: 28rpx;
  color: #FF6B2C;
  font-weight: 600;
}

.order-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  margin-top: 12rpx;
  border-top: 2rpx solid #1a2a33;
}

.total-label {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.total-value {
  font-size: 36rpx;
  color: #FF6B2C;
  font-weight: bold;
}

/* Append */
.append-section {
  padding: 24rpx 32rpx;
}

.append-btn {
  background: transparent !important;
  border: 2rpx solid #FF6B2C !important;
  color: #FF6B2C !important;
  border-radius: 44rpx;
  font-size: 30rpx;
  height: 80rpx;
  line-height: 80rpx;
}

/* Info section */
.info-section {
  margin: 24rpx 32rpx;
  background: #112228;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #ccc;
}
