.container { padding: 0; background: #0B1A20; min-height: 100vh; color: #fff; }

/* Tab 切换 */
.tab-bar { display: flex; border-bottom: 1rpx solid #1a2a33; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: #999; position: relative; }
.tab-item.active { color: #FF6B2C; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 30%; right: 30%; height: 4rpx; background: #FF6B2C; border-radius: 2rpx; }

/* 表单 */
.form-section { padding: 30rpx; }
.form-item { margin-bottom: 36rpx; }
.form-label { font-size: 28rpx; color: #999; margin-bottom: 16rpx; display: block; }

.picker-value { background: #1a2a33; padding: 20rpx 24rpx; border-radius: 12rpx; font-size: 28rpx; color: #fff; }

/* 时段选择 */
.slot-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.slot-item { padding: 16rpx 28rpx; background: #1a2a33; border-radius: 12rpx; font-size: 26rpx; color: #999; }
.slot-item.active { background: #FF6B2C; color: #fff; }

/* 人数步进器 */
.stepper { display: flex; align-items: center; }
.stepper-btn { width: 64rpx; height: 64rpx; background: #1a2a33; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; color: #FF6B2C; text-align: center; line-height: 64rpx; }
.stepper-value { font-size: 32rpx; margin: 0 30rpx; min-width: 48rpx; text-align: center; }

/* 包间偏好 */
.room-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.room-item { padding: 16rpx 28rpx; background: #1a2a33; border-radius: 12rpx; font-size: 26rpx; color: #999; }
.room-item.active { background: #FF6B2C; color: #fff; }

/* 输入框 */
.form-input { background: #1a2a33; padding: 20rpx 24rpx; border-radius: 12rpx; font-size: 28rpx; color: #fff; }
.placeholder { color: #666; }

/* 提交按钮 */
.submit-btn { margin-top: 48rpx; background: #FF6B2C !important; color: #fff !important; border-radius: 44rpx; font-size: 32rpx; padding: 0 60rpx; height: 88rpx; line-height: 88rpx; }
.submit-btn[disabled] { opacity: 0.6; }

/* 预订列表 */
.list-section { padding: 30rpx; }
.empty-tip { text-align: center; color: #666; font-size: 28rpx; padding: 120rpx 0; }

.booking-card { background: #112228; border-radius: 16rpx; padding: 28rpx; margin-bottom: 24rpx; }
.booking-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.booking-date { font-size: 30rpx; font-weight: bold; }
.booking-status { font-size: 24rpx; padding: 6rpx 16rpx; border-radius: 8rpx; }
.status-confirmed { background: rgba(255, 107, 44, 0.15); color: #FF6B2C; }
.status-pending { background: rgba(255, 200, 50, 0.15); color: #FFC832; }
.status-cancelled { background: rgba(153, 153, 153, 0.15); color: #999; }
.status-completed { background: rgba(76, 175, 80, 0.15); color: #4CAF50; }

.booking-body { margin-bottom: 16rpx; }
.booking-detail { font-size: 28rpx; color: #ccc; }
.booking-remark { font-size: 24rpx; color: #999; display: block; margin-top: 8rpx; }

.booking-footer { display: flex; justify-content: flex-end; }
.cancel-btn { font-size: 26rpx; color: #999; background: #1a2a33 !important; border-radius: 30rpx; padding: 0 30rpx; height: 60rpx; line-height: 60rpx; }
