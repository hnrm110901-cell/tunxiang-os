.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 140rpx; }

/* ─── Store header ─── */
.store-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(180deg, #112228, #0B1A20);
}

.store-info { flex: 1; }
.store-name { font-size: 40rpx; font-weight: bold; color: #fff; display: block; }
.store-address { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.table-badge {
  background: #FF6B2C;
  border-radius: 16rpx;
  padding: 12rpx 24rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.table-label { font-size: 20rpx; color: rgba(255,255,255,0.8); }
.table-no { font-size: 36rpx; font-weight: bold; color: #fff; }

.scan-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 107, 44, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-icon {
  font-size: 36rpx;
  color: #FF6B2C;
}

/* ─── Mode tabs ─── */
.mode-tabs {
  display: flex;
  margin: 0 32rpx;
  background: #112228;
  border-radius: 20rpx;
  padding: 6rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #999;
  border-radius: 16rpx;
  transition: all 200ms ease;
}

.mode-tab.active {
  background: #FF6B2C;
  color: #fff;
  font-weight: 600;
}

/* ─── Quick entries ─── */
.quick-entries {
  display: flex;
  justify-content: space-around;
  padding: 36rpx 32rpx;
  background: #112228;
  margin: 24rpx 32rpx 0;
  border-radius: 24rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.entry-icon-circle {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 107, 44, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.entry-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.entry-icon-emoji {
  font-size: 44rpx;
  text-align: center;
  line-height: 96rpx;
}

.entry-label { font-size: 24rpx; color: #ccc; }

/* ─── Active order floating card (with progress + estimated time) ─── */
.active-order-card {
  margin: 20rpx 32rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, rgba(255, 107, 44, 0.15), rgba(255, 107, 44, 0.05));
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 107, 44, 0.3);
}

.active-order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.active-order-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.active-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FF6B2C;
  animation: blink 1.5s ease-in-out infinite;
}

.active-status-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF6B2C;
}

.active-order-time {
  font-size: 26rpx;
  color: #ccc;
}

/* Progress bar */
.active-order-progress {
  margin-bottom: 16rpx;
}

.progress-track {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B2C, #FF9F5C);
  border-radius: 4rpx;
  transition: width 500ms ease;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
}

.progress-label {
  font-size: 22rpx;
  color: #999;
}

.active-order-bottom {
  margin-bottom: 12rpx;
}

.active-dish-label {
  font-size: 24rpx;
  color: #ccc;
}

.active-order-action {
  font-size: 26rpx;
  color: #FF6B2C;
  display: block;
  text-align: right;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ─── Status cards ─── */
.status-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 16rpx 32rpx 0;
  padding: 24rpx 28rpx;
  background: rgba(255, 107, 44, 0.08);
  border-radius: 16rpx;
  border-left: 6rpx solid #FF6B2C;
}

.status-left { display: flex; flex-direction: column; gap: 6rpx; }
.status-type { font-size: 28rpx; color: #FF6B2C; font-weight: bold; }
.status-detail { font-size: 24rpx; color: #ccc; }
.status-action { font-size: 24rpx; color: #FF6B2C; }

/* ─── CTA ─── */
.cta-section {
  padding: 24rpx 32rpx;
}

.cta-btn {
  background: #FF6B2C !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-weight: 600;
}

/* ─── Nearby stores ─── */
.section { padding: 32rpx; }
.section-title { font-size: 34rpx; font-weight: bold; color: #fff; margin-bottom: 24rpx; display: block; }

.loading-tip { text-align: center; padding: 60rpx 0; color: #999; font-size: 28rpx; }

.store-card {
  display: flex;
  align-items: center;
  background: #112228;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.store-card-img {
  width: 120rpx;
  height: 90rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.store-card-main { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.store-card-name { font-size: 30rpx; font-weight: 600; color: #fff; }
.store-card-address { font-size: 24rpx; color: #999; }
.store-card-hours { font-size: 22rpx; color: #666; }

.store-card-right { text-align: right; display: flex; flex-direction: column; gap: 8rpx; margin-left: 16rpx; }
.store-card-distance { font-size: 26rpx; color: #FF6B2C; font-weight: 600; }
.store-card-queue { font-size: 22rpx; color: #999; }
