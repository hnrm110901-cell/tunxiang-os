.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 120rpx; }

/* ─── 顶部门店信息 ─── */
.store-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(180deg, #112228, #0B1A20);
}

.store-info { flex: 1; }
.store-name { font-size: 40rpx; font-weight: bold; color: #fff; display: block; }
.store-address { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }

.table-badge {
  background: #FF6B2C;
  border-radius: 16rpx;
  padding: 12rpx 24rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.table-label { font-size: 20rpx; color: rgba(255,255,255,0.8); }
.table-no { font-size: 36rpx; font-weight: bold; color: #fff; }

/* ─── 快捷入口 ─── */
.quick-entries {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  background: #112228;
  margin: 0 32rpx;
  border-radius: 24rpx;
  margin-top: -8rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 107, 44, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  text-align: center;
  line-height: 96rpx;
}

.entry-label { font-size: 24rpx; color: #ccc; }

/* ─── 当前状态卡片 ─── */
.status-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 24rpx 32rpx 0;
  padding: 28rpx;
  background: rgba(255, 107, 44, 0.1);
  border-radius: 20rpx;
  border-left: 6rpx solid #FF6B2C;
}

.status-left { display: flex; flex-direction: column; gap: 8rpx; }
.status-type { font-size: 28rpx; color: #FF6B2C; font-weight: bold; }
.status-detail { font-size: 26rpx; color: #ccc; }
.status-action { font-size: 26rpx; color: #FF6B2C; }

/* ─── 附近门店 ─── */
.section { padding: 32rpx; }
.section-title { font-size: 34rpx; font-weight: bold; color: #fff; margin-bottom: 24rpx; display: block; }

.loading-tip { text-align: center; padding: 60rpx 0; color: #999; font-size: 28rpx; }

.store-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #112228;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.store-card-main { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.store-card-name { font-size: 30rpx; font-weight: 600; color: #fff; }
.store-card-address { font-size: 24rpx; color: #999; }

.store-card-right { text-align: right; display: flex; flex-direction: column; gap: 8rpx; margin-left: 20rpx; }
.store-card-distance { font-size: 26rpx; color: #FF6B2C; }
.store-card-queue { font-size: 22rpx; color: #999; }
