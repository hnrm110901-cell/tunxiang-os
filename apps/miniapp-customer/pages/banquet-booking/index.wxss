.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 60rpx; }

/* ─── Hero banner ─── */
.hero-banner {
  background: linear-gradient(135deg, #1A3040, #0B1A20);
  padding: 60rpx 32rpx 48rpx; text-align: center;
}
.hero-title { font-size: 44rpx; color: #fff; font-weight: bold; display: block; }
.hero-subtitle { font-size: 26rpx; color: #999; margin-top: 12rpx; display: block; }

/* ─── Type grid ─── */
.type-grid { display: flex; flex-wrap: wrap; padding: 32rpx 24rpx; gap: 16rpx; }
.type-card {
  width: calc(50% - 8rpx); background: #112228; border-radius: 20rpx;
  padding: 32rpx 24rpx; text-align: center; border: 2rpx solid transparent;
}
.type-icon-wrap {
  width: 100rpx; height: 100rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 16rpx;
}
.type-icon { width: 56rpx; height: 56rpx; }
.type-label { font-size: 32rpx; color: #fff; font-weight: 600; display: block; }
.type-desc { font-size: 24rpx; color: #999; margin-top: 4rpx; display: block; }
.type-person { font-size: 22rpx; color: #FF6B2C; margin-top: 8rpx; display: block; }

/* ─── Consult bar ─── */
.consult-bar {
  display: flex; align-items: center; justify-content: space-between;
  margin: 0 32rpx 32rpx; padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #FF6B2C, #FF8F5E);
  border-radius: 16rpx;
}
.consult-text { font-size: 26rpx; color: #fff; }
.consult-btn {
  padding: 12rpx 32rpx; background: #fff; border-radius: 24rpx;
  font-size: 24rpx; color: #FF6B2C; font-weight: 500;
}

/* ─── Section ─── */
.section { padding: 0 32rpx 32rpx; }
.section-title { font-size: 32rpx; color: #fff; font-weight: 600; display: block; margin-bottom: 24rpx; }

/* ─── Package scroll ─── */
.package-scroll { white-space: nowrap; }
.package-card {
  display: inline-block; width: 360rpx; background: #112228;
  border-radius: 16rpx; overflow: hidden; margin-right: 16rpx;
  vertical-align: top;
}
.package-cover { width: 100%; height: 220rpx; }
.package-body { padding: 16rpx 20rpx 24rpx; white-space: normal; }
.package-name { font-size: 28rpx; color: #fff; font-weight: 500; display: block; }
.package-price { font-size: 28rpx; color: #FF6B2C; font-weight: bold; margin-top: 8rpx; display: block; }
.package-capacity { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }

/* ─── Cases ─── */
.case-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.case-card {
  width: calc(50% - 8rpx); height: 280rpx; border-radius: 16rpx;
  overflow: hidden; position: relative;
}
.case-image { width: 100%; height: 100%; }
.case-overlay {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.8));
  padding: 48rpx 16rpx 16rpx;
}
.case-title { font-size: 26rpx; color: #fff; display: block; }
.case-type { font-size: 20rpx; color: #FF6B2C; margin-top: 4rpx; display: block; }

.empty-tip { text-align: center; padding: 48rpx 0; color: #666; font-size: 26rpx; }
.footer-note { text-align: center; padding: 32rpx; color: #666; font-size: 22rpx; }
