.page-container { min-height: 100vh; background: #0B1A20; color: #fff; padding-bottom: 160rpx; }

/* --- 主 Tab --- */
.main-tab-bar {
  display: flex;
  margin: 0 32rpx;
  border-bottom: 1rpx solid #1a2a33;
}

.main-tab {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: #999;
  padding: 28rpx 0;
  position: relative;
}

.main-tab-active {
  color: #FF6B35;
  font-weight: bold;
}

.main-tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background: #FF6B35;
  border-radius: 2rpx;
}

/* --- Section --- */
.section {
  margin: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 24rpx;
}

/* --- 面额选择 --- */
.amount-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.amount-item {
  width: calc(25% - 15rpx);
  background: #112A33;
  border: 2rpx solid #1a3a45;
  border-radius: 16rpx;
  padding: 28rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  box-sizing: border-box;
}

.amount-active {
  border-color: #FF6B35;
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
}

/* --- 卡面主题 --- */
.theme-scroll {
  white-space: nowrap;
}

.theme-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.theme-card {
  width: 200rpx;
  height: 160rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
  flex-shrink: 0;
}

.theme-birthday { background: linear-gradient(135deg, #FF6B35, #FF8C42); }
.theme-thanks { background: linear-gradient(135deg, #E91E63, #FF5252); }
.theme-holiday { background: linear-gradient(135deg, #4CAF50, #8BC34A); }
.theme-love { background: linear-gradient(135deg, #9C27B0, #E040FB); }

.theme-active {
  border-color: #fff;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 53, 0.4);
}

.theme-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.theme-name {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
}

/* --- 祝福语 --- */
.bless-input {
  width: 100%;
  background: #112A33;
  border: 2rpx solid #1a3a45;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #fff;
  font-size: 28rpx;
  height: 160rpx;
  box-sizing: border-box;
}

.bless-count {
  text-align: right;
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

/* --- 手机号 --- */
.phone-input {
  background: #112A33;
  border: 2rpx solid #1a3a45;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #fff;
  font-size: 30rpx;
}

/* --- 底部按钮 --- */
.bottom-placeholder { height: 160rpx; }

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #0B1A20;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #1a2a33;
}

.buy-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #FF6B35 !important;
  color: #fff !important;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  text-align: center;
  border: none;
}

.buy-btn[disabled] {
  background: #4a4a4a !important;
  color: #999 !important;
}

/* --- 子 Tab --- */
.sub-tab-bar {
  display: flex;
  margin: 0 32rpx;
  margin-top: 16rpx;
  gap: 24rpx;
}

.sub-tab {
  font-size: 28rpx;
  color: #999;
  padding: 20rpx 0;
  position: relative;
}

.sub-tab-active {
  color: #FF6B35;
  font-weight: bold;
}

.sub-tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: #FF6B35;
  border-radius: 2rpx;
}

/* --- 卡片列表 --- */
.card-list {
  padding: 24rpx 32rpx;
}

.gift-card-item {
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.theme-bg-birthday { background: linear-gradient(135deg, #FF6B35, #FF8C42); }
.theme-bg-thanks { background: linear-gradient(135deg, #E91E63, #FF5252); }
.theme-bg-holiday { background: linear-gradient(135deg, #4CAF50, #8BC34A); }
.theme-bg-love { background: linear-gradient(135deg, #9C27B0, #E040FB); }

.gc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.gc-amount {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
}

.gc-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255,255,255,0.2);
  color: #fff;
}

.gc-status-used { background: rgba(0,0,0,0.3); color: rgba(255,255,255,0.6); }
.gc-status-expired { background: rgba(0,0,0,0.4); color: rgba(255,255,255,0.4); }

.gc-bless {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.gc-footer {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

/* --- 空状态 --- */
.list-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #666; }
