/* 领券中心 */

.page-container {
  min-height: 100vh;
  background: #0B1A20;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ── Banner ── */
.banner {
  position: relative;
  height: 240rpx;
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
}

.banner-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 40rpx 48rpx;
  height: 100%;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.banner-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
}

/* ── 分类Tab ── */
.category-bar {
  padding: 24rpx 0 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.category-scroll {
  white-space: nowrap;
  padding: 0 32rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 32rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #999;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 32rpx;
  transition: all 0.2s;
}

.category-item.active {
  color: #fff;
  background: #FF6B35;
  font-weight: 600;
}

/* ── 优惠券列表 ── */
.coupon-list {
  padding: 24rpx 32rpx;
}

.coupon-card {
  display: flex;
  align-items: stretch;
  background: #112228;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  min-height: 180rpx;
}

/* 左侧金额区 */
.coupon-left {
  width: 200rpx;
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 12rpx;
  flex-shrink: 0;
  background: rgba(255, 107, 53, 0.15);
  border-right: 2rpx dashed rgba(255, 255, 255, 0.08);
}

.coupon-amount {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.amount-sym {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 600;
}

.amount-sym.small {
  font-size: 22rpx;
}

.gift-sym {
  font-size: 44rpx;
  color: #FF6B35;
}

.amount-val {
  font-size: 60rpx;
  font-weight: bold;
  color: #FF6B35;
}

.discount-val {
  font-size: 52rpx;
}

.coupon-threshold {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: center;
}

/* 右侧信息区 */
.coupon-info {
  flex: 1;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  overflow: hidden;
}

.coupon-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.coupon-scope {
  font-size: 22rpx;
  color: #FF6B35;
  display: block;
}

.coupon-expire {
  font-size: 22rpx;
  color: #666;
  display: block;
}

.countdown-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 4rpx;
}

.countdown-icon {
  font-size: 22rpx;
  color: #E53E3E;
}

.countdown-text {
  font-size: 22rpx;
  color: #E53E3E;
  font-weight: 600;
}

/* 领取按钮区 */
.coupon-action {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  flex-shrink: 0;
}

.claim-btn {
  font-size: 24rpx !important;
  background: #FF6B35 !important;
  color: #fff !important;
  border-radius: 32rpx;
  padding: 0 28rpx;
  height: 68rpx;
  line-height: 68rpx;
  min-width: 0;
  white-space: nowrap;
  border: none;
}

.claim-btn::after {
  border: none;
}

.claim-btn.claiming {
  background: #FF8C42 !important;
  opacity: 0.7;
}

.claim-btn.claimed {
  background: #2D8B4D !important;
  color: rgba(255, 255, 255, 0.9) !important;
}

.claim-btn.soldout {
  background: #1a2a33 !important;
  color: #555 !important;
}

/* ── 通用状态 ── */
.loading-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #666;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0 80rpx;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
}

.empty-sub {
  font-size: 24rpx;
  color: #555;
}

.safe-bottom {
  height: 40rpx;
}
