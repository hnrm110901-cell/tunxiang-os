.container { padding: 0; background: #0B1A20; min-height: 100vh; color: #fff; }

/* Tab栏 */
.tab-bar { display: flex; border-bottom: 1rpx solid #1a2a33; background: #0B1A20; position: sticky; top: 0; z-index: 10; }
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}
.tab-item.active { color: #FF6B35; }
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 4rpx;
  background: #FF6B35;
  border-radius: 2rpx;
}

/* 列表区域 */
.list-section { padding: 24rpx 30rpx; }

/* 加载 */
.loading-tip { text-align: center; color: #666; font-size: 28rpx; padding: 80rpx 0; }

/* 空状态 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #666; }

/* 预约卡片 */
.booking-card {
  background: #112228;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.card-store { font-size: 30rpx; font-weight: bold; color: #fff; }
.card-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}
.status-confirmed { background: rgba(255, 107, 53, 0.15); color: #FF6B35; }
.status-pending { background: rgba(255, 200, 50, 0.15); color: #FFC832; }
.status-cancelled { background: rgba(153, 153, 153, 0.15); color: #999; }
.status-completed { background: rgba(76, 175, 80, 0.15); color: #4CAF50; }
.status-no_show { background: rgba(244, 67, 54, 0.15); color: #F44336; }

/* 卡片内容 */
.card-body { margin-bottom: 16rpx; }
.card-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 0;
}
.card-icon { font-size: 28rpx; }
.card-text { font-size: 28rpx; color: #ccc; }
.card-divider { color: #555; margin: 0 8rpx; }
.card-remark { color: #999; font-size: 24rpx; }

/* 操作栏 */
.card-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
  border-top: 1rpx solid #1a2a33;
}
.cancel-btn {
  font-size: 26rpx;
  color: #999 !important;
  background: #1a2a33 !important;
  border-radius: 30rpx;
  padding: 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
}
