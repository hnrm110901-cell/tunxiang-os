/* 催单结果页 */
.page-container {
  min-height: 100vh;
  background: #0B1A20;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

/* 成功动画 */
.result-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.anim-icon {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.anim-emoji { font-size: 120rpx; }
.result-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #FF6B2C;
  margin-bottom: 16rpx;
}
.result-msg {
  font-size: 28rpx;
  color: #ccc;
}

/* 信息卡 */
.info-card {
  width: 100%;
  background: #112228;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 48rpx;
}
.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.info-row:last-child { border-bottom: none; }
.info-icon { font-size: 32rpx; }
.info-text { font-size: 28rpx; color: #ccc; }

/* 倒计时 */
.countdown-section { margin-bottom: 32rpx; }
.countdown-text { font-size: 26rpx; color: #999; }

/* 返回按钮 */
.action-section { width: 100%; }
.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  background: #FF6B2C;
}
.action-btn-text { color: #fff; font-size: 30rpx; font-weight: 600; }

/* 加载 */
.loading-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}
.loading-text { font-size: 28rpx; color: #999; }
