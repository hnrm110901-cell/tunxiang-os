.page { background: #f8f8f8; min-height: 100vh; }

.tab-bar {
  display: flex;
  background: #fff;
  padding: 20rpx 0 0;
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding-bottom: 16rpx;
}
.tab-item.active {
  color: #FF6B35;
  font-weight: bold;
  border-bottom: 4rpx solid #FF6B35;
}

.feed-scroll { height: calc(100vh - 88rpx); }

.masonry { display: flex; gap: 16rpx; padding: 16rpx; }
.masonry-col { flex: 1; display: flex; flex-direction: column; gap: 16rpx; }

.post-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.post-image { width: 100%; display: block; }
.post-content { padding: 16rpx; }
.post-title { font-size: 26rpx; color: #333; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

.post-tags { margin-top: 8rpx; }
.tag { font-size: 22rpx; color: #FF6B35; margin-right: 8rpx; }

.post-author { display: flex; align-items: center; margin-top: 12rpx; }
.avatar { width: 40rpx; height: 40rpx; border-radius: 50%; margin-right: 8rpx; background: #eee; }
.author-name { flex: 1; font-size: 22rpx; color: #999; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.like-btn { display: flex; align-items: center; gap: 4rpx; }
.like-icon { font-size: 24rpx; color: #ccc; }
.like-count { font-size: 22rpx; color: #999; }
.like-btn.liked .like-icon { color: #ff4d4f; }
.like-btn.liked .like-count { color: #ff4d4f; }

.load-more, .no-more { text-align: center; padding: 24rpx; font-size: 24rpx; color: #999; }

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #FF6B35;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(255,107,53,0.4);
}
.fab-icon { font-size: 56rpx; color: #fff; line-height: 1; }
