.page-container { min-height: 100vh; background: #0B1A20; padding-bottom: 60rpx; }

.tabs-bar {
  display: flex; padding: 24rpx 32rpx; gap: 16rpx;
}
.tab-item {
  flex: 1; text-align: center; padding: 20rpx 0; font-size: 28rpx;
  color: #999; background: #112228; border-radius: 16rpx;
}
.tab-item.active {
  background: #FF6B2C; color: #fff; font-weight: 600;
}

.back-bar {
  display: flex; align-items: center; gap: 8rpx; padding: 24rpx 32rpx;
  color: #999; font-size: 28rpx;
}
.back-arrow { font-size: 32rpx; margin-right: 4rpx; }

/* Activity Card */
.activity-list { padding: 0 32rpx; }
.activity-card {
  background: #112228; border-radius: 24rpx; margin-bottom: 24rpx;
  overflow: hidden;
}
.activity-img-placeholder {
  height: 200rpx; background: linear-gradient(135deg, #1a2a33, #0f3040);
  position: relative; display: flex; align-items: center; justify-content: center;
}
.activity-badge {
  position: absolute; top: 16rpx; left: 16rpx;
  background: #FF6B2C; color: #fff; padding: 6rpx 20rpx;
  border-radius: 20rpx; font-size: 24rpx; font-weight: 600;
}
.activity-info { padding: 24rpx; }
.activity-name { font-size: 32rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 16rpx; }

.price-row { display: flex; align-items: baseline; gap: 12rpx; margin-bottom: 12rpx; }
.group-price { font-size: 40rpx; font-weight: 700; color: #ff4d4f; }
.original-price { font-size: 24rpx; color: #666; text-decoration: line-through; }
.discount-tag {
  font-size: 22rpx; color: #FF6B2C; background: rgba(255,107,44,0.12);
  padding: 4rpx 12rpx; border-radius: 8rpx;
}

.stats-row { display: flex; gap: 24rpx; margin-bottom: 20rpx; }
.stat-text { font-size: 24rpx; color: #999; }
.expire-text { color: #faad14; }

.start-team-btn {
  width: 100% !important; height: 80rpx; line-height: 80rpx;
  background: #FF6B2C !important; color: #fff !important;
  border-radius: 40rpx; font-size: 30rpx; font-weight: 600;
}

/* Team Card */
.my-teams { padding: 0 32rpx; }
.team-card {
  background: #112228; border-radius: 16rpx; padding: 28rpx;
  margin-bottom: 20rpx;
}
.team-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.team-activity-name { font-size: 30rpx; font-weight: 600; color: #fff; }
.team-status { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 12rpx; }
.team-status.forming { background: rgba(24,144,255,0.15); color: #1890ff; }
.team-status.completed { background: rgba(82,196,26,0.15); color: #52c41a; }
.team-status.expired { background: rgba(255,255,255,0.06); color: #666; }

.team-progress { display: flex; align-items: center; gap: 12rpx; }
.progress-bar { flex: 1; height: 12rpx; background: rgba(255,255,255,0.08); border-radius: 6rpx; overflow: hidden; }
.progress-fill { height: 100%; background: #FF6B2C; border-radius: 6rpx; transition: width 0.3s; }
.progress-text { font-size: 24rpx; color: #ccc; }

/* Team Detail */
.team-detail { padding: 0 32rpx; }
.detail-hero {
  background: linear-gradient(135deg, #1a2a33, #0f3040);
  border-radius: 24rpx; padding: 40rpx; text-align: center; margin-bottom: 24rpx;
}
.detail-activity-name { font-size: 36rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 20rpx; }
.detail-price-row { display: flex; align-items: baseline; justify-content: center; gap: 16rpx; }
.detail-group-price { font-size: 52rpx; font-weight: 700; color: #ff4d4f; }
.detail-original-price { font-size: 26rpx; color: #666; text-decoration: line-through; }

.countdown-bar {
  display: flex; justify-content: space-between; align-items: center;
  background: rgba(250,173,20,0.1); border: 1rpx solid rgba(250,173,20,0.3);
  border-radius: 12rpx; padding: 20rpx 28rpx; margin-bottom: 24rpx;
}
.countdown-label { font-size: 26rpx; color: #faad14; }
.countdown-time { font-size: 30rpx; font-weight: 700; color: #faad14; font-family: monospace; }

.member-section { background: #112228; border-radius: 20rpx; padding: 28rpx; margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 24rpx; }
.member-list { display: flex; gap: 32rpx; flex-wrap: wrap; }
.member-avatar { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.avatar-circle {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: #FF6B2C; display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; color: #fff; font-weight: 600;
}
.avatar-circle.leader { border: 3rpx solid #faad14; }
.avatar-circle.waiting { background: rgba(255,255,255,0.06); color: #666; }
.avatar-label { font-size: 22rpx; color: #999; }

.detail-actions { display: flex; gap: 20rpx; }
.action-btn {
  flex: 1; height: 88rpx; line-height: 88rpx;
  border-radius: 44rpx; font-size: 30rpx; font-weight: 600;
}
.share-btn { background: rgba(255,255,255,0.06) !important; color: #ccc !important; }
.join-btn { background: #FF6B2C !important; color: #fff !important; }

.detail-result { text-align: center; padding: 60rpx 0; }
.result-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.result-text { font-size: 36rpx; font-weight: 700; color: #52c41a; display: block; margin-bottom: 8rpx; }
.result-sub { font-size: 26rpx; color: #999; display: block; }
.detail-result.expired .result-text { color: #999; }

/* Empty state */
.empty-state { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.empty-text { font-size: 30rpx; color: #ccc; display: block; margin-bottom: 8rpx; }
.empty-sub { font-size: 24rpx; color: #666; display: block; }
