.page-container {
  min-height: 100vh; background: #0B1A20;
  display: flex; align-items: center; justify-content: center;
}

.result-body {
  display: flex; flex-direction: column; align-items: center;
  padding: 0 64rpx; width: 100%;
}

/* ─── 大印章动画 ─── */
.stamp-anim-wrap {
  width: 240rpx; height: 300rpx;
  display: flex; align-items: flex-end; justify-content: center;
  margin-bottom: 48rpx; overflow: hidden;
}

.stamp-drop {
  opacity: 0; transform: translateY(-400rpx) rotate(30deg) scale(0.3);
}
.stamp-drop.animate {
  animation: stampFall 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s forwards;
}

@keyframes stampFall {
  0% {
    opacity: 0;
    transform: translateY(-400rpx) rotate(30deg) scale(0.3);
  }
  60% {
    opacity: 1;
    transform: translateY(10rpx) rotate(-8deg) scale(1.15);
  }
  80% {
    transform: translateY(-20rpx) rotate(3deg) scale(0.95);
  }
  100% {
    opacity: 1;
    transform: translateY(0) rotate(-12deg) scale(1);
  }
}

.big-stamp {
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: radial-gradient(circle, #FF3B30 0%, #CC2D25 60%, #A01F1A 100%);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(255,59,48,0.5),
              inset 0 -4rpx 12rpx rgba(0,0,0,0.2);
}
.big-stamp-text {
  font-size: 80rpx; font-weight: 900; color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

/* ─── 恭喜文字 ─── */
.congrats-section {
  text-align: center; margin-bottom: 48rpx;
}
.congrats-title {
  display: block; font-size: 38rpx; font-weight: 800; color: #FF6B35;
  margin-bottom: 16rpx;
}
.progress-info {
  display: block; font-size: 28rpx; color: #999;
}

/* ─── 下一档奖品 ─── */
.next-prize {
  width: 100%; margin-bottom: 48rpx;
}
.next-prize-card {
  background: linear-gradient(135deg, rgba(255,107,53,0.1) 0%, rgba(255,107,53,0.05) 100%);
  border: 1rpx solid rgba(255,107,53,0.2);
  border-radius: 20rpx; padding: 32rpx;
  text-align: center;
}
.next-prize-card.full {
  background: linear-gradient(135deg, rgba(82,196,26,0.1) 0%, rgba(82,196,26,0.05) 100%);
  border-color: rgba(82,196,26,0.3);
}
.next-label {
  display: block; font-size: 24rpx; color: #999; margin-bottom: 8rpx;
}
.next-name {
  display: block; font-size: 32rpx; font-weight: 700; color: #FF6B35;
  margin-bottom: 8rpx;
}
.next-gap {
  font-size: 26rpx; color: #ccc;
}
.gap-num {
  font-size: 36rpx; font-weight: 800; color: #FF6B35;
}
.full-text {
  font-size: 28rpx; font-weight: 600; color: #52c41a;
}

/* ─── 返回 ─── */
.back-hint {
  padding: 20rpx 40rpx;
}
.back-hint text {
  font-size: 24rpx; color: #666;
}
