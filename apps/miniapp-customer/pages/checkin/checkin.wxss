.page { background: #f8f8f8; min-height: 100vh; padding-bottom: 60rpx; }

/* ===== 顶部签到英雄区 ===== */
.checkin-hero {
  background: linear-gradient(135deg, #FF6B35, #FF9A5C);
  padding: 48rpx 32rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.streak-info {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.streak-num {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
}

.streak-label {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.85);
}

.streak-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 40rpx;
}

/* 签到按钮 */
.checkin-btn-wrap { margin-bottom: 24rpx; }

.checkin-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  transition: all 200ms ease;
  gap: 6rpx;
}

.checkin-btn.checked {
  background: rgba(255, 255, 255, 0.6);
  box-shadow: none;
}

.checkin-btn-icon { font-size: 48rpx; }

.checkin-btn-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B35;
}

.checkin-btn.checked .checkin-btn-text { color: rgba(255, 107, 53, 0.6); }

.checkin-btn-sub {
  font-size: 20rpx;
  color: #999;
}

.today-points {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.today-points-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

/* ===== 通用区块 ===== */
.section {
  background: #fff;
  margin-top: 16rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
}

/* ===== 连续签到奖励 ===== */
.reward-list {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.reward-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 8rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 200ms;
}

.reward-item.reached {
  background: #fff3ef;
  border-color: #FF6B35;
}

.reward-icon-wrap {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reward-icon { font-size: 40rpx; }

.reward-check {
  position: absolute;
  right: -6rpx;
  bottom: -6rpx;
  width: 28rpx;
  height: 28rpx;
  background: #FF6B35;
  border-radius: 50%;
  font-size: 16rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 28rpx;
  text-align: center;
}

.reward-days {
  font-size: 22rpx;
  color: #333;
  font-weight: bold;
}

.reward-desc {
  font-size: 18rpx;
  color: #999;
  text-align: center;
}

.reward-item.reached .reward-days { color: #FF6B35; }
.reward-item.reached .reward-desc { color: #FF6B35; }

/* ===== 日历 ===== */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title { margin-bottom: 0; }

.calendar-stats {
  font-size: 24rpx;
  color: #999;
}

.calendar-weekdays {
  display: flex;
  margin-bottom: 12rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #999;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.calendar-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 4rpx;
  gap: 2rpx;
}

.calendar-cell.empty { background: transparent; }

.calendar-day {
  font-size: 24rpx;
  color: #333;
  line-height: 1.2;
}

.calendar-cell.future .calendar-day { color: #ccc; }

.calendar-cell.today .calendar-day {
  color: #FF6B35;
  font-weight: bold;
}

.calendar-cell.checked {
  background: rgba(255, 107, 53, 0.08);
  border-radius: 8rpx;
}

.calendar-cell.checked .calendar-day { color: #FF6B35; font-weight: bold; }

.calendar-dot {
  font-size: 16rpx;
  color: #FF6B35;
}

/* ===== 积分明细链接 ===== */
.link-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  cursor: pointer;
}

.link-label {
  font-size: 28rpx;
  color: #333;
}

.link-arrow {
  font-size: 32rpx;
  color: #ccc;
}
