.page-container { min-height: 100vh; background: #0B1A20; }

/* ──── 状态Tab ──── */
.tab-bar {
  display: flex;
  margin: 24rpx 32rpx;
  background: #112228;
  border-radius: 16rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #999;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-item.active {
  background: #FF6B35;
  color: #fff;
  font-weight: 600;
}

/* ──── 兑换卡片列表 ──── */
.record-list { padding: 0 32rpx; }

.record-card {
  background: #112228;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.record-card.expired { opacity: 0.6; }

.card-main {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.record-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.record-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.record-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.meta-cost { font-size: 24rpx; color: #FF6B35; }
.meta-time { font-size: 24rpx; color: #666; }

.record-status-row { margin-top: 8rpx; }

.status-badge {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.status-badge.pending {
  color: #0F6E56;
  background: rgba(15, 110, 86, 0.15);
}

.status-badge.used {
  color: #666;
  background: rgba(255,255,255,0.06);
}

.status-badge.expired {
  color: #E55A28;
  background: rgba(229, 90, 40, 0.12);
}

/* ──── 核销码区域 ──── */
.code-section { padding: 0 24rpx 24rpx; }

.code-divider {
  height: 1rpx;
  background: rgba(255,255,255,0.06);
  margin-bottom: 20rpx;
}

.code-area {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #1a2a33;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.code-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.code-label { font-size: 22rpx; color: #666; }
.code-value { font-size: 28rpx; color: #fff; font-weight: 600; letter-spacing: 2rpx; }
.code-arrow { font-size: 24rpx; color: #FF6B35; }

/* ──── 状态提示 ──── */
.loading-tip { text-align: center; padding: 80rpx 0; color: #666; font-size: 28rpx; }
.load-more-tip { text-align: center; padding: 32rpx; font-size: 24rpx; color: #555; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 16rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #666; }

.go-mall-btn {
  margin-top: 32rpx;
  background: #FF6B35 !important;
  color: #fff !important;
  font-size: 28rpx;
  border-radius: 32rpx;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 72rpx;
}

.safe-bottom { height: 40rpx; }

/* ──── 核销码弹窗 ──── */
.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.65);
  z-index: 200;
}

.code-popup {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #112228;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 201;
  transform: translateY(100%);
  transition: transform 300ms ease-out;
}

.code-popup.show { transform: translateY(0); }

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.popup-title { font-size: 34rpx; font-weight: bold; color: #fff; }
.popup-close { font-size: 32rpx; color: #666; padding: 8rpx; }

.popup-item-name {
  font-size: 28rpx;
  color: #ccc;
  text-align: center;
  margin-bottom: 32rpx;
}

.qr-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.qr-canvas {
  width: 400rpx;
  height: 400rpx;
  background: #fff;
  border-radius: 16rpx;
}

.qr-tip { font-size: 24rpx; color: #666; }

.code-display {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.code-number {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}

.code-copy {
  font-size: 24rpx;
  color: #FF6B35;
  border: 1rpx solid #FF6B35;
  padding: 6rpx 20rpx;
  border-radius: 16rpx;
}

.code-expire {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #666;
}
