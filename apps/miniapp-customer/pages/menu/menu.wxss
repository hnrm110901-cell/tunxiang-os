.menu-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0B1A20;
  color: #fff;
}

/* ─── 顶部 ─── */
.menu-header {
  padding: 24rpx 32rpx;
  background: #112228;
  flex-shrink: 0;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.store-name { font-size: 34rpx; font-weight: bold; }

.table-tag {
  font-size: 24rpx;
  color: #FF6B2C;
  background: rgba(255, 107, 44, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #1a2a33;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 68rpx;
}

.search-input { flex: 1; font-size: 28rpx; color: #fff; }
.search-placeholder { color: #666; }
.search-clear { color: #999; font-size: 28rpx; padding: 8rpx; }

/* ─── 加载 ─── */
.loading-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text { color: #999; font-size: 28rpx; }

/* ─── 分类 + 菜品双栏 ─── */
.menu-body {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.category-nav {
  width: 176rpx;
  background: #112228;
  flex-shrink: 0;
  height: 100%;
}

.category-item {
  padding: 28rpx 16rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  position: relative;
}

.category-item.active {
  color: #FF6B2C;
  font-weight: 600;
  background: #0B1A20;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 25%;
  bottom: 25%;
  width: 6rpx;
  background: #FF6B2C;
  border-radius: 3rpx;
}

.dish-list {
  flex: 1;
  padding: 0 24rpx;
  padding-bottom: 200rpx;
  height: 100%;
}

/* ─── 购物车弹层 ─── */
.cart-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 99;
}

.cart-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #112228;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 300ms ease-out;
  max-height: 60vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.cart-popup.show {
  transform: translateY(0);
}

.cart-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #1a2a33;
}

.cart-popup-title { font-size: 30rpx; font-weight: bold; color: #fff; }
.cart-popup-clear { font-size: 26rpx; color: #999; }

.cart-popup-list {
  max-height: 50vh;
  padding: 0 32rpx;
}

.cart-popup-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #1a2a33;
}

.cart-item-name { font-size: 28rpx; color: #fff; flex: 1; }

.cart-item-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cart-item-price { font-size: 28rpx; color: #FF6B2C; font-weight: bold; }

.cart-item-qty {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qty-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #1a2a33;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  text-align: center;
  line-height: 44rpx;
}

.qty-btn.plus { background: #FF6B2C; color: #fff; }
.qty-num { font-size: 28rpx; color: #fff; min-width: 32rpx; text-align: center; }

.empty-state { text-align: center; color: #666; font-size: 28rpx; padding: 120rpx 0; }
