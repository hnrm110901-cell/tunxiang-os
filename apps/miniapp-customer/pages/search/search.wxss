.search-page {
  min-height: 100vh;
  background: #0B1A20;
}

/* ─── Top search bar ─── */
.search-top {
  display: flex;
  align-items: center;
  padding: 60rpx 24rpx 20rpx;
  background: #112228;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-input-icon {
  font-size: 32rpx;
  color: #999;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
  height: 40rpx;
}

.search-input-placeholder {
  color: #666;
  font-size: 28rpx;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-clear-icon {
  font-size: 28rpx;
  color: #999;
  width: 32rpx;
  height: 32rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  text-align: center;
  line-height: 32rpx;
}

.search-cancel {
  font-size: 28rpx;
  color: #FF6B2C;
  flex-shrink: 0;
  padding: 0 8rpx;
}

/* ─── Before search: history + hot ─── */
.search-before {
  padding: 32rpx;
}

.history-section {
  margin-bottom: 40rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.history-clear {
  font-size: 24rpx;
  color: #999;
}

.hot-section {
  margin-bottom: 40rpx;
}

.hot-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
  display: block;
  margin-bottom: 20rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
}

.tag-item text {
  font-size: 26rpx;
  color: #ccc;
}

.tag-item.hot {
  background: rgba(255, 107, 44, 0.1);
}

.tag-item.hot text {
  color: #FF6B2C;
}

/* ─── Result tabs ─── */
.result-tabs {
  display: flex;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.06);
  padding: 0 32rpx;
}

.result-tab {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  font-size: 28rpx;
  color: #999;
  border-bottom: 4rpx solid transparent;
  margin-right: 16rpx;
}

.result-tab.active {
  color: #FF6B2C;
  border-bottom-color: #FF6B2C;
  font-weight: 600;
}

.result-tab-count {
  font-size: 24rpx;
}

/* ─── Loading & empty ─── */
.loading-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0 80rpx;
}

.empty-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #666;
}

/* ─── Dish results ─── */
.result-list {
  padding: 16rpx 32rpx;
}

.dish-result-item {
  display: flex;
  align-items: center;
  background: #112228;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  gap: 20rpx;
}

.dish-result-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.dish-result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-result-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.dish-result-store {
  font-size: 24rpx;
  color: #999;
}

.dish-result-price {
  font-size: 28rpx;
  color: #FF6B2C;
  font-weight: bold;
}

/* ─── Store results ─── */
.store-result-item {
  background: #112228;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.store-result-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.store-result-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.store-result-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.store-result-rating {
  font-size: 24rpx;
  color: #FFB800;
  font-weight: 600;
}

.store-result-distance {
  font-size: 24rpx;
  color: #FF6B2C;
}

.store-result-address {
  font-size: 24rpx;
  color: #999;
}
