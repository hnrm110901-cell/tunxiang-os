/* 确认下单页 */
.confirm-page {
  padding-bottom: 200rpx;
}

.table-info-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: var(--tx-bg-2);
  margin-bottom: 16rpx;
}

.table-info-label {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--tx-primary);
}

.table-info-hint {
  font-size: 24rpx;
  color: var(--tx-text-3);
}

/* 菜品列表 */
.order-items-section {
  background: var(--tx-bg-2);
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--tx-text-1);
  margin-bottom: 16rpx;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--tx-border);
}

.order-item:last-child {
  border-bottom: none;
}

.item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--tx-radius-sm);
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: var(--tx-text-1);
  margin-bottom: 8rpx;
  display: block;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.item-price {
  font-size: 24rpx;
  color: var(--tx-text-3);
}

.item-qty {
  font-size: 24rpx;
  color: var(--tx-text-3);
}

.item-subtotal {
  font-size: 28rpx;
  color: var(--tx-primary);
  font-weight: 500;
  margin-left: auto;
}

/* 备注 */
.remark-section {
  background: var(--tx-bg-2);
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.remark-input {
  width: 100%;
  min-height: 80rpx;
  padding: 16rpx;
  background: var(--tx-bg-3);
  border-radius: var(--tx-radius-md);
  font-size: 26rpx;
  color: var(--tx-text-1);
}

/* 合计 */
.total-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--tx-bg-2);
  margin-bottom: 24rpx;
}

.total-label {
  font-size: 30rpx;
  color: var(--tx-text-1);
}

.total-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--tx-primary);
}

/* 提交按钮 */
.submit-section {
  padding: 0 32rpx;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: var(--tx-primary);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: var(--tx-radius-lg);
}

.btn-submit.disabled {
  opacity: 0.6;
}

.btn-submit:active:not(.disabled) {
  background: var(--tx-primary-active);
}

/* 提交成功 */
.success-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.success-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(15, 110, 86, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.success-icon-text {
  font-size: 72rpx;
  color: var(--tx-success);
}

.success-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--tx-text-1);
  margin-bottom: 16rpx;
}

.success-hint {
  font-size: 26rpx;
  color: var(--tx-text-3);
  margin-bottom: 60rpx;
}

.success-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-continue {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--tx-primary);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--tx-radius-lg);
}

.btn-status {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--tx-bg-3);
  color: var(--tx-text-1);
  font-size: 30rpx;
  border-radius: var(--tx-radius-lg);
}

.btn-checkout {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: transparent;
  color: var(--tx-primary);
  font-size: 30rpx;
  border: 2rpx solid var(--tx-primary);
  border-radius: var(--tx-radius-lg);
}
