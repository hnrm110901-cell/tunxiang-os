/* 等待出餐页 */
.status-page {
  padding-bottom: 200rpx;
}

/* 顶部状态 */
.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: var(--tx-bg-2, #112228);
  margin-bottom: 16rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.table-no {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF6B2C;
}

.status-order-no {
  font-size: 26rpx;
  color: var(--tx-text-3, #999);
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: var(--tx-radius-sm, 8rpx);
  font-size: 24rpx;
  font-weight: 600;
}

.status-pending, .status-open, .status-confirmed {
  background: rgba(24, 95, 165, 0.15);
  color: var(--tx-info, #185FA5);
}

.status-cooking, .status-dining {
  background: rgba(186, 117, 23, 0.15);
  color: var(--tx-warning, #BA7517);
}

.status-completed, .status-ready {
  background: rgba(15, 110, 86, 0.15);
  color: var(--tx-success, #0F6E56);
}

.status-pending_checkout {
  background: rgba(255, 107, 44, 0.15);
  color: var(--tx-primary, #FF6B2C);
}

.status-cancelled {
  background: rgba(163, 45, 45, 0.15);
  color: var(--tx-danger, #A32D2D);
}

/* 进度概览 */
.progress-overview {
  padding: 32rpx;
  background: var(--tx-bg-2, #112228);
  margin-bottom: 16rpx;
}

.progress-bar-wrap {
  width: 100%;
  height: 12rpx;
  background: var(--tx-bg-3, #1a2a33);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.progress-bar {
  height: 100%;
  background: var(--tx-success, #0F6E56);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--tx-text-1, #fff);
}

.stat-label {
  font-size: 22rpx;
  color: var(--tx-text-3, #999);
  margin-top: 4rpx;
}

.stat-cooking .stat-value {
  color: var(--tx-warning, #BA7517);
}

.stat-done .stat-value {
  color: var(--tx-success, #0F6E56);
}

/* 菜品进度列表 */
.items-section {
  padding: 24rpx 32rpx;
  background: var(--tx-bg-2, #112228);
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--tx-text-1, #fff);
  margin-bottom: 16rpx;
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--tx-border, #1a2a33);
}

.status-item:last-child {
  border-bottom: none;
}

.status-item.done {
  opacity: 0.7;
}

.status-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.status-icon {
  font-size: 36rpx;
  width: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.status-item-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-item-name {
  font-size: 28rpx;
  color: var(--tx-text-1, #fff);
}

.status-item-qty {
  font-size: 24rpx;
  color: var(--tx-text-3, #999);
}

.status-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.status-item-kds {
  font-size: 24rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: var(--tx-radius-sm, 8rpx);
}

.status-item-kds.not_submitted {
  color: var(--tx-text-3, #999);
  background: var(--tx-bg-3, #1a2a33);
}

.status-item-kds.pending {
  color: var(--tx-info, #185FA5);
  background: rgba(24, 95, 165, 0.15);
}

.status-item-kds.cooking {
  color: var(--tx-warning, #BA7517);
  background: rgba(186, 117, 23, 0.15);
}

.status-item-kds.done {
  color: var(--tx-success, #0F6E56);
  background: rgba(15, 110, 86, 0.15);
}

.status-item-station {
  font-size: 20rpx;
  color: var(--tx-text-3, #999);
}

/* 全部出餐 */
.all-done-banner {
  margin: 32rpx;
  padding: 24rpx;
  background: rgba(15, 110, 86, 0.15);
  border: 1rpx solid rgba(15, 110, 86, 0.3);
  border-radius: var(--tx-radius-md, 12rpx);
  text-align: center;
}

.all-done-text {
  font-size: 30rpx;
  color: var(--tx-success, #0F6E56);
  font-weight: 600;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--tx-bg-2, #112228);
  border-top: 1rpx solid var(--tx-border, #1a2a33);
}

.btn-continue {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--tx-bg-3, #1a2a33) !important;
  color: var(--tx-text-1, #fff) !important;
  font-size: 30rpx;
  border-radius: var(--tx-radius-lg, 16rpx);
}

.btn-checkout {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--tx-primary, #FF6B2C) !important;
  color: #fff !important;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--tx-radius-lg, 16rpx);
}

/* 加载 + 空状态 */
.loading-wrap {
  padding: 80rpx;
  text-align: center;
}

.loading-text {
  color: var(--tx-text-3, #999);
  font-size: 28rpx;
}

.empty-tip {
  padding: 60rpx 0;
  text-align: center;
  color: var(--tx-text-3, #999);
}
