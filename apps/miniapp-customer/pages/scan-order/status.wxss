/* 订单状态页 */
.status-page {
  padding-bottom: 200rpx;
}

/* 顶部状态 */
.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: var(--tx-bg-2);
  margin-bottom: 16rpx;
}

.status-order-no {
  font-size: 26rpx;
  color: var(--tx-text-3);
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: var(--tx-radius-sm);
  font-size: 24rpx;
  font-weight: 600;
}

.status-pending, .status-open, .status-confirmed {
  background: rgba(24, 95, 165, 0.15);
  color: var(--tx-info);
}

.status-cooking, .status-dining {
  background: rgba(186, 117, 23, 0.15);
  color: var(--tx-warning);
}

.status-completed, .status-ready {
  background: rgba(15, 110, 86, 0.15);
  color: var(--tx-success);
}

.status-pending_checkout {
  background: rgba(255, 107, 44, 0.15);
  color: var(--tx-primary);
}

.status-cancelled {
  background: rgba(163, 45, 45, 0.15);
  color: var(--tx-danger);
}

/* 进度概览 */
.progress-overview {
  padding: 32rpx;
  background: var(--tx-bg-2);
  margin-bottom: 16rpx;
}

.progress-bar-wrap {
  width: 100%;
  height: 12rpx;
  background: var(--tx-bg-3);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.progress-bar {
  height: 100%;
  background: var(--tx-success);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--tx-text-1);
}

.stat-label {
  font-size: 22rpx;
  color: var(--tx-text-3);
  margin-top: 4rpx;
}

.stat-cooking .stat-value {
  color: var(--tx-warning);
}

.stat-done .stat-value {
  color: var(--tx-success);
}

/* 菜品进度列表 */
.items-section {
  padding: 24rpx 32rpx;
  background: var(--tx-bg-2);
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--tx-text-1);
  margin-bottom: 16rpx;
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--tx-border);
}

.status-item:last-child {
  border-bottom: none;
}

.status-item.done {
  opacity: 0.7;
}

.status-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-dot.not_submitted {
  background: var(--tx-text-3);
}

.status-dot.pending {
  background: var(--tx-info);
}

.status-dot.cooking {
  background: var(--tx-warning);
  animation: blink 1s ease-in-out infinite;
}

.status-dot.done {
  background: var(--tx-success);
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.status-item-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-item-name {
  font-size: 28rpx;
  color: var(--tx-text-1);
}

.status-item-qty {
  font-size: 24rpx;
  color: var(--tx-text-3);
}

.status-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.status-item-kds {
  font-size: 24rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: var(--tx-radius-sm);
}

.status-item-kds.not_submitted {
  color: var(--tx-text-3);
  background: var(--tx-bg-3);
}

.status-item-kds.pending {
  color: var(--tx-info);
  background: rgba(24, 95, 165, 0.15);
}

.status-item-kds.cooking {
  color: var(--tx-warning);
  background: rgba(186, 117, 23, 0.15);
}

.status-item-kds.done {
  color: var(--tx-success);
  background: rgba(15, 110, 86, 0.15);
}

.status-item-station {
  font-size: 20rpx;
  color: var(--tx-text-3);
}

/* 全部出餐 */
.all-done-banner {
  margin: 32rpx;
  padding: 24rpx;
  background: rgba(15, 110, 86, 0.15);
  border: 1rpx solid rgba(15, 110, 86, 0.3);
  border-radius: var(--tx-radius-md);
  text-align: center;
}

.all-done-text {
  font-size: 30rpx;
  color: var(--tx-success);
  font-weight: 600;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: var(--tx-bg-2);
  border-top: 1rpx solid var(--tx-border);
}

.btn-continue {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--tx-bg-3);
  color: var(--tx-text-1);
  font-size: 30rpx;
  border-radius: var(--tx-radius-lg);
}

.btn-checkout {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--tx-primary);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--tx-radius-lg);
}

/* 加载 + 空状态 */
.loading-wrap {
  padding: 80rpx;
  text-align: center;
}

.loading-text {
  color: var(--tx-text-3);
  font-size: 28rpx;
}

.empty-tip {
  padding: 60rpx 0;
  text-align: center;
  color: var(--tx-text-3);
}
