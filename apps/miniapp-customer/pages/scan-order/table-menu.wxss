/* 桌台菜单页 */
.table-menu-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* 桌号横条 */
.table-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--tx-bg-2);
  border-bottom: 1rpx solid var(--tx-border);
}

.table-bar-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.table-no-label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--tx-primary);
}

.table-order-hint {
  font-size: 22rpx;
  color: var(--tx-warning);
  background: rgba(186, 117, 23, 0.15);
  padding: 4rpx 12rpx;
  border-radius: var(--tx-radius-sm);
}

.table-status-link {
  font-size: 26rpx;
  color: var(--tx-primary);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: var(--tx-bg-2);
}

.search-input {
  flex: 1;
  height: 64rpx;
  background: var(--tx-bg-3);
  border-radius: var(--tx-radius-md);
  padding: 0 24rpx;
  font-size: 26rpx;
  color: var(--tx-text-1);
}

.search-clear {
  margin-left: 16rpx;
  color: var(--tx-text-3);
  font-size: 28rpx;
}

/* 主体区域 */
.menu-body {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类 */
.category-sidebar {
  width: 180rpx;
  background: var(--tx-bg-2);
  border-right: 1rpx solid var(--tx-border);
}

.cat-item {
  padding: 24rpx 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--tx-text-2);
  border-left: 4rpx solid transparent;
}

.cat-item.active {
  color: var(--tx-primary);
  background: var(--tx-bg-1);
  border-left-color: var(--tx-primary);
  font-weight: 600;
}

/* 右侧菜品列表 */
.dish-list {
  flex: 1;
  padding: 12rpx 16rpx;
  padding-bottom: 200rpx;
}

.dish-card {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--tx-border);
}

.dish-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--tx-radius-md);
  flex-shrink: 0;
  background: var(--tx-bg-3);
}

.dish-img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 48rpx;
  color: var(--tx-text-3);
}

.dish-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--tx-text-1);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dish-recommend {
  font-size: 22rpx;
  color: var(--tx-primary);
  margin-top: 4rpx;
}

.dish-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dish-price {
  font-size: 32rpx;
  color: var(--tx-primary);
  font-weight: 600;
}

.dish-price::before {
  content: '¥';
  font-size: 22rpx;
}

.dish-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-plus, .btn-minus {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.btn-plus {
  background: var(--tx-primary);
  color: #fff;
}

.btn-minus {
  background: var(--tx-bg-3);
  color: var(--tx-text-2);
}

.cart-qty {
  font-size: 28rpx;
  color: var(--tx-text-1);
  min-width: 40rpx;
  text-align: center;
}

/* 已点菜品提示条 */
.existing-bar {
  position: fixed;
  bottom: 130rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(186, 117, 23, 0.15);
  border: 1rpx solid rgba(186, 117, 23, 0.3);
  border-radius: var(--tx-radius-md);
  z-index: 50;
}

.existing-label {
  font-size: 24rpx;
  color: var(--tx-warning);
}

.existing-action {
  font-size: 24rpx;
  color: var(--tx-primary);
  font-weight: 600;
}

/* 底部购物车栏 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  height: 110rpx;
  padding: 0 24rpx;
  background: var(--tx-bg-2);
  border-top: 1rpx solid var(--tx-border);
  z-index: 100;
}

.cart-bar-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cart-icon-wrap {
  position: relative;
}

.cart-icon-text {
  font-size: 48rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -12rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 20rpx;
  color: #fff;
  background: var(--tx-primary);
  border-radius: 16rpx;
  padding: 0 6rpx;
}

.cart-total {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--tx-text-1);
}

.cart-empty-hint {
  font-size: 26rpx;
  color: var(--tx-text-3);
}

.cart-bar-btn {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: var(--tx-radius-lg);
  font-size: 28rpx;
  font-weight: 600;
  background: var(--tx-bg-3);
  color: var(--tx-text-3);
}

.cart-bar-btn.active {
  background: var(--tx-primary);
  color: #fff;
}

/* 购物车弹层 */
.cart-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.cart-popup {
  position: fixed;
  bottom: 110rpx;
  left: 0;
  right: 0;
  max-height: 60vh;
  background: var(--tx-bg-2);
  border-radius: var(--tx-radius-lg) var(--tx-radius-lg) 0 0;
  z-index: 201;
  display: flex;
  flex-direction: column;
}

.cart-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--tx-border);
}

.cart-popup-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--tx-text-1);
}

.cart-popup-clear {
  font-size: 26rpx;
  color: var(--tx-text-3);
}

.cart-popup-list {
  max-height: 50vh;
  padding: 0 32rpx;
}

.cart-popup-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--tx-border);
}

.cart-item-name {
  font-size: 28rpx;
  color: var(--tx-text-1);
  flex: 1;
}

.cart-item-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.cart-item-price {
  font-size: 28rpx;
  color: var(--tx-primary);
}

.cart-item-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cart-item-qty {
  font-size: 28rpx;
  color: var(--tx-text-1);
  min-width: 40rpx;
  text-align: center;
}

/* 加载 */
.loading-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  color: var(--tx-text-3);
  font-size: 28rpx;
}

.empty-tip {
  padding: 80rpx 0;
  text-align: center;
  color: var(--tx-text-3);
  font-size: 28rpx;
}
