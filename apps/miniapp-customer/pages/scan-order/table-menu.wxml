<!-- 桌台菜单 — 含购物车 + 同桌共享 -->
<view class="page-container table-menu-page">
  <!-- 桌号横条 -->
  <view class="table-bar">
    <view class="table-bar-left">
      <text class="table-no-label">{{tableId}}号桌</text>
      <text class="table-order-hint" wx:if="{{!isNewOrder}}">同桌已有订单</text>
    </view>
    <view class="table-bar-right" bindtap="viewStatus" wx:if="{{orderId}}">
      <text class="table-status-link">订单状态</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索菜品" value="{{searchKeyword}}"
           bindinput="onSearchInput" />
    <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">X</text>
  </view>

  <!-- 主体区域 -->
  <view class="menu-body" wx:if="{{!loading}}">
    <!-- 左侧分类栏 -->
    <scroll-view class="category-sidebar" scroll-y>
      <view class="cat-item {{activeCategoryId === item.id ? 'active' : ''}}"
            wx:for="{{categories}}" wx:key="id"
            bindtap="selectCategory" data-id="{{item.id}}">
        <text>{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 右侧菜品列表 -->
    <scroll-view class="dish-list" scroll-y>
      <view class="dish-card" wx:for="{{filteredDishes}}" wx:key="id">
        <image class="dish-img" src="{{item.imageUrl}}" mode="aspectFill"
               wx:if="{{item.imageUrl}}" />
        <view class="dish-img dish-img-placeholder" wx:else>
          <text class="placeholder-text">{{item.name[0] || ''}}</text>
        </view>
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-recommend" wx:if="{{item.recommendReason}}">{{item.recommendReason}}</text>
          <view class="dish-bottom">
            <text class="dish-price">{{item.priceYuan}}</text>
            <view class="dish-actions">
              <view class="btn-minus" bindtap="minusFromCart" data-dishid="{{item.id}}"
                    wx:if="{{item._cartQty > 0}}">
                <text>-</text>
              </view>
              <text class="cart-qty" wx:if="{{item._cartQty > 0}}">{{item._cartQty}}</text>
              <view class="btn-plus" bindtap="addToCart" data-dish="{{item}}">
                <text>+</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="empty-tip" wx:if="{{filteredDishes.length === 0}}">
        <text>暂无菜品</text>
      </view>
    </scroll-view>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">加载菜单中...</text>
  </view>

  <!-- 已点菜品提示（同桌共享） -->
  <view class="existing-bar" wx:if="{{existingItems.length > 0 && !showCartPopup}}"
        bindtap="viewExistingItems">
    <text class="existing-label">同桌已点 {{existingItems.length}} 道菜</text>
    <text class="existing-action">查看</text>
  </view>

  <!-- 底部购物车栏 -->
  <view class="cart-bar" wx:if="{{!loading}}">
    <view class="cart-bar-left" bindtap="showCart">
      <view class="cart-icon-wrap">
        <text class="cart-icon-text">🛒</text>
        <text class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</text>
      </view>
      <text class="cart-total" wx:if="{{cartCount > 0}}">
        ¥{{(cartTotalFen / 100).toFixed(2)}}
      </text>
      <text class="cart-empty-hint" wx:else>未选择菜品</text>
    </view>
    <view class="cart-bar-btn {{cartCount > 0 ? 'active' : ''}}" bindtap="goToConfirm">
      <text>选好了</text>
    </view>
  </view>

  <!-- 购物车弹层 -->
  <view class="cart-popup-mask" wx:if="{{showCartPopup}}" bindtap="closeCartPopup"></view>
  <view class="cart-popup" wx:if="{{showCartPopup}}">
    <view class="cart-popup-header">
      <text class="cart-popup-title">已选菜品</text>
      <text class="cart-popup-clear" bindtap="clearCart">清空</text>
    </view>
    <scroll-view class="cart-popup-list" scroll-y>
      <view class="cart-popup-item" wx:for="{{cartItems}}" wx:key="index">
        <text class="cart-item-name">{{item.dish.name}}</text>
        <view class="cart-item-right">
          <text class="cart-item-price">¥{{((item.dish.priceFen || 0) * item.quantity / 100).toFixed(2)}}</text>
          <view class="cart-item-actions">
            <view class="btn-minus" bindtap="minusFromCart" data-dishid="{{item.dish.id}}">
              <text>-</text>
            </view>
            <text class="cart-item-qty">{{item.quantity}}</text>
            <view class="btn-plus" bindtap="addToCart" data-dish="{{item.dish}}">
              <text>+</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
