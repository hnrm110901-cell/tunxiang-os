/* 扫码入口页 */
.scan-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 40rpx;
}

.scan-icon-wrap {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: var(--tx-bg-3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.scan-icon {
  width: 120rpx;
  height: 120rpx;
}

.scan-hint {
  color: var(--tx-text-2);
  font-size: 30rpx;
  margin-top: 20rpx;
}

.scan-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--tx-text-1);
  margin-bottom: 16rpx;
}

.scan-desc {
  color: var(--tx-text-3);
  font-size: 26rpx;
  margin-bottom: 60rpx;
}

.btn-scan {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--tx-primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--tx-radius-lg);
}

.btn-scan:active {
  background: var(--tx-primary-active);
}

/* 错误状态 */
.scan-error {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.error-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(163, 45, 45, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.error-icon {
  font-size: 60rpx;
  color: var(--tx-danger);
  font-weight: 700;
}

.error-msg {
  color: var(--tx-text-2);
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 48rpx;
  padding: 0 40rpx;
}

.btn-retry {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--tx-primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--tx-radius-lg);
}

/* 加载动画 */
.scan-loading .scan-icon-wrap {
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.7; }
}
