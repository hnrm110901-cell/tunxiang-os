.ai-recommend {
  margin: 24rpx 0;
  padding: 0 32rpx;
}

.recommend-header {
  margin-bottom: 20rpx;
}

.recommend-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.ai-badge {
  background: linear-gradient(135deg, #FF6B2C, #FF9F5C);
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.recommend-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.recommend-subtitle {
  font-size: 24rpx;
  color: #999;
}

.recommend-loading {
  text-align: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 4-grid layout (2x2) */
.recommend-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.recommend-card {
  width: calc(50% - 10rpx);
  background: #112228;
  border-radius: 20rpx;
  overflow: hidden;
}

.recommend-img {
  width: 100%;
  height: 200rpx;
}

.recommend-body {
  padding: 16rpx;
}

.recommend-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-reason {
  font-size: 20rpx;
  color: #FF6B2C;
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommend-orders {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.recommend-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.recommend-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF6B2C;
}

.recommend-add-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FF6B2C;
  color: #fff;
  font-size: 32rpx;
  text-align: center;
  line-height: 48rpx;
}
