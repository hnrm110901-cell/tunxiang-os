.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.badge-icon {
  font-size: 24rpx;
}

.badge-text {
  font-weight: 600;
}

/* 等级样式 */
.badge-normal {
  background: rgba(153, 153, 153, 0.15);
  color: #999;
}

.badge-silver {
  background: linear-gradient(135deg, rgba(192, 192, 192, 0.2), rgba(220, 220, 220, 0.15));
  color: #C0C0C0;
}

.badge-gold {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2), rgba(255, 193, 7, 0.15));
  color: #FFC107;
}

.badge-platinum {
  background: linear-gradient(135deg, rgba(229, 228, 226, 0.2), rgba(200, 200, 200, 0.15));
  color: #E5E4E2;
}

.badge-diamond {
  background: linear-gradient(135deg, rgba(185, 242, 255, 0.2), rgba(0, 191, 255, 0.15));
  color: #00BFFF;
}
