# ─── 灰度环境变量 ───
# 关键：灰度共用生产数据库，只是跑新版本代码
# 用法: cp .env.gray.example .env.gray
#        docker-compose -f docker-compose.gray.yml --env-file .env.gray up -d

# ── 生产数据库连接（共用，不是独立库） ──
POSTGRES_USER=tunxiang
POSTGRES_PASSWORD=SAME_AS_PROD_PASSWORD
POSTGRES_DB=tunxiang_os

# ── Redis（用 db3 隔离灰度缓存） ──
REDIS_PASSWORD=SAME_AS_PROD_REDIS

# ── AI ──
ANTHROPIC_API_KEY=
