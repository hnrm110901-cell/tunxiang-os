        "tx-supply": {"port": 8006, "description": "供应链"},
        "tx-finance": {"port": 8007, "description": "财务结算"},
        "tx-agent": {"port": 8008, "description": "Agent OS"},
        "tx-analytics": {"port": 8009, "description": "经营分析"},
        "tx-brain": {"port": 8010, "description": "AI决策"},
        "tx-intel": {"port": 8011, "description": "商业智能"},
