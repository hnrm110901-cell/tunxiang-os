    "sunmi_t2": {
      "role": "POS收银主机",
      "model": "商米T2",
      "ip": "192.168.10.30",
      "connection": "wifi",
      "web_url": "http://192.168.10.10/pos/",
      "peripherals": {
        "printer": {
          "type": "network",
          "protocol": "ESC/POS over TCP",
          "ip": "192.168.10.20",
          "port": 9100,
          "model": "佳博网络80",
          "paper_width": "80mm"
        },
        "cash_box": {
          "type": "usb_rj11",
          "connection": "USB→RJ11线连接T2",
          "trigger": "打印机脉冲或TXBridge.openCashBox()"
        },
        "scanner": {
          "type": "usb",
          "model": "新大陆NLS-HR15（建议）",
          "connection": "USB连接T2"
        }
      }
    },

    "sunmi_v2": {
      "role": "移动POS / 服务员点餐",
      "model": "商米V2",
      "ip": "192.168.10.31",
      "connection": "wifi",
      "web_url": "http://192.168.10.10/crew/",
      "peripherals": {
        "printer": {
          "type": "builtin",
          "description": "V2内置58mm热敏打印（小票）",
          "paper_width": "58mm"
        }
      }
    },

    "sunmi_kds_d2s": {
      "role": "后厨出餐显示屏",
      "model": "商米KDS D2s",
      "ip": "192.168.10.40",
      "connection": "wifi",
      "web_url": "http://192.168.10.10/kds/",
      "display": {
        "orientation": "landscape",
        "fullscreen": true,
        "auto_refresh": true
      }
    },

    "gainscha_printer": {
      "role": "网络热敏打印机",
      "model": "佳博网络80",
      "ip": "192.168.10.20",
      "connection": "ethernet",
      "protocol": "ESC/POS over TCP",
      "port": 9100,
      "paper_width": "80mm",
      "config": {
        "default_ip": "192.168.123.100",
        "target_ip": "192.168.10.20",
        "setup_method": "自检页获取默认IP → 浏览器访问Web管理界面 → 修改IP"
      }
    }
