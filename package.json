{
  "name": "tunxiang-os",
  "version": "3.0.0",
  "private": true,
  "description": "TunxiangOS - AI-Native Restaurant Chain Operating System",
  "scripts": {
    "dev:pos": "pnpm --filter web-pos dev",
    "dev:kds": "pnpm --filter web-kds dev",
    "dev:crew": "pnpm --filter web-crew dev",
    "dev:admin": "pnpm --filter web-admin dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:ui": "node scripts/lint-ui/all.mjs",
    "lint:no-antd-in-store": "node scripts/lint-ui/no-antd-in-store.mjs",
    "lint:hardcoded-color": "node scripts/lint-ui/hardcoded-color.mjs",
    "lint:tap-target": "node scripts/lint-ui/tap-target.mjs",
    "lint:font-size": "node scripts/lint-ui/font-size.mjs",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
